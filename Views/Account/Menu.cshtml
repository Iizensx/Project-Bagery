@* Helper function เนเธเธฅเธเธเธทเนเธญ Category เน€เธเนเธ Bootstrap Icon เนเธซเนเนเธชเธ”เธเธซเธเนเธฒเน€เธกเธเธน *@
@functions {
    private string GetCategoryIcon(string categoryName)
    {
        // เนเธเน Switch Expression เน€เธเนเธเธเธทเนเธญ category (เนเธเธฅเธเน€เธเนเธเธ•เธฑเธงเน€เธฅเนเธเธเนเธญเธเน€เธเธทเนเธญเธเนเธญเธเธเธฑเธ case sensitive)
        return categoryName?.ToLower() switch
        {
            var s when s.Contains("ครัว") || s.Contains("pastry")    => "<i class=\"bi bi-basket-fill\"></i>",
            var s when s.Contains("เค้ก") || s.Contains("cake")      => "<i class=\"bi bi-cake2-fill\"></i>",
            var s when s.Contains("เครื่องดื่ม") || s.Contains("drink") => "<i class=\"bi bi-cup-hot-fill\"></i>",
            var s when s.Contains("ซิก") || s.Contains("signature")  => "<i class=\"bi bi-star-fill\"></i>",
            _ => "<i class=\"bi bi-basket\"></i>" // default เธ–เนเธฒเนเธกเนเธ•เธฃเธเธเธฑเธ category เนเธซเธเน€เธฅเธข
        };
    }
}

@section Scripts {
    <script>
        // โ”€โ”€โ”€ 1. เนเธชเธ”เธ Modal เธฃเธฒเธขเธฅเธฐเน€เธญเธตเธขเธ”เธชเธดเธเธเนเธฒ โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€
        function showProductDetails(productId, name, description, price, imageUrl, stock, isLimitedQuantity = false) {
            // เธเธณเธเนเธญเธกเธนเธฅเธชเธดเธเธเนเธฒเธ—เธตเนเธฃเธฑเธเธกเธฒเนเธชเนเนเธ element เธเธญเธ Modal
            document.getElementById('modalProductName').innerText = name;
            document.getElementById('modalProductDescription').innerText = description;
            document.getElementById('modalProductPrice').innerText = price + ' บาท';
            document.getElementById('modalProductImage').src = imageUrl;
            document.getElementById('modalProductStock').innerText = 'คงเหลือ: ' + stock;
            
            // เธเธณเธซเธเธ” onclick เธเธญเธเธเธธเนเธก "เน€เธเธดเนเธกเธฅเธเธ•เธฐเธเธฃเนเธฒ" เนเธ Modal เนเธซเนเน€เธฃเธตเธขเธ addToCart()
            const addToCartBtn = document.getElementById('modalAddToCartBtn');
            addToCartBtn.onclick = function() {
                addToCart(name, price, productId);
                // Optional: เธเธดเธ” Modal เธซเธฅเธฑเธเน€เธเธดเนเธกเธชเธดเธเธเนเธฒ (เธเธฑเธเธเธธเธเธฑเธ comment เนเธงเน)
                // var modal = bootstrap.Modal.getInstance(document.getElementById('productDetailModal'));
                // modal.hide();
            };

            // เน€เธเธดเธ” Bootstrap Modal
            var productModal = new bootstrap.Modal(document.getElementById('productDetailModal'));
            productModal.show();
        }

        // โ”€โ”€โ”€ 2. เธ•เธฑเธงเนเธเธฃ State เธเธญเธเธฃเธฐเธเธ Pagination เนเธฅเธฐ Filter โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€
        const productsPerPage = 6; // เนเธชเธ”เธเธชเธดเธเธเนเธฒ 6 เธเธดเนเธเธ•เนเธญเธซเธเนเธฒ
        let currentPage = 1;
        let currentCategory = 'all'; // category เธ—เธตเนเธเธฃเธญเธเธญเธขเธนเนเธ•เธญเธเธเธตเน

        // เธ”เธถเธ product card เธ—เธฑเนเธเธซเธกเธ”เนเธเธซเธเนเธฒ
        function getAllProductCards() {
            return Array.from(document.querySelectorAll('.product-card'));
        }

        // เธเธฃเธญเธเน€เธเธเธฒเธฐ product เธ—เธตเนเธ•เธฃเธเธเธฑเธ category เธ—เธตเนเน€เธฅเธทเธญเธ
        function getFilteredProducts() {
            return getAllProductCards().filter(product => {
                const productCategory = product.getAttribute('data-category');
                return currentCategory === 'all' || productCategory === currentCategory;
            });
        }

        // โ”€โ”€โ”€ 3. เธชเธฃเนเธฒเธ Page Indicator (เธ–เนเธฒเธขเธฑเธเนเธกเนเธกเธต) โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€
        function ensurePageIndicator() {
            const navControls = document.querySelector('.nav-controls');
            if (!navControls || document.getElementById('pageIndicator')) return;

            const indicator = document.createElement('div');
            indicator.id = 'pageIndicator';
            indicator.className = 'page-indicator';
            indicator.innerText = '1 / 1';
            // เนเธ—เธฃเธ indicator เธฃเธฐเธซเธงเนเธฒเธเธเธธเนเธก Prev เนเธฅเธฐ Next
            navControls.insertBefore(indicator, navControls.children[1] || null);
        }

        // โ”€โ”€โ”€ 4. Setup เธเธธเนเธก Prev / Next โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€
        function setupNavButtons() {
            const navButtons = document.querySelectorAll('.nav-controls .nav-btn');
            if (navButtons.length < 2) return;

            navButtons[0].textContent = 'Prev';
            navButtons[1].textContent = 'Next';
            navButtons[0].onclick = () => changePage(-1); // เธเธ” Prev เธฅเธ”เธซเธเนเธฒ
            navButtons[1].onclick = () => changePage(1);  // เธเธ” Next เน€เธเธดเนเธกเธซเธเนเธฒ
        }

        // โ”€โ”€โ”€ 5. Render เธชเธดเธเธเนเธฒเนเธเธซเธเนเธฒเธเธฑเธเธเธธเธเธฑเธ โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€
        function renderProducts() {
            const allProducts = getAllProductCards();
            const filteredProducts = getFilteredProducts();
            const totalPages = Math.max(1, Math.ceil(filteredProducts.length / productsPerPage));
            const navButtons = document.querySelectorAll('.nav-controls .nav-btn');
            const pageIndicator = document.getElementById('pageIndicator');
            const rangeText = document.getElementById('menuRangeText');

            // เธเนเธญเธเธเธฑเธ currentPage เน€เธเธดเธ totalPages เน€เธกเธทเนเธญ filter เน€เธเธฅเธตเนเธขเธ
            if (currentPage > totalPages) currentPage = totalPages;

            // เธเนเธญเธเธชเธดเธเธเนเธฒเธ—เธฑเนเธเธซเธกเธ”เธเนเธญเธ เนเธฅเนเธงเธเนเธญเธขเนเธชเธ”เธเน€เธเธเธฒเธฐเธ—เธตเนเธญเธขเธนเนเนเธเธซเธเนเธฒเธเธตเน
            allProducts.forEach(product => {
                product.style.display = 'none';
            });

            // เธเธณเธเธงเธ“ index เน€เธฃเธดเนเธกเธ•เนเธเนเธฅเธฐเธชเธดเนเธเธชเธธเธ”เธเธญเธเธซเธเนเธฒเธเธตเน
            const startIndex = (currentPage - 1) * productsPerPage;
            const endIndex = Math.min(startIndex + productsPerPage, filteredProducts.length);

            // เนเธชเธ”เธเน€เธเธเธฒเธฐเธชเธดเธเธเนเธฒเนเธเธเนเธงเธ startIndex เธ–เธถเธ endIndex
            filteredProducts.slice(startIndex, endIndex).forEach(product => {
                product.style.display = 'block';
            });

            // เธญเธฑเธเน€เธ”เธ• Page Indicator เน€เธเนเธ "2 / 4"
            if (pageIndicator) {
                pageIndicator.innerText = `${currentPage} / ${totalPages}`;
            }

            // เธญเธฑเธเน€เธ”เธ•เธเนเธญเธเธงเธฒเธกเธเธญเธเธเธณเธเธงเธเธชเธดเธเธเนเธฒเธ—เธตเนเนเธชเธ”เธเธญเธขเธนเน
            if (rangeText) {
                if (filteredProducts.length === 0) {
                    rangeText.innerText = 'No menu items found in this category yet';
                } else {
                    rangeText.innerText = `Showing ${startIndex + 1}-${endIndex} of ${filteredProducts.length} menu items`;
                }
            }

            // disable เธเธธเนเธก Prev เธ–เนเธฒเธญเธขเธนเนเธซเธเนเธฒเนเธฃเธ / เธเธธเนเธก Next เธ–เนเธฒเธญเธขเธนเนเธซเธเนเธฒเธชเธธเธ”เธ—เนเธฒเธข
            if (navButtons.length >= 2) {
                navButtons[0].disabled = currentPage === 1;
                navButtons[1].disabled = currentPage === totalPages;
            }
        }

        // โ”€โ”€โ”€ 6. เน€เธเธฅเธตเนเธขเธเธซเธเนเธฒ Prev / Next โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€
        function changePage(direction) {
            const totalPages = Math.max(1, Math.ceil(getFilteredProducts().length / productsPerPage));
            const nextPage = currentPage + direction;
            // เธเนเธญเธเธเธฑเธเธญเธญเธเธเธญเธ range
            if (nextPage < 1 || nextPage > totalPages) return;
            currentPage = nextPage;
            renderProducts();
        }

        // โ”€โ”€โ”€ 7. เธเธฃเธญเธเธชเธดเธเธเนเธฒเธ•เธฒเธก Category โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€
        function filterMenu(category, event) {
            if (event) {
                event.preventDefault();
            }

            // เธฅเนเธฒเธ active เธเธญเธเธ—เธธเธ menu item เนเธฅเนเธง active เธญเธฑเธเธ—เธตเนเธเธ”
            document.querySelectorAll('.menu-item').forEach(item => {
                item.classList.remove('active');
            });

            if (event) {
                event.currentTarget.classList.add('active');
            }

            // เน€เธเธฅเธตเนเธขเธ category เนเธฅเธฐ reset เธเธฅเธฑเธเธซเธเนเธฒ 1 เนเธฅเนเธง render เนเธซเธกเน
            currentCategory = category;
            currentPage = 1;
            renderProducts();
        }

        // โ”€โ”€โ”€ 8. เน€เธฃเธดเนเธกเธ•เนเธเธฃเธฐเธเธเน€เธกเธทเนเธญเนเธซเธฅเธ”เธซเธเนเธฒเน€เธชเธฃเนเธ โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€โ”€
        document.addEventListener('DOMContentLoaded', function () {
            ensurePageIndicator(); // เธชเธฃเนเธฒเธ page indicator
            setupNavButtons();     // setup เธเธธเนเธก prev/next
            renderProducts();      // render เธชเธดเธเธเนเธฒเธซเธเนเธฒเนเธฃเธ
        });
    </script>
}


