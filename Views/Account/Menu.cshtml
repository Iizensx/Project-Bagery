@using _66022380.Models.Db;
@model List<Stock>

@{
    ViewData["Title"] = "เมนู";
}

<!-- Bootstrap Icons CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        margin-top: 0px;
    }

    /* Hero Banner */
    .hero-banner {
        height: 500px;
        background-color: #1a1a1a;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        text-align: center;
        overflow: hidden;
    }

    .hero-title {
        font-size: 4rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 4px;
        z-index: 1;
        text-shadow: 0 4px 10px rgba(0,0,0,0.3);
    }

    /* Main Container */
    .main-container {
        max-width: 1400px;
        margin: 50px auto 0;
        padding: 0 2rem 4rem;
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 2.5rem;
    }

    /* Sidebar */
    .menu-sidebar {
        background: white;
        padding: 2.5rem;
        border-radius: 24px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        height: fit-content;
        position: sticky;
        top: 100px;
    }

    .menu-title {
        color: #F97316;
        font-weight: 800;
        letter-spacing: 2px;
        margin-bottom: 1rem;
        font-size: 0.9rem;
    }

    .menu-heading {
        font-size: 1.8rem;
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 2rem;
        color: #1a1a1a;
    }

    .menu-list {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .menu-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.5rem;
        text-decoration: none;
        color: #4B5563;
        font-weight: 600;
        border-radius: 15px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid transparent;
    }

    .menu-item:hover {
        background: #FFF8E7;
        color: #F97316;
        transform: translateX(8px);
    }

    .menu-item.active {
        background: #F97316;
        color: white;
        box-shadow: 0 10px 20px rgba(249, 115, 22, 0.2);
    }

    .menu-icon {
        font-size: 1.4rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
    }

    .menu-icon i {
        font-size: 1.4rem;
    }

    /* Products Grid */
    .products-section {
        background: white;
        padding: 3rem;
        border-radius: 32px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.03);
        position: relative;
        overflow: hidden;
    }

    .dot {
        position: absolute;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: #F97316;
        opacity: 0.1;
    }

    .dot-1 { top: 40px; right: 40px; }
    .dot-2 { bottom: 60px; left: 40px; }
    .dot-3 { top: 60%; right: 20px; }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 3rem;
    }

    .section-subtitle {
        color: #F97316;
        font-weight: 700;
        font-size: 1rem;
        margin-bottom: 0.5rem;
    }

    .section-title {
        font-size: 2.8rem;
        font-weight: 900;
        color: #1a1a1a;
        margin: 0;
    }

    .nav-controls {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .nav-btn {
        min-width: 94px;
        height: 50px;
        border-radius: 15px;
        border: 2px solid #F3F4F6;
        background: white;
        padding: 0 1.2rem;
        font-size: 0.95rem;
        font-weight: 800;
        letter-spacing: 0.02em;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    .nav-btn:hover {
        border-color: #F97316;
        color: #F97316;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(249, 115, 22, 0.12);
    }

    .nav-btn:disabled {
        opacity: 0.45;
        cursor: not-allowed;
        border-color: #E5E7EB;
        color: #9CA3AF;
        box-shadow: none;
        transform: none;
    }

    .page-indicator {
        min-width: 102px;
        text-align: center;
        color: #6B7280;
        font-size: 0.92rem;
        font-weight: 700;
        padding: 0.85rem 1rem;
        background: #FFF7ED;
        border: 1px solid #FED7AA;
        border-radius: 14px;
    }

    .menu-range-text {
        color: #9CA3AF;
        font-size: 0.95rem;
        font-weight: 600;
        margin-top: 0.65rem;
    }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 2.5rem;
        width: 100%;
        max-width: 1400px;
    }

    /* Product Card */
    .product-card {
        background: #fff;
        border-radius: 24px;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid #F3F4F6;
        position: relative;
    }

    .product-card:hover {
        transform: translateY(-12px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        border-color: #F97316;
    }

    .product-image {
        height: 220px;
        overflow: hidden;
        position: relative;
    }

    .product-image img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center;
        transition: transform 0.6s ease;
    }

    .product-card:hover .product-image img {
        transform: scale(1.1);
    }

    .product-info {
        padding: 1.8rem;
    }

    .product-name {
        font-size: 1.3rem;
        font-weight: 800;
        color: #1a1a1a;
        margin-bottom: 0.5rem;
    }

    .product-price {
        font-size: 1.5rem;
        font-weight: 900;
        color: #F97316;
        margin-bottom: 1.2rem;
    }

    .btn-order {
        width: 100%;
        padding: 1rem;
        background: #1a1a1a;
        color: white;
        border: none;
        border-radius: 14px;
        font-weight: 700;
        font-size: 1rem;
        transition: all 0.3s;
        cursor: pointer;
    }

    .btn-order:hover {
        background: #F97316;
        transform: translateY(-2px);
        box-shadow: 0 8px 15px rgba(249, 115, 22, 0.3);
    }

    /* Testimonials Section */
    .testimonials-section {
        background: #1a1a1a;
        border-radius: 40px;
        padding: 4rem;
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
        gap: 2.5rem;
        align-items: stretch;
        color: white;
        margin-bottom: 4rem;
        overflow: hidden;
    }

    .testimonials-wrap {
        max-width: 1400px;
        margin: 3rem auto 0;
        padding: 0 2rem;
    }

    .testimonial-label {
        color: #F97316;
        font-weight: 800;
        letter-spacing: 3px;
        margin-bottom: 1.5rem;
    }

    .testimonial-title {
        font-size: 3rem;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 1.6rem;
    }

    .testimonial-text {
        font-size: 1.08rem;
        line-height: 1.85;
        color: #9CA3AF;
        margin-bottom: 2rem;
        font-style: italic;
        max-width: 560px;
    }

    .testimonial-author {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .author-avatar {
        width: 70px;
        height: 70px;
        border-radius: 20px;
        background: #F97316;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 800;
    }

    .author-name {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 0.2rem;
    }

    .author-title {
        color: #6B7280;
    }

    .author-rating {
        color: #FBBF24;
        margin-top: 0.5rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    .author-rating i {
        font-size: 1rem;
        color: #FBBF24;
    }

    .testimonial-image {
        position: relative;
        min-height: 460px;
        height: 100%;
        border-radius: 30px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .testimonial-image img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }

    .testimonial-avatars {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.8rem;
    }

    .small-avatar {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.08);
        color: white;
        font-size: 1.1rem;
    }

    .small-avatar i {
        font-size: 1.5rem;
    }

    /* Features Section */
    .features-card {
        background: white;
        border-radius: 30px;
        padding: 3rem;
        box-shadow: 0 20px 50px rgba(0,0,0,0.05);
        margin-top: -100px;
        position: relative;
        z-index: 3;
        border: 1px solid #F3F4F6;
    }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 1rem;
    }

    .feature-icon {
        width: 70px;
        height: 70px;
        background: #FFF8E7;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: #F97316;
    }

    .feature-icon i {
        font-size: 2rem;
        color: #F97316;
    }

    .feature-title {
        font-size: 1.2rem;
        font-weight: 800;
        color: #1a1a1a;
        margin: 0;
    }

    .feature-text {
        color: #6B7280;
        margin: 0.3rem 0 0 0;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        body {
            margin-top: 60px;
        }
    }

    @@media (max-width: 1200px) {
        .main-container {
            grid-template-columns: 1fr;
            padding: 0 1.5rem 3rem;
        }

        .menu-sidebar {
            position: relative;
            top: 0;
            margin-bottom: 2rem;
        }

        .menu-list {
            flex-direction: row;
            overflow-x: auto;
            padding-bottom: 1rem;
        }

        .menu-item {
            white-space: nowrap;
        }

        .testimonials-section {
            grid-template-columns: 1fr;
            padding: 3rem;
        }

        .products-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    .stock-badge {
        display: inline-block;
        padding: 0.35rem 0.8rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 700;
        margin-bottom: 1rem;
        background: #f0fdf4;
        color: #166534;
    }

    .stock-badge.limited {
        background: #fee2e2;
        color: #b91c1c;
    }

    .btn-details {
        width: 100%;
        padding: 0.8rem;
        background: #f3f4f6;
        color: #4b5563;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.95rem;
        transition: all 0.3s;
        cursor: pointer;
        margin-bottom: 0.8rem;
    }

    .btn-details:hover {
        background: #e5e7eb;
        color: #1f2937;
    }

    /* Modal Styles */
    .modal-content {
        border-radius: 24px;
        border: none;
        overflow: hidden;
    }

    .detail-image {
        width: 100%;
        height: 300px;
        object-fit: cover;
        border-radius: 16px;
        margin-bottom: 1.5rem;
    }

    .detail-price {
        font-size: 2rem;
        font-weight: 900;
        color: #F97316;
        margin-bottom: 1rem;
    }

    .detail-description {
        color: #4b5563;
        line-height: 1.6;
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }

    /* Bottom Sections */
    .bottom-section-wrap {
        max-width: 1400px;
        margin: 0 auto 5rem;
        padding: 0 2rem;
        display: grid;
        gap: 2rem;
    }

    .menu-bottom-grid {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: 2rem;
    }

    .menu-bottom-card {
        background: white;
        border: 1px solid #F3F4F6;
        border-radius: 32px;
        padding: 2.5rem;
        box-shadow: 0 18px 40px rgba(0,0,0,0.04);
    }

    .bottom-kicker {
        color: #F97316;
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 2px;
        margin-bottom: 0.8rem;
    }

    .bottom-heading {
        color: #1a1a1a;
        font-size: 2.2rem;
        font-weight: 900;
        line-height: 1.15;
        margin-bottom: 1rem;
    }

    .bottom-copy {
        color: #6B7280;
        font-size: 1rem;
        line-height: 1.8;
        margin-bottom: 1.5rem;
    }

    .reason-list,
    .order-steps {
        display: grid;
        gap: 1rem;
    }

    .reason-item,
    .step-item {
        display: flex;
        gap: 1rem;
        align-items: flex-start;
        padding: 1rem 1.1rem;
        border-radius: 20px;
        background: #FFF8F3;
        border: 1px solid #FCE7D7;
    }

    .reason-icon,
    .step-num {
        width: 52px;
        height: 52px;
        flex: 0 0 52px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 16px;
        background: linear-gradient(135deg, #F97316, #FB923C);
        color: white;
        font-weight: 900;
        font-size: 1rem;
        box-shadow: 0 10px 20px rgba(249, 115, 22, 0.2);
    }

    .reason-title,
    .step-title {
        font-size: 1rem;
        font-weight: 800;
        color: #1a1a1a;
        margin-bottom: 0.25rem;
    }

    .reason-text,
    .step-text {
        color: #6B7280;
        line-height: 1.7;
        margin: 0;
    }

    .cta-banner {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #1a1a1a 0%, #2b1809 55%, #F97316 130%);
        color: white;
        border-radius: 36px;
        padding: 3rem;
        box-shadow: 0 24px 60px rgba(26, 26, 26, 0.16);
    }

    .cta-banner::before {
        content: '';
        position: absolute;
        width: 260px;
        height: 260px;
        border-radius: 50%;
        right: -60px;
        top: -60px;
        background: rgba(255,255,255,0.06);
    }

    .cta-banner::after {
        content: '';
        position: absolute;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        left: -40px;
        bottom: -70px;
        background: rgba(255,255,255,0.05);
    }

    .cta-content {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: space-between;
        gap: 2rem;
        align-items: center;
    }

    .cta-title {
        font-size: 2.2rem;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 0.8rem;
    }

    .cta-text {
        color: rgba(255,255,255,0.78);
        font-size: 1rem;
        line-height: 1.8;
        max-width: 700px;
        margin: 0;
    }

    .cta-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .cta-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 1.5rem;
        border-radius: 16px;
        font-weight: 800;
        text-decoration: none;
        transition: all 0.3s;
    }

    .cta-btn.primary {
        background: white;
        color: #1a1a1a;
    }

    .cta-btn.secondary {
        background: rgba(255,255,255,0.1);
        color: white;
        border: 1px solid rgba(255,255,255,0.18);
    }

    .cta-btn:hover {
        transform: translateY(-2px);
    }

    @@media (max-width: 768px) {
        .main-container {
            margin-top: 24px;
            padding: 0 1rem 2.25rem;
            gap: 1rem;
        }

        .menu-sidebar {
            padding: 1.2rem;
            border-radius: 18px;
            margin-bottom: 0.75rem;
        }

        .menu-title {
            margin-bottom: 0.55rem;
            font-size: 0.74rem;
            letter-spacing: 1.5px;
        }

        .menu-heading {
            font-size: 1.1rem;
            margin-bottom: 1rem;
        }

        .menu-list {
            gap: 0.55rem;
            padding-bottom: 0.35rem;
            flex-wrap: nowrap;
        }

        .menu-item {
            gap: 0.55rem;
            padding: 0.78rem 1rem;
            border-radius: 12px;
            font-size: 0.92rem;
        }

        .menu-item:hover {
            transform: none;
        }

        .section-title {
            font-size: 2rem;
        }

        .hero-title {
            font-size: 2.5rem;
        }

        .testimonials-section {
            padding: 2rem;
        }

        .testimonial-title {
            font-size: 2rem;
        }

        .products-section {
            padding: 1.5rem;
            border-radius: 22px;
        }

        .products-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .section-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.7rem;
            margin-bottom: 1.5rem;
        }

        .nav-controls {
            width: 100%;
            justify-content: space-between;
            gap: 0.6rem;
        }

        .testimonial-image {
            min-height: 320px;
        }

        .page-indicator {
            min-width: 88px;
            padding: 0.7rem 0.8rem;
            font-size: 0.85rem;
        }

        .nav-btn {
            min-width: 78px;
            height: 44px;
            padding: 0 0.9rem;
            font-size: 0.88rem;
        }

        .bottom-section-wrap {
            padding: 0 1rem;
        }

        .cta-banner,
        .menu-bottom-card {
            padding: 1.25rem;
        }
    }

    @@media (max-width: 1100px) {
        .menu-bottom-grid,
        .cta-content {
            grid-template-columns: 1fr;
            display: grid;
        }
    }

    @@media (max-width: 480px) {
        .hero-banner {
            height: 220px;
        }

        .hero-title {
            font-size: 1.7rem;
            letter-spacing: 2px;
        }

        .main-container {
            padding: 0 0.75rem 2rem;
        }

        .menu-sidebar {
            padding: 1rem;
        }

        .menu-heading {
            font-size: 1rem;
        }

        .menu-item {
            min-width: max-content;
            padding: 0.7rem 0.9rem;
            font-size: 0.88rem;
        }

        .products-section {
            padding: 1rem;
        }

        .section-subtitle {
            font-size: 0.88rem;
        }

        .section-title {
            font-size: 1.55rem;
        }

        .menu-range-text {
            font-size: 0.84rem;
            margin-top: 0.25rem;
        }

        .nav-controls {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .nav-btn,
        .page-indicator {
            width: 100%;
            min-width: 0;
        }

        .product-image {
            height: 180px;
        }

        .product-info {
            padding: 1rem;
        }

        .product-name {
            font-size: 1.08rem;
        }

        .product-price {
            font-size: 1.18rem;
            margin-bottom: 0.9rem;
        }

        .stock-badge {
            margin-bottom: 0.75rem;
            font-size: 0.78rem;
        }

        .btn-details,
        .btn-order {
            padding: 0.78rem;
            font-size: 0.9rem;
        }
    }
</style>

<!-- Hero Banner -->
<div class="hero-banner">
    <img src="~/img/BaileyBakery.png" alt="Menu Banner" style="width: 100%; height: 100%; object-fit: cover; position: absolute; opacity: 0.5;">
    <h1 class="hero-title"></h1>
</div>

<!-- Features Section -->
<div class="container">
    <div class="features-card">
        <div class="row">
            <div class="col-md-4">
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="bi bi-truck"></i>
                    </div>
                    <div>
                        <h3 class="feature-title">Fast Delivery</h3>
                        <p class="feature-text">Within 30 minutes</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="bi bi-basket-fill"></i>
                    </div>
                    <div>
                        <h3 class="feature-title">Freshly Baked</h3>
                        <p class="feature-text">Baked fresh every morning</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="bi bi-gift"></i>
                    </div>
                    <div>
                        <h3 class="feature-title">Free Delivery</h3>
                        <p class="feature-text">Near distance free delivery</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="main-container">
    <!-- Sidebar Menu -->
    <aside class="menu-sidebar">
        <div class="menu-title">OUR MENU</div>
        <div class="menu-heading">Menu That Always Makes You Fall In Love</div>
        <div class="menu-list">
            <a href="#" class="menu-item active" onclick="filterMenu('all', event)">
                <span class="menu-icon"><i class="bi bi-list"></i></span>
                เมนูทั้งหมด
            </a>
            @if (Model != null && Model.Count > 0)
            {
                @foreach (var category in Model.GroupBy(p => p.Category?.CategoryName).Select(g => g.Key).Distinct())
                {
                    <a href="#" class="menu-item" onclick="filterMenu('@(category?.ToLower() ?? "all")', event)">
                        <span class="menu-icon">@Html.Raw(GetCategoryIcon(category))</span>
                        @category
                    </a>
                }
            }
        </div>
    </aside>

    <!-- Products Section -->
    <section class="products-section">
        <div class="dot dot-1"></div>
        <div class="dot dot-2"></div>
        <div class="dot dot-3"></div>

        <div class="section-header">
            <div>
                <div class="section-subtitle">Special Offer</div>
                <h2 class="section-title">Popular Menu</h2>
                <div class="menu-range-text" id="menuRangeText">Showing our featured menu selections</div>
            </div>
            <div class="nav-controls">
                <button type="button" class="nav-btn" data-direction="prev">Prev</button>
                <button type="button" class="nav-btn" data-direction="next" style="background: #E85D5D; color: white; border-color: #E85D5D;">Next</button>
            </div>
        </div>

        <div class="products-grid" id="productsGrid">
            @if (Model != null && Model.Count > 0)
            {
                @foreach (var product in Model)
                {
                    <div class="product-card" data-category="@(product.Category?.CategoryName?.ToLower() ?? "all")">
                        <div class="product-image">
                            <img src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? "/img/bagery1.png" : product.ImageUrl)" alt="@product.ProductName">
                        </div>
                        <div class="product-info">
                            <div class="product-name">@product.ProductName</div>
                            <div class="product-price">@product.Price บาท</div>
                            <div class="stock-badge">คงเหลือ: @(product.Stock1 ?? 0)</div>
                            <button class="btn-details" onclick="showProductDetails(@product.ProductId, '@product.ProductName', '@(product.Description ?? "ไม่มีรายละเอียด")', @(product.Price ?? 0), '@(string.IsNullOrWhiteSpace(product.ImageUrl) ? "/img/bagery1.png" : product.ImageUrl)', @(product.Stock1 ?? 0), @product.IsLimitedQuantity.ToString().ToLower())">รายละเอียด</button>
                            @if (product.IsLimitedQuantity)
                            {
                                <div class="stock-badge limited">[สินค้ามีจำนวนจำกัด]</div>
                            }
                            @if (product.Stock1 <= 0)
                            {
                                <button class="btn-order" style="background: #ccc; color: #666; cursor: not-allowed;" disabled>สินค้าหมด</button>
                            }
                            else
                            {
                                <button class="btn-order" onclick="addToCart('@product.ProductName', @(product.Price ?? 0), @product.ProductId)">สั่งเลย</button>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="grid-column: 1 / -1; text-align: center; padding: 3rem; color: #666;">
                    <p>ไม่มีสินค้าในระบบ</p>
                </div>
            }
        </div>
    </section>
</div>

