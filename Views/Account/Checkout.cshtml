@{
    ViewData["Title"] = "ชำระเงิน";
    Layout = "~/Views/Shared/_Layoutmain.cshtml";
}

<div class="container mt-5 pt-5">
    <div class="row">
        <!-- Section 1: Cart Items & Subtotal -->
        <div class="col-md-8">
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-white">
                    <h4 class="mb-0">รายการสินค้า</h4>
                </div>
                <div class="card-body">
                    <div id="checkout-items-container">
                        <!-- Items will be injected here -->
                    </div>
                </div>
            </div>

            <!-- Section 2: Delivery Address -->
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-white">
                    <h4 class="mb-0">ที่อยู่จัดส่ง</h4>
                </div>
                <div class="card-body">
                    <div id="address-list" class="list-group">
                        <!-- Addresses will be injected here -->
                        <p class="text-center text-muted">กำลังโหลดที่อยู่...</p>
                    </div>
                    <div class="mt-3">
                        <a href="/Profile/Profile" class="btn btn-outline-primary btn-sm">จัดการที่อยู่</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Section 3: Promotions & Summary -->
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h4 class="mb-0">ส่วนลด & สรุปยอด</h4>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">โปรโมชั่น</label>
                        <select id="promo-select" class="form-select">
                            <option value="">ไม่ใช้โปรโมชั่น</option>
                        </select>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between mb-2">
                        <span>ยอดรวมสินค้า:</span>
                        <span id="subtotal-amount">0 บาท</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 text-success">
                        <span>ส่วนลด:</span>
                        <span id="discount-amount">0 บาท</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 font-weight-bold h5">
                        <span>ยอดรวมสุทธิ:</span>
                        <span id="total-amount" class="text-primary">0 บาท</span>
                    </div>

                    <button id="confirm-order-btn" class="btn btn-primary w-100 mt-3 py-2 fw-bold" disabled>
                        ยืนยันการสั่งซื้อ
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .address-item {
        cursor: pointer;
        transition: all 0.2s;
        border: 2px solid #eee;
        margin-bottom: 10px;
        border-radius: 8px;
    }
    .address-item:hover {
        background-color: #f8f9fa;
    }
    .address-item.active {
        border-color: #0d6efd;
        background-color: #e7f1ff;
    }
    .checkout-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #eee;
    }
    .checkout-item:last-child {
        border-bottom: none;
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', async () => {
    // ตัวแปรหลักที่ใช้ตลอดหน้า Checkout
    let cart = JSON.parse(localStorage.getItem('bakeryCart')) || [];
    let userId = @((ViewBag.CurrentUserId as int?) ?? 0);
    let selectedAddressId = null;  // ที่อยู่ที่ user เลือก
    let selectedPromoId = null;    // โปรโมชั่นที่ user เลือก
    let subtotal = 0;
    let discount = 0;
    let total = 0;
    let availablePromos = [];      // รายการโปรโมชั่นทั้งหมดที่ดึงมาจาก server

    // ถ้าตะกร้าว่างให้ redirect กลับหน้าเมนูทันที
    if (cart.length === 0) {
        alert('ตะกร้าว่างเปล่า');
        window.location.href = '/Home/Menu';
        return;
    }

    // ─── 1. แสดงรายการสินค้าในตะกร้า ───────────────────────────────────────
    const container = document.getElementById('checkout-items-container');

    // คำนวณราคารวมก่อนหักส่วนลด
    subtotal = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
    
    // สร้าง HTML แสดงรายการสินค้าแต่ละชิ้น
    container.innerHTML = cart.map(item => `
        <div class="checkout-item">
            <div>
                <h6 class="mb-0">${item.name}</h6>
                <small class="text-muted">จำนวน: ${item.quantity} x ${item.price} บาท</small>
            </div>
            <span class="fw-bold">${item.price * item.quantity} บาท</span>
        </div>
    `).join('');

    document.getElementById('subtotal-amount').innerText = subtotal + ' บาท';
    updateTotal(); // อัปเดตยอดรวมครั้งแรก

    // ─── 2. ดึงข้อมูล User, ที่อยู่, และโปรโมชั่น ──────────────────────────
    try {
        // เรียก API ดึง UserId จาก Session ที่ฝั่ง Server
        const userData = { success: userId > 0, userId };
        
        // ถ้ายังไม่ได้ login ให้ redirect ไปหน้า Login
        if (!userData.success || userData.userId <= 0) {
            alert('กรุณาเข้าสู่ระบบก่อนชำระเงิน');
            window.location.href = '/Account/Login';
            return;
        }
        
        userId = userData.userId;

        // ── ดึงรายการที่อยู่ของ User ────────────────────────────────────────
        const addrRes = await fetch(`/Profile/GetUserAddresses?userId=${userId}`);
        const addrData = await addrRes.json();
        const addrList = document.getElementById('address-list');
        
        if (addrData.success && addrData.addresses.length > 0) {
            // สร้าง card ให้แต่ละที่อยู่ให้ user กดเลือกได้
            addrList.innerHTML = addrData.addresses.map(addr => `
                <div class="list-group-item address-item p-3" data-id="${addr.addressId}">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1 fw-bold">${addr.addressLine}</p>
                            <small class="text-muted">${addr.district}, ${addr.province} ${addr.postalCode}</small>
                        </div>
                    </div>
                </div>
            `).join('');

            // เพิ่ม Event Click ให้แต่ละที่อยู่
            document.querySelectorAll('.address-item').forEach(item => {
                item.addEventListener('click', () => {
                    // ล้าง active ของทุกอัน แล้ว active อันที่กดเท่านั้น
                    document.querySelectorAll('.address-item').forEach(i => i.classList.remove('active'));
                    item.classList.add('active');
                    selectedAddressId = item.dataset.id; // เก็บ id ที่อยู่ที่เลือก
                    checkValidity(); // เช็คว่าครบพร้อมกด confirm ยัง
                });
            });
        } else {
            addrList.innerHTML = '<p class="text-center text-muted">ไม่พบข้อมูลที่อยู่ กรุณาเพิ่มที่อยู่ใหม่</p>';
        }

        // ── ดึงโปรโมชั่นที่ user มีและยังไม่ได้ใช้ ──────────────────────────
        try {
            const promoRes = await fetch(`/Order/GetUserPromos?userId=${userId}`);
            if (promoRes.ok) {
                const promoData = await promoRes.json();
                const promoSelect = document.getElementById('promo-select');
                
                if (promoData.success && promoData.promos && promoData.promos.length > 0) {
                    availablePromos = promoData.promos;

                    // เพิ่ม option ให้ dropdown โปรโมชั่น
                    promoData.promos.forEach(p => {
                        const opt = document.createElement('option');
                        opt.value = p.promotionId;
                        // แสดงชื่อโปร + ค่าส่วนลด (% หรือ บาท)
                        opt.innerText = `${p.promotionName} (${p.discountValue} ${p.discountType === 'Percent' || p.discountType === 'Percentage' ? '%' : 'บาท'})`;
                        promoSelect.appendChild(opt);
                    });
                }
            } else {
                console.error('Failed to fetch promotions: ', promoRes.status);
            }
        } catch (promoErr) {
            console.error('Promotion error:', promoErr);
        }

    } catch (e) {
        console.error(e);
        alert('เกิดข้อผิดพลาดในการดึงข้อมูล');
    }

    // ─── 3. เมื่อ User เลือกโปรโมชั่น ────────────────────────────────────────
    document.getElementById('promo-select').addEventListener('change', (e) => {
        selectedPromoId = e.target.value;
        const promo = availablePromos.find(p => p.promotionId == selectedPromoId);
        
        if (promo) {
            // คำนวณส่วนลดตามประเภท: Percent = คิดเป็น % / อื่นๆ = ลดเป็นบาทตรงๆ
            if (promo.discountType === 'Percent' || promo.discountType === 'Percentage') {
                discount = (subtotal * promo.discountValue) / 100;
            } else {
                discount = promo.discountValue;
            }
        } else {
            // ถ้าเลือก "ไม่ใช้โปร" ให้ reset ส่วนลดเป็น 0
            discount = 0;
            selectedPromoId = null;
        }
        
        updateTotal();
    });

    // ─── Helper: คำนวณและแสดงยอดรวม ─────────────────────────────────────────
    function updateTotal() {
        total = Math.max(0, subtotal - discount); // ป้องกันยอดติดลบ
        document.getElementById('discount-amount').innerText = '-' + discount.toFixed(2) + ' บาท';
        document.getElementById('total-amount').innerText = total.toFixed(2) + ' บาท';
    }

    // ─── Helper: เช็คว่าพร้อมกด Confirm ยัง (ต้องเลือกที่อยู่และมีสินค้า) ──
    function checkValidity() {
        const btn = document.getElementById('confirm-order-btn');
        if (selectedAddressId && cart.length > 0) {
            btn.disabled = false;
        } else {
            btn.disabled = true;
        }
    }

    // ─── 4. กดยืนยันการสั่งซื้อ ──────────────────────────────────────────────
    document.getElementById('confirm-order-btn').addEventListener('click', async () => {
        if (!selectedAddressId) {
            alert('กรุณาเลือกที่อยู่จัดส่ง');
            return;
        }

        // ล็อคปุ่มป้องกัน user กดซ้ำ
        const confirmBtn = document.getElementById('confirm-order-btn');
        confirmBtn.disabled = true;
        confirmBtn.innerText = 'กำลังประมวลผล...';

        // รวมข้อมูล Order ที่จะส่งไป Controller
        const orderData = {
            userId: userId,
            addressId: parseInt(selectedAddressId),
            promotionId: selectedPromoId ? parseInt(selectedPromoId) : null,
            items: cart.map(item => ({
                productId: item.productId || null,
                productName: item.name,
                price: item.price,
                quantity: item.quantity
            })),
            totalAmount: total
        };

        try {
            // ส่งข้อมูล Order ไปที่ /Order/CreateOrder แบบ POST JSON
            const res = await fetch('/Order/CreateOrder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(orderData)
            });
            const data = await res.json();

            if (data.success) {
                localStorage.removeItem('bakeryCart'); // ล้างตะกร้าหลังสั่งสำเร็จ
                window.location.href = `/Order/Payment?orderId=${data.orderId}`; // ไปหน้าชำระเงิน
            } else {
                alert(data.message || 'เกิดข้อผิดพลาดในการสั่งซื้อ');
                // คืนสถานะปุ่มให้กดได้ใหม่
                confirmBtn.disabled = false;
                confirmBtn.innerText = 'ยืนยันการสั่งซื้อ';
            }
        } catch (e) {
            alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
            confirmBtn.disabled = false;
            confirmBtn.innerText = 'ยืนยันการสั่งซื้อ';
        }
    });
});
</script>
