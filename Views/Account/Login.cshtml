@model AuthUserViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>เข้าสู่ระบบ - BAGERY</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background:  #FFF8E7;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 2rem;
        }

        .login-wrapper {
            width: 100%;
            max-width: 1000px;
        }

        .login-card {
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
            display: flex;
            min-height: 550px;
        }

        /* Left Side - Form */
        .login-form-section {
            flex: 1;
            padding: 4rem 3rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .form-header {
            margin-bottom: 2.5rem;
        }

        .form-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 0.5rem;
        }

        .form-subtitle {
            font-size: 0.95rem;
            color: #6B7280;
            line-height: 1.6;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-control {
            width: 100%;
            padding: 0.875rem 1rem;
            border: 1px solid #E5E7EB;
            border-radius: 8px;
            font-size: 0.95rem;
            background-color: #F9FAFB;
            transition: all 0.3s ease;
            color: #374151;
        }

        .form-control::placeholder {
            color: #D1D5DB;
        }

        .form-control:focus {
            outline: none;
            background-color: white;
            border-color: #1a1a1a;
            box-shadow: 0 0 0 3px rgba(26, 26, 26, 0.1);
        }

        .form-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
        }

        .form-check {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .form-check input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
            accent-color: #1a1a1a;
            border-radius: 3px;
        }

        .form-check label {
            cursor: pointer;
            color: #6B7280;
            margin: 0;
            font-size: 0.9rem;
            font-weight: 500;
            text-transform: none;
            letter-spacing: normal;
        }

        .forgot-password {
            color: #1a1a1a;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
            font-size: 0.9rem;
        }

        .forgot-password:hover {
            color: #4B5563;
            text-decoration: underline;
        }

        .btn-submit {
            width: 100%;
            padding: 0.875rem;
            background-color: #1a1a1a;
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 0.5rem;
        }

        .btn-submit:hover {
            background-color: #333333;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

        .divider {
            text-align: center;
            margin: 1.5rem 0;
            color: #D1D5DB;
            font-size: 0.9rem;
        }

        .divider::before {
            content: '';
            display: block;
            height: 1px;
            background: #E5E7EB;
            margin-bottom: 1rem;
        }

        .social-login {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .social-btn {
            width: 100%;
            padding: 0.75rem;
            border: 1.5px solid #E5E7EB;
            border-radius: 8px;
            background: white;
            color: #374151;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            text-decoration: none;
        }

        .social-btn:hover {
            border-color: #1a1a1a;
            background-color: #F9FAFB;
            transform: translateY(-1px);
        }

        .social-btn-icon {
            font-size: 1.1rem;
        }

        .form-link {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.9rem;
            color: #6B7280;
        }

        .form-link a {
            color: #1a1a1a;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
        }

        .form-link a:hover {
            color: #4B5563;
            text-decoration: underline;
        }

        /* Right Side - Image */
        .login-image-section {
            flex: 1;
            background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 550px;
        }

        .image-background {
            position: absolute;
            width: 100%;
            height: 100%;
            background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 550"><defs><filter id="blur"><feGaussianBlur in="SourceGraphic" stdDeviation="2"/></filter></defs><rect fill="%23000" width="400" height="550"/><circle cx="80" cy="100" r="40" fill="%23FF6B35" opacity="0.3" filter="url(%23blur)"/><circle cx="320" cy="150" r="50" fill="%23FF8A50" opacity="0.2" filter="url(%23blur)"/><circle cx="150" cy="350" r="60" fill="%23FF6B35" opacity="0.25" filter="url(%23blur)"/><circle cx="300" cy="450" r="45" fill="%23FF8A50" opacity="0.2" filter="url(%23blur)"/><path d="M50,400 Q100,300 150,400 T250,400 T350,400" stroke="%23FF6B35" stroke-width="2" fill="none" opacity="0.15"/><path d="M30,450 Q80,350 130,450 T230,450 T330,450" stroke="%23FF8A50" stroke-width="2" fill="none" opacity="0.1"/></svg>');
            background-size: cover;
            background-position: center;
            opacity: 0.32;
        }

        .flower-pattern {
            position: relative;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #000000;
        }

        .flower {
            display: none;
        }

        .brand-side-logo {
            position: relative;
            z-index: 1;
            width: min(78%, 360px);
            max-width: 360px;
            object-fit: contain;
            filter: drop-shadow(0 18px 34px rgba(0, 0, 0, 0.28));
        }

        @@keyframes sway {
            0%, 100% {
                transform: translateX(0) translateY(0);
            }
            25% {
                transform: translateX(5px) translateY(-5px);
            }
            50% {
                transform: translateX(-5px) translateY(5px);
            }
            75% {
                transform: translateX(3px) translateY(-3px);
            }
        }

        .copyright {
            position: absolute;
            bottom: 20px;
            right: 20px;
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.3);
        }

        /* Responsive */
        @@media (max-width: 1024px) {
            .login-image-section {
                display: none;
            }

            .login-card {
                flex-direction: column;
                min-height: auto;
            }

            .login-form-section {
                padding: 3rem 2rem;
            }
        }

        @@media (max-width: 768px) {
            .login-form-section {
                padding: 2rem 1.5rem;
            }

            .form-title {
                font-size: 1.5rem;
            }

            .login-card {
                border-radius: 20px;
            }
        }

        @@media (max-width: 480px) {
            body {
                padding: 1rem;
            }

            .login-form-section {
                padding: 1.5rem 1rem;
            }

            .form-title {
                font-size: 1.3rem;
            }

            .form-subtitle {
                font-size: 0.85rem;
            }

            .form-group {
                margin-bottom: 1rem;
            }
        }
    </style>
</head>
<body>
    

    <div class="login-wrapper">
        <div class="login-card">
            <!-- Left Side - Form -->
            <div class="login-form-section">
                <div class="form-header">
                    <h1 class="form-title">แวะมาเติมความหวานกัน</h1>
                    <p class="form-subtitle">
                        วันนี้รับขนมปังหรือเค้กชิ้นไหนดีคะ? 
                        ล็อกอินเข้าสู่ระบบเพื่อสั่งขนมและให้เราดูแลมื้ออร่อยของคุณในวันนี้เลย
                    </p>
                </div>

                <form id="loginForm" method="post" asp-controller="Account" asp-action="Login">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" id="loginError" style="font-size: 0.9rem; padding: 0.5rem 1rem; margin-bottom: 1rem;"></div>
                    <div class="form-group">
                        <label for="username">Username or Email</label>
                        <input type="text" id="username" asp-for="Username" class="form-control" placeholder="admin or example@email.com" required>
                    </div>

                    <div class="form-group">
                        <label for="password">Password</label>
                        <input type="password" id="password" asp-for="Password" class="form-control" placeholder="At least 8 characters" required>
                    </div>

                    <div class="form-footer">
                        <div class="form-check">
                            <input type="checkbox" id="remember" />
                            <label for="remember">Remember me</label>
                        </div>
                        <a asp-controller="Account" asp-action="ForgotPassword" class="forgot-password">Forgot Password?</a>
                    </div>

                    <button type="submit" class="btn-submit">Sign in</button>
                </form>

                <div class="form-link">
                    Don't you have an account? <a asp-controller="Account" asp-action="Signup">Sign up</a>
                </div>
            </div>

            <!-- Right Side - Image -->
            <div class="login-image-section">
                <div class="image-background"></div>
                <div class="flower-pattern">
                    <img class="brand-side-logo" src="~/img/Bailey.png" alt="Bailey Art and Bakery">
                    <div class="flower flower-1">🌹</div>
                    <div class="flower flower-2">🌷</div>
                    <div class="flower flower-3">🌺</div>
                    <div class="flower flower-4">🌸</div>
                    <div class="flower flower-5">🌻</div>
                    <div class="flower flower-6">🌹</div>
                </div>
                <div class="copyright">© 2024 ALL RIGHTS RESERVED</div>
            </div>
        </div>
    </div>

   @* บันทึกข้อมูล User ลง localStorage ตอน Submit Login *@
<script>
    // ดักจับ event ตอนกด Submit ฟอร์ม Login
    document.getElementById('loginForm').addEventListener('submit', function (e) {
        const username = document.getElementById('username').value;

        // สร้าง object เก็บข้อมูล user ที่จะบันทึกลง localStorage
        const user = {
            username: username,
            loginTime: new Date().getTime() // เก็บเวลา login เป็น timestamp (milliseconds)
        };

        // บันทึกลง localStorage เพื่อให้หน้าอื่นๆ เรียกใช้ได้
        // เช่น แสดงชื่อ user ที่ navbar โดยไม่ต้องเรียก server
        localStorage.setItem('user', JSON.stringify(user));
        
        // หมายเหตุ: ไม่มี e.preventDefault() 
        // ดังนั้นฟอร์มจะยัง submit ตามปกติไปที่ Controller
    });
</script>
</body>
</html>
