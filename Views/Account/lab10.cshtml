@{
    Layout = null;
}
@model _66022380.Models.UserViewModel

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>แก้ไขข้อมูลผู้ใช้</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #e8f0fe 0%, #f3e8ff 100%);
        }

        .form-card {
            background: #ffffff;
            border-radius: 20px;
            padding: 2.5rem;
            width: 100%;
            max-width: 480px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.12);
        }

        .form-card-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .form-card-header .icon-circle {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #4f80ff, #a855f7);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin: 0 auto 1rem auto;
        }

        .form-card-header h4 {
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 0.25rem;
        }

        .form-card-header p {
            font-size: 0.875rem;
            color: #94a3b8;
        }

        .form-label {
            font-size: 0.82rem;
            font-weight: 600;
            color: #475569;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .form-control {
            border-radius: 10px;
            border: 1.5px solid #e2e8f0;
            padding: 0.65rem 1rem;
            font-size: 0.95rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .form-control:focus {
            border-color: #4f80ff;
            box-shadow: 0 0 0 3px rgba(79, 128, 255, 0.15);
        }

        .form-control:disabled {
            background-color: #f8fafc;
            color: #94a3b8;
        }

        .btn {
            border-radius: 10px;
            padding: 0.7rem 1rem;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, #4f80ff, #a855f7);
            border: none;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #3b6ef0, #9333ea);
        }

        .btn-outline-secondary {
            border: 1.5px solid #e2e8f0;
            color: #64748b;
        }

        .btn-outline-secondary:hover {
            background-color: #f1f5f9;
            color: #1e293b;
        }

        .divider {
            border: none;
            border-top: 1.5px solid #f1f5f9;
            margin: 1.5rem 0;
        }
    </style>
</head>
<body>

    <div class="form-card">

        <div class="form-card-header">
            <div class="icon-circle">✏️</div>
            <h4>แก้ไข/เพิ่มผู้ใช้</h4>
            
        </div>

        <form asp-action="Lab10" asp-controller="Account" method="post">

            <div class="mb-3">
                <label for="UserId" class="form-label">User ID</label>
                <input type="hidden" name="UserId" id="UserId" value="@Model?.UserId" />
                <input type="text" class="form-control" value="@Model?.UserId" disabled />
            </div>
            <br>

            <div class="mb-3">
                <label for="Username" class="form-label">ชื่อผู้ใช้</label>
                <input type="text" name="Username" id="Username" class="form-control" value="@Model?.Username" required />
            </div>
            <br>

            <div class="mb-3">
                <label for="Email" class="form-label">อีเมล</label>
                <input type="email" name="Email" id="Email" class="form-control" value="@Model?.Email" />
            </div>
            <br>

            <div class="mb-3">
                <label for="Phone" class="form-label">เบอร์โทรศัพท์</label>
                <input type="text" name="Phone" id="Phone" class="form-control" value="@Model?.Phone" />
            </div>
            

            <hr class="divider" />

            <div class="d-flex gap-2">
                <a href="javascript:history.back()" class="btn btn-outline-secondary w-50">← ยกเลิก</a>
                <button type="submit" class="btn btn-primary w-50">💾 บันทึก</button>
            </div>

        </form>

    </div>

</body>
</html>