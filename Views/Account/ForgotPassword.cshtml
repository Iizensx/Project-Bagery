@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - BAGERY</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --bg: #fff8e7;
            --card: #fffdf8;
            --ink: #1f2937;
            --muted: #6b7280;
            --line: #f1dfc9;
            --accent: #f97316;
            --accent-deep: #c2410c;
            --accent-soft: #fff1e6;
            --success-bg: #ecfdf3;
            --success-ink: #166534;
            --error-bg: #fff1f2;
            --error-ink: #be123c;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            background:
                radial-gradient(circle at top left, rgba(249, 115, 22, 0.16), transparent 28%),
                radial-gradient(circle at bottom right, rgba(251, 191, 36, 0.18), transparent 24%),
                linear-gradient(180deg, #fff7ed 0%, #fffaf4 44%, #fff 100%);
            color: var(--ink);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .forgot-shell {
            width: min(1120px, 100%);
        }

        .forgot-card {
            background: rgba(255, 253, 248, 0.95);
            border: 1px solid rgba(241, 223, 201, 0.9);
            border-radius: 32px;
            overflow: hidden;
            box-shadow: 0 30px 90px rgba(124, 45, 18, 0.14);
            display: grid;
            grid-template-columns: 1.02fr 0.98fr;
            min-height: 700px;
        }

        .forgot-side {
            position: relative;
            overflow: hidden;
            padding: 3rem 2.5rem;
            background:
                radial-gradient(circle at 20% 20%, rgba(255,255,255,0.18), transparent 20%),
                linear-gradient(160deg, #111827 0%, #7c2d12 45%, #ea580c 100%);
            color: #fff7ed;
        }

        .brand-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.55rem 0.9rem;
            border-radius: 999px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.14);
            font-size: 0.82rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .side-title {
            margin: 1.3rem 0 0.9rem;
            font-size: clamp(2rem, 4vw, 3.2rem);
            line-height: 0.96;
            font-weight: 900;
            max-width: 420px;
        }

        .side-copy {
            margin: 0;
            max-width: 430px;
            color: rgba(255, 244, 235, 0.82);
            line-height: 1.8;
            font-size: 0.98rem;
        }

        .step-list {
            margin-top: 2rem;
            display: grid;
            gap: 0.95rem;
        }

        .step-item {
            display: grid;
            grid-template-columns: 52px 1fr;
            gap: 0.9rem;
            align-items: start;
            padding: 1rem;
            border-radius: 22px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.08);
            backdrop-filter: blur(8px);
        }

        .step-badge {
            width: 52px;
            height: 52px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,0.14);
            font-size: 1.05rem;
            font-weight: 900;
            color: #fff;
        }

        .step-item h3 {
            margin: 0 0 0.35rem;
            font-size: 1rem;
            font-weight: 800;
            color: #fff;
        }

        .step-item p {
            margin: 0;
            color: rgba(255,244,235,0.78);
            line-height: 1.65;
            font-size: 0.92rem;
        }

        .mock-chip {
            margin-top: 1.8rem;
            display: inline-flex;
            align-items: center;
            gap: 0.55rem;
            padding: 0.8rem 1rem;
            border-radius: 18px;
            background: rgba(17, 24, 39, 0.26);
            border: 1px solid rgba(255,255,255,0.12);
            color: #ffedd5;
            font-weight: 700;
        }

        .forgot-main {
            padding: 3rem 2.5rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background:
                radial-gradient(circle at top right, rgba(249, 115, 22, 0.08), transparent 24%),
                linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(255,250,244,0.96) 100%);
        }

        .main-head {
            margin-bottom: 1.6rem;
        }

        .eyebrow {
            color: var(--accent-deep);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-size: 0.78rem;
            font-weight: 900;
        }

        .main-title {
            margin: 0.65rem 0 0.45rem;
            font-size: clamp(1.9rem, 3vw, 2.6rem);
            line-height: 1.02;
            font-weight: 900;
            color: #111827;
        }

        .main-copy {
            margin: 0;
            color: var(--muted);
            line-height: 1.8;
        }

        .progress {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.8rem;
            margin-bottom: 1.2rem;
        }

        .progress-step {
            padding: 0.9rem 1rem;
            border-radius: 18px;
            border: 1px solid var(--line);
            background: #fff;
            color: #9ca3af;
            font-weight: 800;
            font-size: 0.88rem;
            transition: all 0.25s ease;
        }

        .progress-step.active {
            background: linear-gradient(135deg, #fff7ed, #ffedd5);
            color: var(--accent-deep);
            border-color: #fdba74;
            box-shadow: 0 14px 28px rgba(249, 115, 22, 0.12);
        }

        .panel {
            display: none;
            padding: 1.35rem;
            border-radius: 28px;
            background: var(--card);
            border: 1px solid var(--line);
            box-shadow: 0 18px 36px rgba(15, 23, 42, 0.04);
        }

        .panel.active {
            display: block;
        }

        .panel h2 {
            margin: 0 0 0.35rem;
            font-size: 1.25rem;
            font-weight: 900;
            color: #111827;
        }

        .panel p {
            margin: 0 0 1.2rem;
            color: var(--muted);
            line-height: 1.7;
        }

        .field {
            margin-bottom: 1rem;
        }

        .field label {
            display: block;
            margin-bottom: 0.45rem;
            color: #7c2d12;
            font-size: 0.82rem;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .input {
            width: 100%;
            border: 1px solid #f1d1aa;
            border-radius: 16px;
            background: #fff;
            color: #111827;
            padding: 0.95rem 1rem;
            font-size: 0.96rem;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .input:focus {
            outline: none;
            border-color: #fb923c;
            box-shadow: 0 0 0 4px rgba(251, 146, 60, 0.12);
        }

        .otp-row {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 0.8rem;
        }

        .btn-main,
        .btn-ghost {
            border: none;
            border-radius: 16px;
            padding: 0.96rem 1.15rem;
            font-size: 0.96rem;
            font-weight: 900;
            cursor: pointer;
            transition: transform 0.18s ease, box-shadow 0.18s ease, opacity 0.18s ease;
        }

        .btn-main {
            width: 100%;
            background: linear-gradient(135deg, var(--accent), #fb923c);
            color: #fff;
            box-shadow: 0 16px 30px rgba(249, 115, 22, 0.18);
        }

        .btn-ghost {
            background: #fff;
            color: var(--accent-deep);
            border: 1px solid #fdba74;
        }

        .btn-main:hover,
        .btn-ghost:hover {
            transform: translateY(-1px);
        }

        .btn-main:disabled,
        .btn-ghost:disabled {
            opacity: 0.7;
            cursor: wait;
            transform: none;
        }

        .status-box {
            display: none;
            margin-bottom: 1rem;
            padding: 0.95rem 1rem;
            border-radius: 18px;
            font-weight: 700;
            line-height: 1.6;
        }

        .status-box.show {
            display: block;
        }

        .status-box.success {
            background: var(--success-bg);
            color: var(--success-ink);
            border: 1px solid #bbf7d0;
        }

        .status-box.error {
            background: var(--error-bg);
            color: var(--error-ink);
            border: 1px solid #fecdd3;
        }

        .otp-hint {
            margin-top: 1rem;
            padding: 1rem;
            border-radius: 18px;
            border: 1px dashed #fdba74;
            background: var(--accent-soft);
            color: #9a3412;
            font-weight: 700;
            display: none;
        }

        .otp-hint.show {
            display: block;
        }

        .meta-row {
            margin-top: 1rem;
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
            color: var(--muted);
            font-size: 0.9rem;
        }

        .back-link {
            margin-top: 1.2rem;
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            color: #9a3412;
            text-decoration: none;
            font-weight: 800;
        }

        .mock-modal {
            position: fixed;
            inset: 0;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            background: rgba(17, 24, 39, 0.45);
            z-index: 3000;
        }

        .mock-modal.show {
            display: flex;
        }

        .mock-modal-card {
            width: min(420px, 100%);
            border-radius: 28px;
            background: #fffaf6;
            border: 1px solid #fdba74;
            padding: 1.4rem;
            text-align: center;
            box-shadow: 0 30px 80px rgba(17, 24, 39, 0.22);
        }

        .mock-modal-card h3 {
            margin: 0 0 0.55rem;
            font-size: 1.3rem;
            font-weight: 900;
            color: #7c2d12;
        }

        .mock-modal-card p {
            margin: 0;
            color: var(--muted);
            line-height: 1.65;
        }

        .mock-otp-code {
            margin: 1rem 0;
            padding: 1rem;
            border-radius: 22px;
            background: linear-gradient(135deg, #fff7ed, #ffedd5);
            color: #c2410c;
            font-size: 2.4rem;
            letter-spacing: 0.28em;
            font-weight: 900;
            text-indent: 0.28em;
        }

        @@media (max-width: 980px) {
            .forgot-card {
                grid-template-columns: 1fr;
            }

            .forgot-side {
                padding-bottom: 2rem;
            }
        }

        @@media (max-width: 640px) {
            body {
                padding: 1rem;
            }

            .forgot-side,
            .forgot-main {
                padding: 1.5rem;
            }

            .progress {
                grid-template-columns: 1fr;
            }

            .otp-row {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="forgot-shell">
        <div class="forgot-card">
            <aside class="forgot-side">
                <div class="brand-pill">BAGERY Recovery Flow</div>
                <h1 class="side-title">Reset your password with a mock OTP.</h1>
                <p class="side-copy">
                    หน้านี้ออกแบบให้ตรงกับระบบเดิมของร้าน โดยใช้ OTP แบบจำลองบนหน้าจอ
                    เพื่อให้ทดสอบ flow ลืมรหัสผ่านได้ครบตั้งแต่ขอรหัส ยืนยันตัวตน ไปจนถึงตั้งรหัสใหม่
                </p>

                <div class="step-list">
                    <div class="step-item">
                        <div class="step-badge">01</div>
                        <div>
                            <h3>Request OTP</h3>
                            <p>กรอกอีเมลที่ใช้สมัคร ระบบจะสร้างรหัส 4 หลักและกำหนดอายุ 5 นาที</p>
                        </div>
                    </div>
                    <div class="step-item">
                        <div class="step-badge">02</div>
                        <div>
                            <h3>Verify Identity</h3>
                            <p>นำรหัสจาก popup หรือกล่อง mock มากรอกเพื่อยืนยันว่าเป็นเจ้าของบัญชี</p>
                        </div>
                    </div>
                    <div class="step-item">
                        <div class="step-badge">03</div>
                        <div>
                            <h3>Create New Password</h3>
                            <p>เมื่อ OTP ถูกต้อง ระบบจะเปิดฟอร์มตั้งรหัสใหม่และบันทึกแบบ hash ให้ปลอดภัยขึ้น</p>
                        </div>
                    </div>
                </div>

                <div class="mock-chip">Mock OTP Mode เปิดอยู่สำหรับทดสอบในระบบนี้</div>
            </aside>

            <main class="forgot-main">
                <div class="main-head">
                    <div class="eyebrow">Account Recovery</div>
                    <h1 class="main-title">Forgot Password</h1>
                    <p class="main-copy">
                        ใช้อีเมลเดิมของบัญชีคุณเพื่อรับ OTP แบบจำลอง และตั้งรหัสผ่านใหม่ในหน้าเดียว
                    </p>
                </div>

                <div class="progress">
                    <div class="progress-step active" data-progress-step="1">1. กรอกอีเมล</div>
                    <div class="progress-step" data-progress-step="2">2. ยืนยัน OTP</div>
                    <div class="progress-step" data-progress-step="3">3. ตั้งรหัสใหม่</div>
                </div>

                <div id="forgotStatus" class="status-box"></div>

                <section class="panel active" data-panel="1">
                    <h2>ส่งคำขอรับ OTP</h2>
                    <p>กรอกอีเมลของบัญชีที่ต้องการเปลี่ยนรหัสผ่าน แล้วระบบจะสร้าง OTP แบบจำลองให้ทันที</p>
                    <div class="field">
                        <label for="forgotEmail">Email</label>
                        <input id="forgotEmail" class="input" type="email" placeholder="example@email.com" />
                    </div>
                    <button id="requestOtpBtn" type="button" class="btn-main">ส่งรหัสยืนยัน</button>
                    <div id="otpHint" class="otp-hint"></div>
                    <div class="meta-row">
                        <span>OTP จะหมดอายุภายใน 5 นาที</span>
                        <span>ใช้สำหรับทดสอบ flow ลืมรหัสผ่าน</span>
                    </div>
                </section>

                <section class="panel" data-panel="2">
                    <h2>ยืนยัน OTP</h2>
                    <p>กรอกรหัส 4 หลักที่ระบบแสดงให้ แล้วกดยืนยันเพื่อไปขั้นตอนตั้งรหัสผ่านใหม่</p>
                    <div class="field">
                        <label for="otpCode">OTP Code</label>
                        <div class="otp-row">
                            <input id="otpCode" class="input" type="text" inputmode="numeric" maxlength="6" placeholder="1234" />
                            <button id="resendOtpBtn" type="button" class="btn-ghost">ขอ OTP ใหม่</button>
                        </div>
                    </div>
                    <button id="verifyOtpBtn" type="button" class="btn-main">ยืนยัน OTP</button>
                </section>

                <section class="panel" data-panel="3">
                    <h2>ตั้งรหัสผ่านใหม่</h2>
                    <p>กรอกรหัสผ่านใหม่ 2 ครั้งให้ตรงกัน ระบบจะบันทึกและพาคุณกลับไปหน้าเข้าสู่ระบบ</p>
                    <div class="field">
                        <label for="newPassword">New Password</label>
                        <input id="newPassword" class="input" type="password" placeholder="อย่างน้อย 6 ตัวอักษร" />
                    </div>
                    <div class="field">
                        <label for="confirmPassword">Confirm New Password</label>
                        <input id="confirmPassword" class="input" type="password" placeholder="กรอกรหัสผ่านใหม่อีกครั้ง" />
                    </div>
                    <button id="resetPasswordBtn" type="button" class="btn-main">บันทึกรหัสผ่านใหม่</button>
                </section>

                <a class="back-link" asp-controller="Account" asp-action="Login"><span>&larr;</span> กลับไปหน้า Login</a>
            </main>
        </div>
    </div>

    <div class="mock-modal" id="mockOtpModal">
        <div class="mock-modal-card">
            <h3>Mock OTP Ready</h3>
            <p>ระบบจำลองการส่ง OTP สำเร็จแล้ว รหัสสำหรับทดสอบของคุณคือ</p>
            <div class="mock-otp-code" id="mockOtpCode">0000</div>
            <p id="mockOtpExpireText">รหัสนี้จะหมดอายุในอีก 5 นาที</p>
            <button type="button" class="btn-main" id="closeMockOtpModal">เริ่มยืนยัน OTP</button>
        </div>
    </div>

    <script>
        (function () {
            const statusBox = document.getElementById('forgotStatus');
            const otpHint = document.getElementById('otpHint');
            const forgotEmail = document.getElementById('forgotEmail');
            const otpCode = document.getElementById('otpCode');
            const newPassword = document.getElementById('newPassword');
            const confirmPassword = document.getElementById('confirmPassword');
            const requestOtpBtn = document.getElementById('requestOtpBtn');
            const verifyOtpBtn = document.getElementById('verifyOtpBtn');
            const resendOtpBtn = document.getElementById('resendOtpBtn');
            const resetPasswordBtn = document.getElementById('resetPasswordBtn');
            const mockOtpModal = document.getElementById('mockOtpModal');
            const mockOtpCode = document.getElementById('mockOtpCode');
            const mockOtpExpireText = document.getElementById('mockOtpExpireText');
            const closeMockOtpModal = document.getElementById('closeMockOtpModal');
            const panels = Array.from(document.querySelectorAll('[data-panel]'));
            const progressSteps = Array.from(document.querySelectorAll('[data-progress-step]'));
            let currentEmail = '';
            let verifiedOtpCode = '';

            function showStatus(message, type) {
                statusBox.textContent = message;
                statusBox.className = `status-box show ${type}`;
            }

            function clearStatus() {
                statusBox.textContent = '';
                statusBox.className = 'status-box';
            }

            function setProgress(step) {
                panels.forEach(panel => {
                    panel.classList.toggle('active', panel.dataset.panel === String(step));
                });

                progressSteps.forEach(item => {
                    item.classList.toggle('active', Number(item.dataset.progressStep) <= step);
                });
            }

            async function parseJsonResponse(response) {
                const text = await response.text();
                if (!text) {
                    throw new Error(`Empty response (${response.status})`);
                }

                const data = JSON.parse(text);
                if (!response.ok || data.success === false) {
                    throw new Error(data.message || `HTTP ${response.status}`);
                }

                return data;
            }

            async function postJson(url, payload) {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                return parseJsonResponse(response);
            }

            function setLoading(button, loading, loadingText, normalText) {
                if (!button) return;
                button.disabled = loading;
                button.textContent = loading ? loadingText : normalText;
            }

            async function requestOtp() {
                const email = forgotEmail.value.trim();
                if (!email) {
                    showStatus('กรุณากรอกอีเมลก่อนส่งคำขอ', 'error');
                    forgotEmail.focus();
                    return;
                }

                clearStatus();
                setLoading(requestOtpBtn, true, 'กำลังสร้าง OTP...', 'ส่งรหัสยืนยัน');
                setLoading(resendOtpBtn, true, 'กำลังสร้าง OTP...', 'ขอ OTP ใหม่');

                try {
                    const data = await postJson('@Url.Action("RequestPasswordReset", "Account")', { email });
                    currentEmail = email;
                    verifiedOtpCode = '';
                    otpHint.textContent = `Mock OTP: ${data.mockOtp} | หมดอายุเวลา ${data.expiresAt} น.`;
                    otpHint.classList.add('show');
                    mockOtpCode.textContent = data.mockOtp;
                    mockOtpExpireText.textContent = `รหัสนี้จะหมดอายุเวลา ${data.expiresAt} น.`;
                    mockOtpModal.classList.add('show');
                    showStatus(data.message || 'สร้าง OTP สำเร็จแล้ว', 'success');
                    otpCode.value = '';
                    setProgress(2);
                } catch (error) {
                    showStatus(error.message || 'ไม่สามารถส่ง OTP ได้ในขณะนี้', 'error');
                } finally {
                    setLoading(requestOtpBtn, false, 'กำลังสร้าง OTP...', 'ส่งรหัสยืนยัน');
                    setLoading(resendOtpBtn, false, 'กำลังสร้าง OTP...', 'ขอ OTP ใหม่');
                }
            }

            async function verifyOtp() {
                const email = currentEmail || forgotEmail.value.trim();
                const code = otpCode.value.trim();

                if (!email) {
                    showStatus('กรุณาขอ OTP ก่อนยืนยันรหัส', 'error');
                    setProgress(1);
                    return;
                }

                if (!code) {
                    showStatus('กรุณากรอก OTP ก่อนกดยืนยัน', 'error');
                    otpCode.focus();
                    return;
                }

                clearStatus();
                setLoading(verifyOtpBtn, true, 'กำลังตรวจสอบ OTP...', 'ยืนยัน OTP');

                try {
                    const data = await postJson('@Url.Action("VerifyPasswordResetOtp", "Account")', {
                        email,
                        otpCode: code
                    });

                    verifiedOtpCode = code;
                    showStatus(data.message || 'ยืนยัน OTP สำเร็จ', 'success');
                    setProgress(3);
                    newPassword.focus();
                } catch (error) {
                    verifiedOtpCode = '';
                    showStatus(error.message || 'OTP ไม่ถูกต้อง', 'error');
                } finally {
                    setLoading(verifyOtpBtn, false, 'กำลังตรวจสอบ OTP...', 'ยืนยัน OTP');
                }
            }

            async function resetPassword() {
                const email = currentEmail || forgotEmail.value.trim();
                const otp = verifiedOtpCode || otpCode.value.trim();
                const password = newPassword.value;
                const confirm = confirmPassword.value;

                if (!email) {
                    showStatus('กรุณาเริ่มต้นด้วยการขอ OTP ก่อน', 'error');
                    setProgress(1);
                    return;
                }

                if (!otp) {
                    showStatus('กรุณายืนยัน OTP ให้สำเร็จก่อนตั้งรหัสผ่านใหม่', 'error');
                    setProgress(2);
                    return;
                }

                if (!password || !confirm) {
                    showStatus('กรุณากรอกรหัสผ่านใหม่ให้ครบทั้ง 2 ช่อง', 'error');
                    return;
                }

                clearStatus();
                setLoading(resetPasswordBtn, true, 'กำลังบันทึกรหัสผ่าน...', 'บันทึกรหัสผ่านใหม่');

                try {
                    const data = await postJson('@Url.Action("ResetPassword", "Account")', {
                        email,
                        otpCode: otp,
                        newPassword: password,
                        confirmPassword: confirm
                    });

                    showStatus(data.message || 'เปลี่ยนรหัสผ่านสำเร็จ', 'success');
                    otpHint.classList.remove('show');
                    setTimeout(function () {
                        window.location.href = data.redirectUrl || '@Url.Action("Login", "Account")';
                    }, 1200);
                } catch (error) {
                    showStatus(error.message || 'ไม่สามารถเปลี่ยนรหัสผ่านได้', 'error');
                } finally {
                    setLoading(resetPasswordBtn, false, 'กำลังบันทึกรหัสผ่าน...', 'บันทึกรหัสผ่านใหม่');
                }
            }

            requestOtpBtn?.addEventListener('click', requestOtp);
            resendOtpBtn?.addEventListener('click', requestOtp);
            verifyOtpBtn?.addEventListener('click', verifyOtp);
            resetPasswordBtn?.addEventListener('click', resetPassword);

            closeMockOtpModal?.addEventListener('click', function () {
                mockOtpModal.classList.remove('show');
                otpCode.focus();
            });

            mockOtpModal?.addEventListener('click', function (event) {
                if (event.target === mockOtpModal) {
                    mockOtpModal.classList.remove('show');
                    otpCode.focus();
                }
            });
        })();
    </script>
</body>
</html>
