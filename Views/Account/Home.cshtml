<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.menu-card .menu-price').forEach(function (priceEl) {
            priceEl.textContent = priceEl.textContent
                .replace(/เธ\./g, 'บ.')
                .replace(/เน€เธย\./g, 'บ.');
        });

        document.querySelectorAll('.menu-card .btn-buy').forEach(function (button) {
            if (button.textContent.includes('เธ') || button.textContent.includes('เน€')) {
                button.textContent = 'เลือกซื้อ';
            }
        });

        document.querySelectorAll('.menu-card .add-favorite').forEach(function (favoriteEl) {
            if (favoriteEl.textContent.includes('เธ') || favoriteEl.textContent.includes('เน€') || favoriteEl.textContent.includes('โ')) {
                favoriteEl.textContent = '♡ เพิ่มลงรายการโปรด';
            }
        });
    });
</script>
