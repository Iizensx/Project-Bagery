        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        box-shadow: 0 12px 24px rgba(249,115,22,0.28);
    }

    .app-phone-brand-name {
        font-size: 1.2rem;
        font-weight: 900;
        color: #111827;
    }

    .app-phone-brand-copy {
        color: #6B7280;
        font-size: 0.88rem;
    }

    .app-phone-card {
        border-radius: 22px;
        background: #fff;
        border: 1px solid #F3E5DA;
        padding: 1rem;
        box-shadow: 0 14px 30px rgba(76,42,17,0.08);
        margin-bottom: 0.9rem;
    }

    .app-phone-card-title {
        color: #111827;
        font-weight: 900;
        margin-bottom: 0.45rem;
    }

    .app-phone-card-copy {
        color: #6B7280;
        font-size: 0.88rem;
        line-height: 1.7;
        margin-bottom: 0.85rem;
    }

    .app-phone-chip-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .app-phone-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        border-radius: 999px;
        background: #FFF3E8;
        color: #C2410C;
        padding: 0.45rem 0.75rem;
        font-size: 0.8rem;
        font-weight: 800;
    }

    .app-phone-store-row {
        display: grid;
        gap: 0.7rem;
    }

    .app-phone-store {
        display: flex;
