@{
    ViewData["Title"] = "Home Page";
}

<style>
    body {
        background-color: #FDE8E1;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* ─── Hero Banner ─────────────────────────────── */
    .hero-banner-wrap {
        position: relative;
        width: 100%;
        height: 92vh;
        min-height: 580px;
        max-height: 750px;
        overflow: visible;
        margin-top: -80px;
    }

    .hero-banner-clip {
        position: absolute;
        inset: 0;
        overflow: hidden;
    }

    .hero-bg-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 30%;
        animation: heroZoom 8s ease-out forwards;
    }

    @@keyframes heroZoom {
        from { transform: scale(1.06); }
        to   { transform: scale(1.00); }
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            105deg,
            rgba(15, 8, 3, 0.82) 0%,
            rgba(20, 10, 4, 0.65) 40%,
            rgba(10, 5, 2, 0.28) 70%,
            rgba(0, 0, 0, 0.08) 100%
        );
    }

    .hero-overlay::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 30% 50%, transparent 40%, rgba(0,0,0,0.40) 100%);
    }

    .hero-content {
        position: relative;
        z-index: 2;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 0 6rem;
        padding-bottom: 6rem;
        max-width: 700px;
        animation: heroComeIn 1s ease-out 0.3s both;
    }

    @@keyframes heroComeIn {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(249, 115, 22, 0.18);
        border: 1px solid rgba(249, 115, 22, 0.50);
        color: #FFB980;
        font-size: 0.75rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        padding: 6px 18px;
        border-radius: 30px;
        margin-bottom: 1.5rem;
        width: fit-content;
    }

    .hero-eyebrow::before {
        content: '';
        width: 6px; height: 6px;
        background: #F97316;
        border-radius: 50%;
        display: inline-block;
    }

    .hero-title {
        font-size: clamp(2.4rem, 5vw, 3.8rem);
        font-weight: 800;
        line-height: 1.1;
        color: #FFFFFF;
        margin: 0 0 0.5rem;
        letter-spacing: -1px;
    }

    .hero-title .accent       { color: #F97316; display: block; }
    .hero-title .accent-light { color: #FFD4A8; }

    .hero-subtitle {
        color: rgba(255, 230, 205, 0.80);
        font-size: 1.05rem;
        line-height: 1.7;
        margin: 1.2rem 0 2rem;
        max-width: 420px;
    }

    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

    .btn-hero-primary {
        background: #F97316;
        color: #fff;
        padding: 0.85rem 2.2rem;
        border-radius: 50px;
        border: none;
        font-weight: 700;
        font-size: 0.95rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s;
        box-shadow: 0 8px 24px rgba(249, 115, 22, 0.40);
    }

    .btn-hero-primary:hover {
        background: #ea580c;
        transform: translateY(-3px);
        box-shadow: 0 12px 30px rgba(249, 115, 22, 0.50);
        color: #fff;
    }

    .btn-hero-secondary {
        background: rgba(255,255,255,0.10);
        color: #fff;
        padding: 0.85rem 2.2rem;
        border-radius: 50px;
        border: 1.5px solid rgba(255,255,255,0.45);
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        backdrop-filter: blur(4px);
        transition: all 0.3s;
    }

    .btn-hero-secondary:hover {
        background: rgba(255,255,255,0.20);
        border-color: rgba(255,255,255,0.70);
        color: #fff;
        transform: translateY(-3px);
    }

    .scroll-hint {
        position: absolute;
        bottom: 130px;
        right: 5rem;
        z-index: 3;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        animation: heroComeIn 1s ease-out 1.2s both;
    }

    .scroll-hint span {
        font-size: 0.68rem;
        letter-spacing: 3px;
        color: rgba(255,220,190,0.55);
        text-transform: uppercase;
        writing-mode: vertical-rl;
    }

    .scroll-line {
        width: 1px; height: 50px;
        background: linear-gradient(to bottom, rgba(249,115,22,0.7), transparent);
        animation: scrollPulse 2s ease-in-out infinite;
    }

    @@keyframes scrollPulse {
        0%, 100% { opacity: 0.5; transform: scaleY(1); }
        50%       { opacity: 1;   transform: scaleY(1.2); }
    }

    /* ─── Features Float Card ─────────────────────── */
    .features-float {
    position: absolute;
    bottom: -64px;
    left: 2rem;
    right: 2rem;
    width: auto;
    max-width: 1100px;
    margin: 0 auto;
    z-index: 10;
    animation: heroComeIn 1s ease-out 0.9s both;
}

    .features-card-inner {
        background: #ffffff;
        border-radius: 20px;
        padding: 1.8rem 2rem;
        box-shadow: 0 20px 60px rgba(0,0,0,0.18), 0 4px 16px rgba(0,0,0,0.08);
        display: grid;
        grid-template-columns: repeat(3, 1fr);
    }

    .feature-item-new {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.8rem 1.5rem;
        border-right: 1px solid #F3F4F6;
        border-radius: 12px;
        transition: background 0.3s;
    }

    .feature-item-new:last-child { border-right: none; }
    .feature-item-new:hover { background: #FFF8F3; }

    .feature-icon-box {
        width: 54px; height: 54px;
        background: #FFF3E8;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        flex-shrink: 0;
        transition: transform 0.3s;
    }

    .feature-item-new:hover .feature-icon-box { transform: scale(1.1) rotate(-4deg); }

    .feature-title-new {
        font-size: 1rem;
        font-weight: 700;
        color: #1a1a1a;
        margin: 0 0 3px;
    }

    .feature-text-new {
        font-size: 0.82rem;
        color: #6B7280;
        margin: 0;
    }

    /* spacer ให้ section ถัดไปไม่ทับ card */
    .hero-spacer { height: 90px; background: #FDE8E1; }

    /* ─── Section Title ───────────────────────────── */
    .section-title {
        color: #F97316;
        font-size: 2rem;
        font-weight: bold;
        margin: 3rem 0 2rem 0;
    }

    .view-all {
        color: #333;
        font-size: 1rem;
        text-decoration: none;
        transition: color 0.3s;
    }

    .view-all:hover { color: #F97316; }

    /* ─── Menu Cards ──────────────────────────────── */
    .menu-card {
        background: white;
        border-radius: 18px;
        padding: 1rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        transition: all 0.3s;
        margin-bottom: 1.5rem;
        border: 1px solid #F3F4F6;
    }

    .menu-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 30px rgba(249,115,22,0.15);
        border-color: #F97316;
    }

    .menu-image {
        width: 100%;
        height: 160px;
        background-color: #E5E7EB;
        border-radius: 12px;
        margin-bottom: 1rem;
        overflow: hidden;
    }

    .menu-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s;
    }

    .menu-card:hover .menu-image img { transform: scale(1.07); }

    .menu-title {
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 0.3rem;
    }

    .menu-price {
        color: #F97316;
        font-weight: bold;
        font-size: 1.1rem;
        margin-bottom: 0.8rem;
    }

    .btn-buy {
        width: 100%;
        background-color: #1a1a1a;
        color: white;
        padding: 0.65rem;
        border-radius: 10px;
        border: none;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-buy:hover {
        background-color: #F97316;
        transform: translateY(-1px);
    }

    .add-favorite {
        text-align: center;
        color: #9CA3AF;
        font-size: 0.85rem;
        margin-top: 0.5rem;
        cursor: pointer;
        transition: color 0.3s;
    }

    .add-favorite:hover { color: #F97316; }

    /* ─── Promotion Section ───────────────────────── */
    .promo-section-wrap {
        background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
        border-radius: 24px;
        padding: 3rem;
        margin: 2rem 0 3rem;
    }

    .promo-section-title {
        color: #F97316;
        font-size: 0.8rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
    }

    .promo-section-heading {
        color: #fff;
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 2rem;
    }

    .promo-card-new {
        border-radius: 16px;
        padding: 2rem;
        min-height: 180px;
        margin-bottom: 1.2rem;
        position: relative;
        overflow: hidden;
        transition: transform 0.3s;
    }

    .promo-card-new:hover { transform: translateY(-4px); }

    .promo-main {
        background: linear-gradient(135deg, #F97316 0%, #ea580c 100%);
        min-height: 240px;
    }

    .promo-badge {
        display: inline-block;
        background: rgba(255,255,255,0.2);
        color: #fff;
        font-size: 0.7rem;
        letter-spacing: 2px;
        padding: 4px 12px;
        border-radius: 20px;
        margin-bottom: 1rem;
    }

    .promo-main h2 {
        color: #fff;
        font-size: 2.5rem;
        font-weight: 900;
        margin-bottom: 0.5rem;
        line-height: 1;
    }

    .promo-main p { color: rgba(255,255,255,0.85); font-size: 0.95rem; }

    .coupon-box {
        background: rgba(255,255,255,0.15);
        border: 1.5px dashed rgba(255,255,255,0.5);
        color: #fff;
        padding: 0.6rem 1.5rem;
        border-radius: 10px;
        display: inline-block;
        font-weight: 800;
        font-size: 1.1rem;
        margin-top: 1rem;
        letter-spacing: 2px;
    }

    .promo-secondary {
        background: linear-gradient(135deg, #FFF8E7 0%, #FFE4B0 100%);
    }

    .promo-secondary h3 {
        color: #7C3A0E;
        font-size: 1.4rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
    }

    .promo-secondary p { color: #9a6040; font-size: 0.9rem; }

    .promo-dark {
        background: linear-gradient(135deg, #7C3A0E 0%, #4A1B0C 100%);
    }

    .promo-dark h3 { color: #F97316; font-size: 1.6rem; font-weight: 900; margin-bottom: 0.3rem; }
    .promo-dark p  { color: rgba(255,220,190,0.8); font-size: 0.9rem; }

    /* ─── Cake / Feature Section ──────────────────── */
    .highlight-section {
        background: white;
        border-radius: 24px;
        padding: 4rem 3rem;
        margin: 0 0 3rem;
        box-shadow: 0 4px 24px rgba(0,0,0,0.06);
    }

    .highlight-label {
        color: #F97316;
        font-size: 0.8rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 0.8rem;
        font-weight: 600;
    }

    .highlight-title {
        font-size: 2rem;
        font-weight: 800;
        color: #1a1a1a;
        line-height: 1.3;
        margin-bottom: 1.5rem;
    }

    .highlight-title span { color: #F97316; }

    .highlight-text {
        color: #6B7280;
        font-size: 1rem;
        line-height: 1.8;
        margin-bottom: 2rem;
    }

    .btn-highlight {
        background: #F97316;
        color: #fff;
        padding: 0.85rem 2.2rem;
        border-radius: 50px;
        border: none;
        font-weight: 700;
        font-size: 0.95rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s;
        box-shadow: 0 8px 24px rgba(249,115,22,0.35);
    }

    .btn-highlight:hover {
        background: #ea580c;
        transform: translateY(-3px);
        color: #fff;
    }

    .highlight-img {
        width: 100%;
        height: 380px;
        border-radius: 20px;
        object-fit: cover;
        box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    }

    /* ─── Responsive ──────────────────────────────── */
    @@media (max-width: 900px) {
        .features-card-inner {
            grid-template-columns: 1fr;
        }
        .feature-item-new { border-right: none; border-bottom: 1px solid #F3F4F6; }
        .feature-item-new:last-child { border-bottom: none; }
        .features-float { bottom: -220px; }
        .hero-spacer    { height: 260px; }
    }

    @@media (max-width: 768px) {
        .hero-content { padding: 0 2rem; padding-bottom: 5rem; max-width: 100%; }
        .hero-title   { font-size: 2.2rem; }
        .scroll-hint  { display: none; }
        .features-float { width: calc(100% - 2rem); }
        .promo-section-wrap { padding: 2rem 1.5rem; }
    }

    @@media (max-width: 480px) {
        .hero-banner-wrap { height: 100svh; max-height: none; }
        .hero-content { padding: 0 1.5rem; padding-bottom: 5rem; }
        .hero-title   { font-size: 1.9rem; }
        .hero-subtitle { font-size: 0.95rem; }
        .btn-hero-primary, .btn-hero-secondary { padding: 0.75rem 1.6rem; font-size: 0.88rem; }
        .features-float { bottom: -280px; }
        .hero-spacer    { height: 320px; }
    }
</style>


@* ─── HERO BANNER ──────────────────────────────────── *@
<div class="hero-banner-wrap">

    <div class="hero-banner-clip">
        <img class="hero-bg-img" src="~/img/HomeBG.jpg" alt="BAGERY Bakery">
        <div class="hero-overlay"></div>
    </div>

    <div class="hero-content">
        <div class="hero-eyebrow">อบสดทุกเช้า &nbsp;·&nbsp; ส่งเร็วภายใน 30 นาที</div>
        <h1 class="hero-title">
            <span class="accent-light">เบเกอรี่และเค้ก</span>
            <span class="accent">อร่อยทุกคำ</span>
            ส่งตรงถึงบ้าน
        </h1>
        <p class="hero-subtitle">
            คัดสรรวัตถุดิบคุณภาพ อบสดใหม่ทุกวัน
            ครัวซองต์ เค้ก ขนมปัง และเมนูพิเศษอีกมากมาย
        </p>
        <div class="hero-actions">
            <a href="#menu" class="btn-hero-primary">🛒 &nbsp;สั่งเลยตอนนี้</a>
            <a asp-controller="Account" asp-action="Menu" class="btn-hero-secondary">ดูเมนูทั้งหมด →</a>
        </div>
    </div>

    <div class="scroll-hint">
        <div class="scroll-line"></div>
        <span>scroll</span>
    </div>

    @* Features Card ลอยทับ *@
    <div class="features-float">
        <div class="features-card-inner">
            <div class="feature-item-new">
                <div class="feature-icon-box">🛵</div>
                <div>
                    <p class="feature-title-new">Fast Delivery</p>
                    <p class="feature-text-new">จัดส่งด่วนภายใน 30 นาที</p>
                </div>
            </div>
            <div class="feature-item-new">
                <div class="feature-icon-box">🥐</div>
                <div>
                    <p class="feature-title-new">Fresh Food</p>
                    <p class="feature-text-new">วัตถุดิบคุณภาพ อบสดทุกเช้า</p>
                </div>
            </div>
            <div class="feature-item-new">
                <div class="feature-icon-box">📦</div>
                <div>
                    <p class="feature-title-new">Free Delivery</p>
                    <p class="feature-text-new">3 ออเดอร์แรก ฟรีค่าจัดส่ง</p>
                </div>
            </div>
        </div>
    </div>

</div>

@* Spacer *@
<div class="hero-spacer"></div>


@* ─── MENU SECTION ─────────────────────────────────── *@
<div class="container" id="menu">
    <div class="d-flex justify-content-between align-items-center">
        <h2 class="section-title">เมนูยอดฮิต</h2>
        <a asp-controller="Account" asp-action="Menu" class="view-all">ดูทั้งหมด →</a>
    </div>

    <div class="row">
        <div class="col-md-3">
            <div class="menu-card">
                <div class="menu-image">
                    <img src="https://images.unsplash.com/photo-1555507036-ab1f4038808a?auto=format&fit=crop&q=80&w=400" alt="ครัวซองต์">
                </div>
                <h5 class="menu-title">Plain Croissant</h5>
                <p class="menu-price">75 บ.</p>
                <button class="btn-buy" onclick="addToCart('Plain Croissant', 75)">เลือกซื้อ</button>
                <p class="add-favorite">♡ เพิ่มลงรายการโปรด</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="menu-card">
                <div class="menu-image">
                    <img src="https://images.unsplash.com/photo-1533134242443-d4fd215305ad?auto=format&fit=crop&q=80&w=400" alt="ชีสเค้ก">
                </div>
                <h5 class="menu-title">Blueberry Cheesecake</h5>
                <p class="menu-price">145 บ.</p>
                <button class="btn-buy" onclick="addToCart('Blueberry Cheesecake', 145)">เลือกซื้อ</button>
                <p class="add-favorite">♡ เพิ่มลงรายการโปรด</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="menu-card">
                <div class="menu-image">
                    <img src="https://images.unsplash.com/photo-1578985545062-69928b1d9587?auto=format&fit=crop&q=80&w=400" alt="ช็อกโกแลตเค้ก">
                </div>
                <h5 class="menu-title">Chocolate Fudge Cake</h5>
                <p class="menu-price">125 บ.</p>
                <button class="btn-buy" onclick="addToCart('Chocolate Fudge Cake', 125)">เลือกซื้อ</button>
                <p class="add-favorite">♡ เพิ่มลงรายการโปรด</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="menu-card">
                <div class="menu-image">
                    <img src="https://images.unsplash.com/photo-1509440159596-0249088772ff?auto=format&fit=crop&q=80&w=400" alt="อัลมอนด์ครัวซองต์">
                </div>
                <h5 class="menu-title">Almond Croissant</h5>
                <p class="menu-price">95 บ.</p>
                <button class="btn-buy" onclick="addToCart('Almond Croissant', 95)">เลือกซื้อ</button>
                <p class="add-favorite">♡ เพิ่มลงรายการโปรด</p>
            </div>
        </div>
    </div>
</div>


@* ─── PROMOTION SECTION ────────────────────────────── *@
<div class="container">
    <div class="promo-section-wrap">
        <p class="promo-section-title">Special Deals</p>
        <h2 class="promo-section-heading">โปรโมชั่นพิเศษ</h2>

        <div class="row">
            <div class="col-md-5">
                <div class="promo-card-new promo-main">
                    <div class="promo-badge">LIMITED TIME OFFER</div>
                    <h2>25% OFF</h2>
                    <p>สั่งอาหารทุกเมนู รับส่วนลดพิเศษทันที</p>
                    <div class="coupon-box">BAGERY25</div>
                </div>
            </div>
            <div class="col-md-7">
                <div class="promo-card-new promo-secondary">
                    <h3>🎂 ฟรีเค้กวันเกิด</h3>
                    <p>สมัครสมาชิกวันนี้ รับเค้กวันเกิดฟรี 1 ชิ้น<br>พร้อมส่วนลด 10% ตลอดเดือนเกิด</p>
                    <a asp-controller="Account" asp-action="Signup"
                       style="display:inline-flex; align-items:center; gap:6px; margin-top:1rem;
                              background:#F97316; color:#fff; padding:0.6rem 1.5rem;
                              border-radius:20px; font-weight:700; font-size:0.88rem;
                              text-decoration:none; transition:all 0.3s;">
                        สมัครเลย →
                    </a>
                </div>

                <div class="promo-card-new promo-dark" style="margin-top:0;">
                    <h3>BAGERY CARD</h3>
                    <p>สะสมแต้มทุกออเดอร์ แลกรับของรางวัลและส่วนลดพิเศษ</p>
                </div>
            </div>
        </div>
    </div>
</div>


@* ─── HIGHLIGHT / CAKE SECTION ─────────────────────── *@
<div class="container">
    <div class="highlight-section">
        <div class="row align-items-center g-5">
            <div class="col-md-6">
                <p class="highlight-label">Our Specialty</p>
                <h2 class="highlight-title">
                    เค้กอบใหม่ทุกวัน<br>
                    <span>สดจากเตา</span> ถึงมือคุณ
                </h2>
                <p class="highlight-text">
