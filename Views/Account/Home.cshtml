        }

        .home-stat-grid {
            grid-template-columns: 1fr;
        }

        .social-platforms {
            grid-template-columns: 1fr;
        }

        .social-app-shell {
            padding: 1.5rem;
            border-radius: 24px;
        }

        .app-phone-screen {
            min-height: auto;
        }
    }
</style>


