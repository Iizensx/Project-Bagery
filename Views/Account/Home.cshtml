@* ─── HIGHLIGHT / CAKE SECTION ─────────────────────── *@
<div class="container" style="margin-top:-2rem;">
    <div class="promo-section-wrap" style="background: transparent; box-shadow: none; padding-top: 0;">
        @if (publicPromotions.Any())
        {
            <div class="home-promo-head">
                <div>
                    <div class="promo-section-title">Public Promotion</div>
                    <h2 class="promo-section-heading" style="color:#1a1a1a; margin-bottom:0;">โปรโมชั่นแนะนำบนหน้าแรก</h2>
                    <p class="home-promo-copy">โปรโมชั่นพิเศษจาก BAGERY ที่เปิดให้ลูกค้าเห็นบนหน้าแรกทันที</p>
                </div>
                <a asp-controller="Home" asp-action="Promotion" class="view-all">ดูโปรโมชั่นทั้งหมด →</a>
            </div>

            <section class="home-promo-grid">
                @foreach (var promo in publicPromotions.Take(3))
                {
                    <article class="home-promo-card">
                        <div class="home-promo-image">
                            @if (!string.IsNullOrWhiteSpace(promo.ImagePath))
                            {
                                <img src="@promo.ImagePath" alt="@promo.PromotionName">
                            }
                        </div>
                        <div class="home-promo-body">
                            <div class="home-promo-top">
                                <div class="home-promo-badge">@HomePromoTitle(promo)</div>
                            </div>
                            <div class="home-promo-name">@promo.PromotionName</div>
                            <div class="home-promo-desc">@(string.IsNullOrWhiteSpace(promo.Description) ? "โปรโมชั่นพิเศษจาก BAGERY ที่เปิดให้ลูกค้าเห็นบนหน้าแรกทันที" : promo.Description)</div>
                            <a asp-controller="Home" asp-action="Promotion" class="home-promo-link">ดูรายละเอียดโปรโมชั่น →</a>
                        </div>
                    </article>
                }
            </section>
        }
        else
        {
            <div class="promo-card-new promo-secondary" style="margin-top:0;">
                <h3>ยังไม่มีโปรโมชั่น Public</h3>
                <p>โปรที่จะขึ้นหน้า Home ต้องมีรูปภาพก่อน ถ้าโปรไม่มีรูปจะถูกเก็บไว้ให้แอดมินใช้แจกอย่างเดียวและไม่โชว์ฝั่งลูกค้า</p>
                <a asp-controller="Home" asp-action="Promotion"
                   style="display:inline-flex; align-items:center; gap:6px; margin-top:1rem;
                          background:#F97316; color:#fff; padding:0.6rem 1.5rem;
                          border-radius:20px; font-weight:700; font-size:0.88rem;
                          text-decoration:none; transition:all 0.3s;">
                    ไปหน้ารวมโปรโมชั่น →
                </a>
            </div>
        }
    </div>
</div>






