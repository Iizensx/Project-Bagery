@{
    ViewData["Title"] = "Home Page";
    var publicPromotions = ViewBag.PublicPromotions as List<_66022380.Models.Db.Promotion> ?? new();
    var featuredProducts = ViewBag.FeaturedProducts as List<_66022380.Models.Db.Stock> ?? new();
    var fallbackFeaturedProducts = new[]
    {
        new { Name = "Plain Croissant", Price = 75m, Image = "https://images.unsplash.com/photo-1555507036-ab1f4038808a?auto=format&fit=crop&q=80&w=400" },
        new { Name = "Blueberry Cheesecake", Price = 145m, Image = "https://images.unsplash.com/photo-1533134242443-d4fd215305ad?auto=format&fit=crop&q=80&w=400" },
        new { Name = "Chocolate Fudge Cake", Price = 125m, Image = "https://images.unsplash.com/photo-1578985545062-69928b1d9587?auto=format&fit=crop&q=80&w=400" },
        new { Name = "Almond Croissant", Price = 95m, Image = "https://images.unsplash.com/photo-1509440159596-0249088772ff?auto=format&fit=crop&q=80&w=400" },
        new { Name = "Classic Brownie", Price = 89m, Image = "https://images.unsplash.com/photo-1486427944299-d1955d23e34d?auto=format&fit=crop&q=80&w=400" },
        new { Name = "Strawberry Mini Cake", Price = 135m, Image = "https://images.unsplash.com/photo-1519864600265-abb23847ef2c?auto=format&fit=crop&q=80&w=400" },
        new { Name = "Cinnamon Roll", Price = 79m, Image = "https://images.unsplash.com/photo-1464306076886-da185f6a9d05?auto=format&fit=crop&q=80&w=400" },
        new { Name = "Fruit Tart", Price = 119m, Image = "https://images.unsplash.com/photo-1608198093002-ad4e005484ec?auto=format&fit=crop&q=80&w=400" }
    };

    string HomePromoTitle(_66022380.Models.Db.Promotion promo)
    {
        if (promo.PromoType == 1)
            return $"ลด {promo.DiscountValue:0.##} {(promo.DiscountType == "Percent" ? "%" : "บาท")}";
        if (promo.PromoType == 2)
            return $"ซื้อ {promo.BuyQuantity ?? 0} แถม {promo.RewardQuantity ?? 0}";
        return "กิจกรรมพิเศษหน้าร้าน";
    }
}

<style>
    :root {
        --home-surface: #FDE8E1;
    }

    body {
        background-color: var(--home-surface);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding-top: 0 !important;
    }

    main .container {
        width: min(1280px, calc(100% - 2rem));
        max-width: 1280px;
        margin-left: auto;
        margin-right: auto;
        padding-left: 0;
        padding-right: 0;
    }

    /* ─── Hero Banner ─────────────────────────────── */
    .hero-banner-wrap {
        position: relative;
        width: 100%;
        height: 100vh;
        min-height: 520px;
        max-height: 750px;
        overflow: visible;
        margin-top: 0;
        background-color: var(--home-surface);
    }

    .hero-banner-wrap::before {
        display: none;
    }

    .hero-banner-clip {
        position: absolute;
        inset: 0;
        overflow: hidden;
    }

    .hero-bg-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 18%;
        animation: heroZoom 8s ease-out forwards;
    }

    @@keyframes heroZoom {
        from { transform: scale(1.06); }
        to   { transform: scale(1.00); }
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            105deg,
            rgba(15, 8, 3, 0.82) 0%,
            rgba(20, 10, 4, 0.65) 40%,
            rgba(10, 5, 2, 0.28) 70%,
            rgba(0, 0, 0, 0.08) 100%
        );
    }

    .hero-overlay::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 30% 50%, transparent 40%, rgba(0,0,0,0.40) 100%);
    }

    .wave-divider {
        position: absolute;
        left: 0;
        right: 0;
        bottom: -1px;
        line-height: 0;
        overflow: hidden;
        z-index: 3;
        pointer-events: none;
    }

    .wave-divider svg {
        display: block;
        width: 100%;
        height: 96px;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 0 6rem;
        padding-bottom: 6rem;
        max-width: 700px;
        animation: heroComeIn 1s ease-out 0.3s both;
    }

    @@keyframes heroComeIn {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(249, 115, 22, 0.18);
        border: 1px solid rgba(249, 115, 22, 0.50);
        color: #FFB980;
        font-size: 0.75rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        padding: 6px 18px;
        border-radius: 30px;
        margin-bottom: 1.5rem;
        width: fit-content;
    }

    .hero-eyebrow::before {
        content: '';
        width: 6px; height: 6px;
        background: #F97316;
        border-radius: 50%;
        display: inline-block;
    }

    .hero-title {
        font-size: clamp(2.4rem, 5vw, 3.8rem);
        font-weight: 800;
        line-height: 1.1;
        color: #FFFFFF;
        margin: 0 0 0.5rem;
        letter-spacing: -1px;
    }

    .hero-title .accent       { color: #F97316; display: block; }
    .hero-title .accent-light { color: #FFD4A8; }

    .hero-subtitle {
        color: rgba(255, 230, 205, 0.80);
        font-size: 1.05rem;
        line-height: 1.7;
        margin: 1.2rem 0 2rem;
        max-width: 420px;
    }

    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

    .btn-hero-primary {
        background: #F97316;
        color: #fff;
        padding: 0.85rem 2.2rem;
        border-radius: 50px;
        border: none;
        font-weight: 700;
        font-size: 0.95rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s;
        box-shadow: 0 8px 24px rgba(249, 115, 22, 0.40);
    }

    .btn-hero-primary:hover {
        background: #ea580c;
        transform: translateY(-3px);
        box-shadow: 0 12px 30px rgba(249, 115, 22, 0.50);
        color: #fff;
    }

    .btn-hero-secondary {
        background: rgba(255,255,255,0.10);
        color: #fff;
        padding: 0.85rem 2.2rem;
        border-radius: 50px;
        border: 1.5px solid rgba(255,255,255,0.45);
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        backdrop-filter: blur(4px);
        transition: all 0.3s;
    }

    .btn-hero-secondary:hover {
        background: rgba(255,255,255,0.20);
        border-color: rgba(255,255,255,0.70);
        color: #fff;
        transform: translateY(-3px);
    }

    .scroll-hint {
        position: absolute;
        bottom: 130px;
        right: 5rem;
        z-index: 3;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        animation: heroComeIn 1s ease-out 1.2s both;
    }

    .scroll-hint span {
        font-size: 0.68rem;
        letter-spacing: 3px;
        color: rgba(255,220,190,0.55);
        text-transform: uppercase;
        writing-mode: vertical-rl;
    }

    .scroll-line {
        width: 1px; height: 50px;
        background: linear-gradient(to bottom, rgba(249,115,22,0.7), transparent);
        animation: scrollPulse 2s ease-in-out infinite;
    }

    @@keyframes scrollPulse {
        0%, 100% { opacity: 0.5; transform: scaleY(1); }
        50%       { opacity: 1;   transform: scaleY(1.2); }
    }

    /* ─── Features Float Card ─────────────────────── */
    .features-float {
    position: absolute;
    bottom: -64px;
    left: 2rem;
    right: 2rem;
    width: auto;
    max-width: 1100px;
    margin: 0 auto;
    z-index: 10;
    animation: heroComeIn 1s ease-out 0.9s both;
}

    .features-card-inner {
        background: #ffffff;
        border-radius: 20px;
        padding: 1.8rem 2rem;
        box-shadow: 0 20px 60px rgba(0,0,0,0.18), 0 4px 16px rgba(0,0,0,0.08);
        display: grid;
        grid-template-columns: repeat(3, 1fr);
    }

    .feature-item-new {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.8rem 1.5rem;
        border-right: 1px solid #F3F4F6;
        border-radius: 12px;
        transition: background 0.3s;
    }

    .feature-item-new:last-child { border-right: none; }
    .feature-item-new:hover { background: #FFF8F3; }

    .feature-icon-box {
        width: 54px; height: 54px;
        background: #FFF3E8;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        flex-shrink: 0;
        transition: transform 0.3s;
    }

    .feature-item-new:hover .feature-icon-box { transform: scale(1.1) rotate(-4deg); }

    .feature-title-new {
        font-size: 1rem;
        font-weight: 700;
        color: #1a1a1a;
        margin: 0 0 3px;
    }

    .feature-text-new {
        font-size: 0.82rem;
        color: #6B7280;
        margin: 0;
    }

    /* spacer ให้ section ถัดไปไม่ทับ card */
    .hero-spacer { height: 90px; background: #FDE8E1; }

    /* ─── Section Title ───────────────────────────── */
    .section-title {
        color: #F97316;
        font-size: 2rem;
        font-weight: bold;
        margin: 3rem 0 2rem 0;
    }

    .view-all {
        color: #333;
        font-size: 1rem;
        text-decoration: none;
        transition: color 0.3s;
    }

    .view-all:hover { color: #F97316; }

    /* ─── Menu Cards ──────────────────────────────── */
    .menu-card {
        background: white;
        border-radius: 18px;
        padding: 1rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        transition: all 0.3s;
        margin-bottom: 1.5rem;
        border: 1px solid #F3F4F6;
    }

    .menu-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 30px rgba(249,115,22,0.15);
        border-color: #F97316;
    }

    .menu-image {
        width: 100%;
        height: 160px;
        background-color: #E5E7EB;
        border-radius: 12px;
        margin-bottom: 1rem;
        overflow: hidden;
    }

    .menu-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s;
    }

    .menu-card:hover .menu-image img { transform: scale(1.07); }

    .menu-title {
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 0.3rem;
    }

    .menu-price {
        color: #F97316;
        font-weight: bold;
        font-size: 1.1rem;
        margin-bottom: 0.8rem;
    }

    .btn-buy {
        width: 100%;
        background-color: #1a1a1a;
        color: white;
        padding: 0.65rem;
        border-radius: 10px;
        border: none;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-buy:hover {
        background-color: #F97316;
        transform: translateY(-1px);
    }

    .add-favorite {
        text-align: center;
        color: #9CA3AF;
        font-size: 0.85rem;
        margin-top: 0.5rem;
        cursor: pointer;
        transition: color 0.3s;
    }

    .add-favorite:hover { color: #F97316; }

    /* ─── Promotion Section ───────────────────────── */
    .promo-section-wrap {
        background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
        border-radius: 24px;
        padding: 3rem;
        margin: 2rem 0 3rem;
    }

    .promo-section-title {
        color: #F97316;
        font-size: 0.8rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
    }

    .promo-section-heading {
        color: #fff;
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 2rem;
    }

    .promo-section-wrap > .row {
        display: none;
    }

    .promo-card-new {
        border-radius: 16px;
        padding: 2rem;
        min-height: 180px;
        margin-bottom: 1.2rem;
        position: relative;
        overflow: hidden;
        transition: transform 0.3s;
    }

    .promo-card-new:hover { transform: translateY(-4px); }

    .promo-main {
        background: linear-gradient(135deg, #F97316 0%, #ea580c 100%);
        min-height: 240px;
    }

    .promo-badge {
        display: inline-block;
        background: rgba(255,255,255,0.2);
        color: #fff;
        font-size: 0.7rem;
        letter-spacing: 2px;
        padding: 4px 12px;
        border-radius: 20px;
        margin-bottom: 1rem;
    }

    .promo-main h2 {
        color: #fff;
        font-size: 2.5rem;
        font-weight: 900;
        margin-bottom: 0.5rem;
        line-height: 1;
    }

    .promo-main p { color: rgba(255,255,255,0.85); font-size: 0.95rem; }

    .coupon-box {
        background: rgba(255,255,255,0.15);
        border: 1.5px dashed rgba(255,255,255,0.5);
        color: #fff;
        padding: 0.6rem 1.5rem;
        border-radius: 10px;
        display: inline-block;
        font-weight: 800;
        font-size: 1.1rem;
        margin-top: 1rem;
        letter-spacing: 2px;
    }

    .promo-secondary {
        background: linear-gradient(135deg, #FFF8E7 0%, #FFE4B0 100%);
    }

    .promo-secondary h3 {
        color: #7C3A0E;
        font-size: 1.4rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
    }

    .promo-secondary p { color: #9a6040; font-size: 0.9rem; }

    .promo-dark {
        background: linear-gradient(135deg, #7C3A0E 0%, #4A1B0C 100%);
    }

    .promo-dark h3 { color: #F97316; font-size: 1.6rem; font-weight: 900; margin-bottom: 0.3rem; }
    .promo-dark p  { color: rgba(255,220,190,0.8); font-size: 0.9rem; }

    .home-promo-head {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1.25rem;
    }

    .home-promo-copy {
        margin: 0.35rem 0 0;
        color: #6B7280;
        line-height: 1.7;
    }

    .home-promo-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.2rem;
    }

    .home-promo-card {
        overflow: hidden;
        border-radius: 24px;
        background: #fff;
        border: 1px solid #F3E5DA;
        box-shadow: 0 16px 38px rgba(76, 42, 17, 0.08);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .home-promo-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 44px rgba(76, 42, 17, 0.12);
    }

    .home-promo-image {
        height: 220px;
        background: linear-gradient(135deg, #FFE7D6 0%, #FFF7F1 100%);
        overflow: hidden;
    }

    .home-promo-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .home-promo-body {
        padding: 1.25rem 1.25rem 1.35rem;
    }

    .home-promo-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.8rem;
        margin-bottom: 0.8rem;
    }

    .home-promo-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.4rem 0.78rem;
        border-radius: 999px;
        background: #FFF3E8;
        color: #C2410C;
        font-size: 0.75rem;
        font-weight: 800;
    }

    .home-promo-name {
        color: #1F2937;
        font-size: 1.08rem;
        font-weight: 900;
        line-height: 1.3;
        margin-bottom: 0.55rem;
    }

    .home-promo-desc {
        color: #6B7280;
        font-size: 0.92rem;
        line-height: 1.7;
        min-height: 4.7rem;
        margin-bottom: 1rem;
    }

    .home-promo-link {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        color: #F97316;
        font-size: 0.9rem;
        font-weight: 800;
        text-decoration: none;
    }

    .home-promo-link:hover {
        color: #EA580C;
    }

    .model-section {
        width: min(900px, calc(100% - 2rem));
        margin: 1.5rem auto 3rem;
    }

    .model-section-head {
        text-align: center;
        margin-bottom: 1.15rem;
    }

    .model-section-kicker {
        color: #F97316;
        font-size: 0.78rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        font-weight: 800;
        margin-bottom: 0.55rem;
    }

    .model-section-title {
        color: #1a1a1a;
        font-size: clamp(1.6rem, 3vw, 2.35rem);
        font-weight: 900;
        margin: 0 0 0.45rem;
    }

    .model-section-copy {
        color: #6B7280;
        line-height: 1.7;
        margin: 0 auto;
        max-width: 640px;
    }

    .sketchfab-embed-wrapper {
        position: relative;
        width: 100%;
        padding-bottom: 56.25%;
        height: 0;
        overflow: hidden;
        border-radius: 24px;
        box-shadow: 0 30px 80px rgba(0,0,0,0.18);
        border: 1px solid rgba(243, 229, 218, 0.9);
        background: linear-gradient(135deg, #fff7f1 0%, #ffe7d6 100%);
    }

    .sketchfab-embed-wrapper iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: 0;
        border-radius: 24px;
    }

    /* ─── Cake / Feature Section ──────────────────── */
    .highlight-section {
        background: white;
        border-radius: 24px;
        padding: 4rem 3rem;
        margin: 0 0 3rem;
        box-shadow: 0 4px 24px rgba(0,0,0,0.06);
    }

    .highlight-label {
        color: #F97316;
        font-size: 0.8rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 0.8rem;
        font-weight: 600;
    }

    .highlight-title {
        font-size: 2rem;
        font-weight: 800;
        color: #1a1a1a;
        line-height: 1.3;
        margin-bottom: 1.5rem;
    }

    .highlight-title span { color: #F97316; }

    .highlight-text {
        color: #6B7280;
        font-size: 1rem;
        line-height: 1.8;
        margin-bottom: 2rem;
    }

    .btn-highlight {
        background: #F97316;
        color: #fff;
        padding: 0.85rem 2.2rem;
        border-radius: 50px;
        border: none;
        font-weight: 700;
        font-size: 0.95rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s;
        box-shadow: 0 8px 24px rgba(249,115,22,0.35);
    }

    .btn-highlight:hover {
        background: #ea580c;
        transform: translateY(-3px);
        color: #fff;
    }

    .highlight-img {
        width: 100%;
        height: 380px;
        border-radius: 20px;
        object-fit: cover;
        box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    }

    /* ─── Responsive ──────────────────────────────── */
    @@media (max-width: 900px) {
        .features-card-inner {
            grid-template-columns: 1fr;
        }
        .feature-item-new { border-right: none; border-bottom: 1px solid #F3F4F6; }
        .feature-item-new:last-child { border-bottom: none; }
        .features-float { bottom: -220px; }
        .hero-spacer    { height: 260px; }
    }

    @@media (max-width: 768px) {
        main .container {
            width: calc(100% - 1.5rem);
        }

        .hero-banner-wrap { min-height: 520px; height: 100vh; }
        .hero-content { padding: 0 1.4rem; padding-bottom: 3.5rem; max-width: 100%; }
        .hero-title   { font-size: 1.95rem; }
        .hero-subtitle { font-size: 0.92rem; line-height: 1.55; max-width: 100%; margin: 0.9rem 0 1.35rem; }
        .hero-actions { gap: 0.75rem; }
        .btn-hero-primary, .btn-hero-secondary { width: 100%; justify-content: center; padding: 0.82rem 1rem; }
        .scroll-hint  { display: none; }
        .features-float { width: calc(100% - 2rem); }
        .features-card-inner { padding: 0.4rem 0; }
        .feature-item-new { padding: 0.8rem 0.25rem; }
        .promo-section-wrap { padding: 2rem 1.5rem; }
    }

    @@media (max-width: 480px) {
        .hero-banner-wrap { height: 100vh; min-height: 470px; max-height: none; margin-top: 0; }
        .hero-content { padding: 0 1rem; padding-bottom: 2.75rem; }
        .hero-title   { font-size: 1.7rem; line-height: 1.04; }
        .hero-subtitle { font-size: 0.88rem; }
        .hero-eyebrow { font-size: 0.62rem; letter-spacing: 2px; padding: 5px 12px; margin-bottom: 1rem; }
        .btn-hero-primary, .btn-hero-secondary { padding: 0.72rem 1rem; font-size: 0.84rem; }
        .features-float { bottom: -235px; left: 0.75rem; right: 0.75rem; width: auto; }
        .features-card-inner { border-radius: 16px; padding: 0.2rem 0.9rem; }
        .feature-item-new { gap: 0.75rem; }
        .feature-icon-box { width: 44px; height: 44px; font-size: 1.15rem; }
        .feature-title-new { font-size: 0.92rem; }
        .feature-text-new { font-size: 0.78rem; }
        .hero-spacer    { height: 270px; }
    }
    .home-extra-section {
        margin: 0 0 3rem;
    }

    .home-extra-grid {
        display: grid;
        grid-template-columns: 0.95fr 1.05fr;
        gap: 1.2rem;
    }

    .home-panel {
        background: #fff;
        border-radius: 24px;
        padding: 2rem;
        border: 1px solid #F3E5DA;
