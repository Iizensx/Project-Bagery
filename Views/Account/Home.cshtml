        align-items: center;
        gap: 0.8rem;
        color: #111827;
        font-weight: 800;
    }

    .app-phone-store-label i {
        color: #F97316;
        font-size: 1rem;
    }

    .app-phone-store-badge {
        color: #F97316;
        font-size: 0.8rem;
        font-weight: 900;
    }

    .faq-grid-home {
        grid-template-columns: repeat(2, minmax(0, 1fr));
