        gap: 0.9rem;
        margin-bottom: 1.2rem;
    }

    .social-platform-card {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        padding: 0.95rem 1rem;
        border-radius: 18px;
        background: rgba(255,255,255,0.54);
        border: 1px solid rgba(255,255,255,0.65);
        backdrop-filter: blur(14px);
    }

    .social-platform-icon {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #FFF3E8 0%, #FFE2CF 100%);
        color: #C2410C;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .social-platform-name {
        color: #111827;
        font-weight: 800;
        margin-bottom: 0.15rem;
    }

    .social-platform-handle {
        color: #6B7280;
        font-size: 0.88rem;
    }

