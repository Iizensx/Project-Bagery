@using System.Text.Json
@model _66022380.Models.DeliveryTrackingViewModel

@{
    ViewData["Title"] = "Delivery";
    Layout = "~/Views/Shared/_Layoutmain.cshtml";
}

<style>
    body {
        background: linear-gradient(180deg, #fde8e1 0%, #fff7f1 55%, #fffaf7 100%);
        padding-top: 0 !important;
    }

    .del-shell {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 1.25rem 4rem;
    }

    .del-hero {
        position: relative;
        overflow: hidden;
        margin-top: 0;
        min-height: 550px;
        padding: 0;
        background: url('/img/BanerDelivery.png') center/cover no-repeat;
        border-radius: 0;
    }

    .del-hero-grid {
        display: none;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        margin-bottom: 1rem;
        padding: 0.45rem 0.9rem;
        border: 1px solid rgba(255,185,128,0.35);
        border-radius: 999px;
        background: rgba(249,115,22,0.14);
        color: #ffd8b5;
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .hero-badge::before {
        content: "";
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #f97316;
        box-shadow: 0 0 12px rgba(249,115,22,0.6);
    }

    .hero-title {
        margin: 0 0 0.75rem;
        color: #fff;
        font-size: clamp(2.3rem, 5vw, 4rem);
        font-weight: 900;
        line-height: 0.96;
    }

    .hero-title span {
        color: #ff9a47;
        display: block;
    }

    .hero-sub {
        max-width: 640px;
        margin: 0;
        color: rgba(255,236,220,0.76);
        font-size: 1rem;
        line-height: 1.7;
    }

    .hero-side {
        padding: 1.25rem;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 22px;
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(14px);
        color: #fff6ef;
    }

    .hero-side-label {
        color: rgba(255,220,190,0.72);
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .hero-side-value {
        margin-top: 0.35rem;
        font-size: 1.35rem;
        font-weight: 900;
    }

    .hero-side-sub {
        margin-top: 0.4rem;
        color: rgba(255,236,220,0.72);
        font-size: 0.9rem;
        line-height: 1.6;
    }

    .tabs-wrap {
        position: relative;
        z-index: 2;
        margin-top: -34px;
    }

    .del-tabs {
        display: inline-flex;
        gap: 0.75rem;
        padding: 0.55rem;
        border: 1px solid rgba(249,115,22,0.12);
        border-radius: 20px;
        background: rgba(255,255,255,0.88);
        box-shadow: 0 18px 40px rgba(48,27,12,0.09);
        backdrop-filter: blur(14px);
    }

    .del-tab {
        padding: 0.82rem 1.15rem;
        border-radius: 14px;
        color: #6b4c3a;
        font-size: 0.92rem;
        font-weight: 800;
        text-decoration: none;
    }

    .del-tab.active {
        background: linear-gradient(135deg, #f97316, #fb923c);
        color: #fff;
        box-shadow: 0 10px 22px rgba(249,115,22,0.28);
    }

    .section-block {
        margin-top: 2rem;
    }

    .section-title {
        margin-bottom: 0.35rem;
        color: #f97316;
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .section-heading {
        margin: 0 0 1.4rem;
        color: #1f2937;
        font-size: clamp(1.55rem, 3vw, 2.3rem);
        font-weight: 900;
        line-height: 1.15;
    }

    .tracking-card {
        padding: 2rem;
        border: 1px solid #f7dccb;
        border-radius: 28px;
        background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(255,247,241,0.98));
        box-shadow: 0 24px 60px rgba(76,42,17,0.10);
    }

    .tracking-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: start;
        padding-bottom: 1.3rem;
        margin-bottom: 1.35rem;
        border-bottom: 1px solid #f4e3d8;
    }

    .track-label {
        color: #9ca3af;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .track-order-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.7rem;
        margin: 0.45rem 0 0.8rem;
    }

    .track-order-num {
        color: #111827;
        font-size: 1.65rem;
        font-weight: 900;
    }

    .track-pill {
        display: inline-flex;
        align-items: center;
        padding: 0.42rem 0.85rem;
        border-radius: 999px;
        background: #fff1e8;
        color: #c2410c;
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.2px;
    }

    .track-copy {
        max-width: 680px;
        color: #4b5563;
        font-size: 0.95rem;
        line-height: 1.75;
    }

    .track-state-box {
        min-width: 190px;
        padding: 1rem 1.1rem;
        border: 1px solid #fde3d1;
        border-radius: 18px;
        background: #fffaf6;
        text-align: right;
    }

    .track-state-value {
        margin-top: 0.28rem;
        color: #f97316;
        font-size: 1.25rem;
        font-weight: 900;
    }

    .steps-row {
        display: grid;
        grid-template-columns: 1fr 34px 1fr 34px 1fr 34px 1fr 34px 1fr;
        align-items: center;
        margin: 1.1rem 0 1.5rem;
    }

    .step-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.65rem;
        text-align: center;
    }

    .step-icon {
        width: 68px;
        height: 68px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 3px solid #e8e1db;
        border-radius: 50%;
        background: #f9fafb;
        color: #9ca3af;
        font-size: 1.05rem;
        font-weight: 900;
        transition: all .25s ease;
    }

    .step-icon.done {
        border-color: #f97316;
        background: #fff1e8;
        color: #ea580c;
    }

    .step-icon.active {
        border-color: #f97316;
        background: linear-gradient(135deg, #f97316, #fb923c);
        color: #fff;
        box-shadow: 0 0 0 8px rgba(249,115,22,0.14);
    }

    .step-name {
        color: #9ca3af;
        font-size: 0.84rem;
        font-weight: 800;
    }

    .step-name.active { color: #111827; }
    .step-name.done { color: #ea580c; }

    .step-sub {
        margin-top: -2px;
        color: #c4c9d4;
        font-size: 0.72rem;
        line-height: 1.45;
    }

    .step-sub.active { color: #6b7280; }

    .step-line {
        height: 5px;
        margin-bottom: 42px;
        border-radius: 999px;
        background: #ece8e4;
        overflow: hidden;
    }

    .step-line-fill {
        height: 100%;
        width: 0;
        border-radius: 999px;
        background: linear-gradient(90deg, #f97316, #fdba74);
    }

    .step-line-fill.on { width: 100%; }

    .tracking-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
    }

    .meta-card {
        padding: 1rem 1.05rem;
        border: 1px solid #f8dfcf;
        border-radius: 18px;
        background: #fffaf7;
    }

    .meta-label {
        margin-bottom: 0.35rem;
        color: #9ca3af;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .meta-value {
        color: #1f2937;
        font-size: 0.92rem;
        font-weight: 700;
        line-height: 1.6;
        word-break: break-word;
    }

    .action-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem;
        margin-top: 1.35rem;
    }

    .action-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.92rem 1.35rem;
        border: none;
        border-radius: 15px;
        font-size: 0.92rem;
        font-weight: 800;
        text-decoration: none;
        cursor: pointer;
        transition: transform .18s ease, box-shadow .18s ease;
    }

    .action-btn:hover {
        transform: translateY(-1px);
    }

    .action-btn.primary {
        background: linear-gradient(135deg, #f97316, #fb923c);
        color: #fff;
        box-shadow: 0 12px 24px rgba(249,115,22,0.28);
    }

    .action-btn.success {
        background: linear-gradient(135deg, #16a34a, #22c55e);
        color: #fff;
        box-shadow: 0 12px 24px rgba(34,197,94,0.22);
    }

    .action-btn.secondary {
        background: #fff;
        color: #7c2d12;
        border: 1px solid #f2c7ab;
    }

    .delivery-actions-panel {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 1rem;
        margin-top: 1.4rem;
    }

    .delivery-card {
        padding: 1.15rem 1.2rem;
        border-radius: 20px;
        border: 1px solid #f7dccb;
        background: #fffaf7;
    }

    .delivery-card strong {
        display: block;
        margin-bottom: 0.35rem;
        color: #111827;
        font-size: 1rem;
    }

    .delivery-card p {
        margin: 0;
        color: #6b7280;
        font-size: 0.9rem;
        line-height: 1.65;
    }

    .history-grid {
        display: grid;
        gap: 1rem;
    }

    .history-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .history-summary {
        color: #6b7280;
        font-size: 0.92rem;
        font-weight: 700;
    }

    .history-card {
        padding: 1.3rem 1.35rem;
        border: 1px solid #f7dccb;
        border-radius: 22px;
        background: rgba(255,255,255,0.95);
        box-shadow: 0 16px 38px rgba(60,30,8,0.06);
    }

    .history-card[hidden] {
        display: none !important;
    }

    .history-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: start;
        margin-bottom: 0.8rem;
    }

    .history-order-num {
        color: #111827;
        font-size: 1.08rem;
        font-weight: 900;
    }

    .history-time {
        color: #9ca3af;
        font-size: 0.82rem;
    }

    .history-pill-row {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        justify-content: end;
    }

    .history-pill {
        display: inline-flex;
        align-items: center;
        padding: 0.36rem 0.72rem;
        border-radius: 999px;
        font-size: 0.74rem;
        font-weight: 800;
    }

    .history-pill.status { background: #fff1e8; color: #c2410c; }
    .history-pill.payment { background: #eef8ff; color: #1d4ed8; }
    .history-pill.active { background: #ecfdf3; color: #15803d; }

    .history-body {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr 0.95fr;
        gap: 1rem;
    }

    .history-label {
        margin-bottom: 0.2rem;
        color: #9ca3af;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .history-value {
        color: #374151;
        font-size: 0.9rem;
        font-weight: 700;
        line-height: 1.65;
    }

    .history-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid #f4e3d8;
        flex-wrap: wrap;
    }

    .history-discount {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        align-items: center;
    }

    .history-discount .history-label {
        margin-bottom: 0;
    }

    .history-discount-chip {
        display: inline-flex;
        align-items: center;
        padding: 0.42rem 0.8rem;
        border-radius: 999px;
        background: #fff5eb;
        color: #c2410c;
        font-size: 0.78rem;
        font-weight: 800;
        border: 1px solid #fed7aa;
    }

    .history-discount-chip.muted {
        background: #f9fafb;
        color: #6b7280;
        border-color: #e5e7eb;
    }

    .history-nav {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 0.8rem;
        margin-top: 1.1rem;
        flex-wrap: wrap;
    }

    .history-page-indicator {
        color: #6b7280;
        font-size: 0.88rem;
        font-weight: 800;
    }

    .history-detail-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
    }

    .history-detail-card {
        padding: 1rem;
        border: 1px solid #f7dccb;
        border-radius: 18px;
        background: #fffaf7;
    }

    .history-items-list {
        display: grid;
        gap: .8rem;
    }

    .history-item-row {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
        padding: .9rem 1rem;
        border-radius: 16px;
        border: 1px solid #f4e3d8;
        background: #fff;
    }

    .history-item-main {
        display: grid;
        gap: .2rem;
    }

    .history-item-name {
        color: #111827;
        font-size: .94rem;
        font-weight: 900;
    }

    .history-item-meta {
        color: #6b7280;
        font-size: .84rem;
        font-weight: 700;
    }

    .history-item-price {
        color: #111827;
        font-size: .92rem;
        font-weight: 900;
        text-align: right;
        white-space: nowrap;
    }

    .history-item-price.reward {
        color: #ea580c;
    }

    .history-item-badge {
        display: inline-flex;
        width: fit-content;
        align-items: center;
        padding: .28rem .58rem;
        border-radius: 999px;
        background: #fff7ed;
        color: #c2410c;
        font-size: .72rem;
        font-weight: 900;
        border: 1px solid #fed7aa;
    }

    .history-detail-wide {
        grid-column: 1 / -1;
    }

    .empty-history {
        padding: 1.7rem;
        border: 1px dashed #f2c7ab;
        border-radius: 22px;
        background: rgba(255,255,255,0.7);
        color: #9ca3af;
        text-align: center;
        font-weight: 700;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
    }

    .info-card {
        padding: 1.45rem;
        border: 1px solid #f7dccb;
        border-radius: 22px;
        background: rgba(255,255,255,0.94);
    }

    .info-kicker {
        color: #f97316;
        font-size: 0.8rem;
        font-weight: 900;
    }

    .info-card h3 {
        margin: 0.6rem 0 0.45rem;
        color: #111827;
        font-size: 1rem;
        font-weight: 900;
    }

    .info-card p {
        margin: 0;
        color: #6b7280;
        font-size: 0.9rem;
        line-height: 1.7;
    }

    .no-order {
        padding: 2rem;
        border: 1px dashed #f2c7ab;
        border-radius: 24px;
        background: rgba(255,255,255,0.82);
        text-align: center;
    }

    .no-order-title {
        color: #6b7280;
        font-size: 1.1rem;
        font-weight: 900;
    }

    .no-order-copy {
        margin: 0.45rem auto 0;
        max-width: 580px;
        color: #9ca3af;
        font-size: 0.92rem;
        line-height: 1.75;
    }

    .modal-panel {
        border: none;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 24px 60px rgba(60,30,8,0.18);
    }

    .modal-header.custom {
        border-bottom: none;
        background: linear-gradient(135deg, #fff7f1, #fff);
        padding: 1.15rem 1.3rem 0.5rem;
    }

    .modal-body.custom {
        padding: 0.7rem 1.3rem 1.35rem;
    }

    .contact-help {
        display: grid;
        gap: 0.8rem;
        margin-top: 0.8rem;
    }

    .contact-help-item {
        padding: 0.95rem 1rem;
        border: 1px solid #f7dccb;
        border-radius: 16px;
        background: #fffaf7;
    }

    .contact-help-label {
        color: #9ca3af;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .contact-help-value {
        margin-top: 0.25rem;
        color: #111827;
        font-size: 1rem;
        font-weight: 900;
    }

    @@media (max-width: 980px) {
        .del-hero-grid,
        .delivery-actions-panel,
        .history-body,
        .tracking-grid,
        .info-grid {
            grid-template-columns: 1fr;
        }

        .tracking-header {
            grid-template-columns: 1fr;
        }

        .track-state-box {
            text-align: left;
        }

        .history-detail-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 760px) {
        .steps-row {
            grid-template-columns: 1fr 18px 1fr 18px 1fr 18px 1fr 18px 1fr;
        }

        .step-icon {
            width: 54px;
            height: 54px;
            font-size: 0.92rem;
        }

        .tracking-card,
        .history-card,
        .info-card {
            padding: 1.2rem;
        }

        .hero-side {
            display: none;
        }

        .del-tabs {
            display: grid;
            width: 100%;
        }

        .history-head {
            flex-direction: column;
        }

        .history-pill-row {
            justify-content: start;
        }

        .history-footer,
        .history-nav {
            justify-content: start;
        }
    }
</style>

@{
    string StepClass(int step)
    {
        if (Model.TrackingStage == step) return "active";
        return Model.TrackingStage > step ? "done" : "";
    }

    string FillClass(int step)
    {
        return Model.TrackingStage > step ? "on" : "";
    }

    var historyTotal = Model.OrderHistory.Count;
}

<section class="del-hero">
    <div class="del-shell">
        <div class="del-hero-grid">
            <div>
                <div class="hero-badge">Live Order Tracking</div>
                <h1 class="hero-title">BAGERY <span>Delivery</span></h1>
                <p class="hero-sub">ติดตามออเดอร์ล่าสุดของคุณจากฐานข้อมูลจริง, ปิดงานหลังรับสินค้า, และดูประวัติการสั่งซื้อย้อนหลังได้ในหน้าเดียว</p>
            </div>
            <div class="hero-side">
                <div class="hero-side-label">สถานะล่าสุด</div>
                <div class="hero-side-value">@(Model.HasOrder ? Model.StatusTitle : "ยังไม่มีออเดอร์ค้างอยู่")</div>
                <div class="hero-side-sub">เมื่อออเดอร์อยู่ในสถานะ “ระหว่างจัดส่ง” ระบบจะแสดงปุ่ม “ได้รับออเดอร์แล้ว” และ “แจ้งปัญหา” ให้ทันที</div>
            </div>
        </div>
    </div>
</section>

<div class="del-shell">
    <div class="tabs-wrap">
        <div class="del-tabs">
            <a class="del-tab active" href="#tracking-section">ติดตามออเดอร์</a>
            <a class="del-tab" href="#history-section">ประวัติการสั่งซื้อ</a>
        </div>
    </div>

    <section class="section-block" id="tracking-section">
        <div class="section-title">Tracking</div>
        <h2 class="section-heading">การ์ดติดตามออเดอร์ล่าสุด</h2>

        @if (Model.HasOrder)
        {
            <div class="tracking-card">
                <div class="tracking-header">
                    <div>
                        <div class="track-label">Current Order</div>
                        <div class="track-order-row">
                            <div class="track-order-num">#@Model.OrderNumber</div>
                            <div class="track-pill">@Model.StatusTitle</div>
                        </div>
                        <div class="track-copy">@Model.StatusMessage</div>
                    </div>
                    <div class="track-state-box">
                        <div class="track-label">Current State</div>
                        <div class="track-state-value">@Model.EtaText</div>
                    </div>
                </div>

                <div class="steps-row">
                    <div class="step-box">
                        <div class="step-icon @StepClass(1)">1</div>
                        <div class="step-name @StepClass(1)">Pending</div>
                        <div class="step-sub @(Model.TrackingStage == 1 ? "active" : "")">สร้างออเดอร์แล้ว</div>
                    </div>
                    <div class="step-line"><div class="step-line-fill @FillClass(1)"></div></div>
                    <div class="step-box">
                        <div class="step-icon @StepClass(2)">2</div>
                        <div class="step-name @StepClass(2)">Paid</div>
                        <div class="step-sub @(Model.TrackingStage == 2 ? "active" : "")">ยืนยันการชำระเงิน</div>
                    </div>
                    <div class="step-line"><div class="step-line-fill @FillClass(2)"></div></div>
                    <div class="step-box">
                        <div class="step-icon @StepClass(3)">3</div>
                        <div class="step-name @StepClass(3)">Preparing</div>
                        <div class="step-sub @(Model.TrackingStage == 3 ? "active" : "")">ร้านกำลังเตรียมสินค้า</div>
                    </div>
                    <div class="step-line"><div class="step-line-fill @FillClass(3)"></div></div>
                    <div class="step-box">
                        <div class="step-icon @StepClass(4)">4</div>
                        <div class="step-name @StepClass(4)">Shipped</div>
                        <div class="step-sub @(Model.TrackingStage == 4 ? "active" : "")">อยู่ระหว่างจัดส่ง</div>
                    </div>
                    <div class="step-line"><div class="step-line-fill @FillClass(4)"></div></div>
                    <div class="step-box">
                        <div class="step-icon @StepClass(5)">5</div>
                        <div class="step-name @StepClass(5)">Completed</div>
                        <div class="step-sub @(Model.TrackingStage == 5 ? "active" : "")">ปิดออเดอร์แล้ว</div>
                    </div>
                </div>

                <div class="tracking-grid">
                    <div class="meta-card">
                        <div class="meta-label">Payment Status</div>
                        <div class="meta-value">@Model.PaymentStatus</div>
                    </div>
                    <div class="meta-card">
                        <div class="meta-label">Created At</div>
                        <div class="meta-value">@Model.CreatedAtText</div>
                    </div>
                    <div class="meta-card">
                        <div class="meta-label">Order Items</div>
                        <div class="meta-value">@Model.ItemSummary</div>
                    </div>
                    <div class="meta-card">
                        <div class="meta-label">Delivery Address</div>
                        <div class="meta-value">@Model.DeliveryAddress</div>
                    </div>
                </div>

                <div class="action-row">
                    @if (Model.ShowPaymentAction)
                    {
                        <a class="action-btn primary" href="@Model.PaymentUrl">ไปหน้าชำระเงินและอัปโหลดสลิป</a>
                    }
                </div>

                @if (Model.ShowDeliveryActions)
                {
                    <div class="delivery-actions-panel">
                        <div class="delivery-card">
                            <strong>ออเดอร์นี้อยู่ระหว่างจัดส่งแล้ว</strong>
                            <p>เมื่อได้รับสินค้าเรียบร้อยแล้ว สามารถกด “ได้รับออเดอร์แล้ว” เพื่อสิ้นสุดขั้นตอนและย้ายรายการนี้ไปยังประวัติการสั่งซื้อได้ทันที</p>
                            <div class="action-row">
                                <button type="button" class="action-btn success" onclick="completeOrder(@Model.OrderId)">ได้รับออเดอร์แล้ว</button>
                                <button type="button" class="action-btn secondary" data-bs-toggle="modal" data-bs-target="#problemModal">แจ้งปัญหา</button>
                            </div>
                        </div>
                        <div class="delivery-card">
                            <strong>ต้องการความช่วยเหลือ?</strong>
                            <p>ถ้ามีสินค้าไม่ครบ, ได้รับของล่าช้า, หรือสินค้าเสียหาย สามารถกดแจ้งปัญหาเพื่อดูช่องทางติดต่อพนักงานได้ทันที</p>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-order">
                <div class="no-order-title">ตอนนี้ยังไม่มีออเดอร์ที่ต้องติดตาม</div>
                <div class="no-order-copy">หากคุณกด “ได้รับออเดอร์แล้ว” รายการจะถูกย้ายไปอยู่ในประวัติการสั่งซื้อด้านล่าง ส่วนออเดอร์ใหม่ที่สร้างขึ้นจะกลับมาแสดงในการ์ดติดตามอัตโนมัติ</div>
                <div class="action-row" style="justify-content:center;">
                    <a class="action-btn primary" asp-controller="Account" asp-action="Menu">ไปเลือกสินค้า</a>
                </div>
            </div>
        }
    </section>

    <section class="section-block" id="history-section">
        <div class="section-title">History</div>
        <h2 class="section-heading">ประวัติการสั่งซื้อ</h2>

        @if (Model.OrderHistory.Any())
        {
            <div class="history-toolbar">
                <div class="history-summary">แสดงประวัติย้อนหลังทั้งหมด @historyTotal รายการ โดยแสดงครั้งละ 4 รายการ</div>
            </div>
            <div class="history-grid">
                @for (var i = 0; i < Model.OrderHistory.Count; i++)
                {
                    var order = Model.OrderHistory[i];
                    <div class="history-card">
                        <div class="history-head">
                            <div>
                                <div class="history-order-num">#@order.OrderNumber</div>
                                <div class="history-time">@order.CreatedAtText</div>
                            </div>
                            <div class="history-pill-row">
                                <div class="history-pill status">@order.OrderStatus</div>
                                <div class="history-pill payment">@order.PaymentStatus</div>
                                @if (order.IsActive)
                                {
                                    <div class="history-pill active">กำลังติดตามอยู่</div>
                                }
                            </div>
                        </div>

                        <div class="history-body">
                            <div>
                                <div class="history-label">รายการสินค้า</div>
                                <div class="history-value">@order.ItemSummary</div>
                            </div>
                            <div>
                                <div class="history-label">ยอดรวม</div>
                                <div class="history-value">฿@order.TotalAmount.ToString("N2")</div>
                            </div>
                            <div>
                                <div class="history-label">ที่อยู่จัดส่ง</div>
                                <div class="history-value">@order.DeliveryAddress</div>
                            </div>
                        </div>

                        <div class="history-footer">
                            <div class="history-discount">
                                <div class="history-label">ส่วนลดที่ใช้</div>
                                <div class="history-discount-chip @(order.DiscountDisplay == "-" ? "muted" : "")">
                                    @(order.DiscountDisplay == "-" ? "ไม่มีส่วนลด" : $"{order.PromotionName} · {order.DiscountDisplay}")
                                </div>
                            </div>
                            <button type="button"
                                    class="action-btn secondary history-detail-btn"
                                    data-bs-toggle="modal"
                                    data-bs-target="#historyDetailModal"
                                    data-order-number="@order.OrderNumber"
                                    data-order-date="@order.CreatedAtText"
                                    data-order-status="@order.OrderStatus"
                                    data-payment-status="@order.PaymentStatus"
                                    data-total-amount="@order.TotalAmount.ToString("N2")"
                                    data-item-summary="@order.ItemSummary"
                                    data-items-json="@JsonSerializer.Serialize(order.Items)"
                                    data-delivery-address="@order.DeliveryAddress"
                                    data-promotion-name="@order.PromotionName"
                                    data-discount-display="@order.DiscountDisplay">
                                ดูรายละเอียด
                            </button>
                        </div>
                    </div>
                }
            </div>

            @if (historyTotal > 4)
            {
                <div class="history-nav">
                    <button type="button" class="action-btn secondary" id="historyPrevBtn">ย้อนกลับ</button>
                    <div class="history-page-indicator" id="historyPageIndicator">หน้า 1 / 1</div>
                    <button type="button" class="action-btn primary" id="historyNextBtn">หน้าถัดไป</button>
                </div>
            }
        }
        else
        {
            <div class="empty-history">ยังไม่มีประวัติการสั่งซื้อ</div>
        }
    </section>

    @* <section class="section-block">
        <div class="section-title">Suggestions</div>
        <h2 class="section-heading">แนะนำให้เก็บอะไรในประวัติการสั่งซื้อบ้าง</h2>

        <div class="info-grid">
            <div class="info-card">
                <div class="info-kicker">01</div>
                <h3>เก็บ Snapshot ของรายการสินค้า</h3>
                <p>ตอนนี้ระบบมี `Orderdetail` อยู่แล้ว ถือว่าดีมาก เพราะช่วยให้ประวัติย้อนหลังไม่เปลี่ยนตามราคาหรือชื่อสินค้าปัจจุบัน</p>
