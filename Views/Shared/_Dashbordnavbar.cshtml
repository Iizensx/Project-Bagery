        </li>


        <li class="navbar-item">
            <a class="navbar-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "PromotionAdmin" ? "active" : "")" asp-controller="AdminPromotion" asp-action="PromotionAdmin">
                <i class="fas fa-gift"></i>
                <span>จัดการโปรโมชั่น</span>
            </a>
        </li>

        <li class="navbar-item">
