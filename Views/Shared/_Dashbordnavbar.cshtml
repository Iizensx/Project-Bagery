<!-- Dashboard Sidebar Navigation -->
<style>
    .dashboard-navbar {
        width: 280px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 0;
        position: fixed;
        height: 100vh;
        left: 0;
        top: 0;
        overflow-y: auto;
        box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);
        z-index: 1000;
    }

    .navbar-header {
        padding: 30px 20px;
        text-align: center;
        border-bottom: 2px solid rgba(255, 255, 255, 0.2);
    }

    .navbar-logo {
        font-size: 28px;
        font-weight: 700;
        letter-spacing: 2px;
        margin: 0;
        color: white;
    }

    .navbar-menu {
        list-style: none;
        padding: 20px 0;
        margin: 0;
    }

    .navbar-item {
        margin: 10px 10px;
        border-radius: 8px;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .navbar-item:hover {
        background-color: rgba(255, 255, 255, 0.15);
    }

    .navbar-link {
        display: flex;
        align-items: center;
        padding: 15px 20px;
        color: white;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.3s ease;
        cursor: pointer;
        border: none;
        background: none;
        width: 100%;
        text-align: left;
    }

    .navbar-link i {
        font-size: 18px;
        margin-right: 15px;
        min-width: 20px;
        text-align: center;
    }

    .navbar-link:hover {
        color: #ffd700;
        transform: translateX(5px);
    }

    .navbar-link.active {
        background-color: rgba(255, 255, 255, 0.25);
        border-left: 4px solid #ffd700;
        padding-left: 16px;
        color: #ffd700;
    }

    .navbar-footer {
        position: absolute;
        bottom: 0;
        width: 100%;
        padding: 20px 10px;
        border-top: 2px solid rgba(255, 255, 255, 0.2);
    }

    .navbar-link.logout {
        margin: 0;
        border-radius: 8px;
        justify-content: center;
        background-color: rgba(255, 255, 255, 0.1);
    }

    .navbar-link.logout:hover {
        background-color: #ff6b6b;
        color: white;
    }

    .dashboard-navbar::-webkit-scrollbar {
        width: 8px;
    }

    .dashboard-navbar::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.1);
    }

    .dashboard-navbar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.3);
        border-radius: 4px;
    }

    .dashboard-navbar::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.5);
    }
</style>

