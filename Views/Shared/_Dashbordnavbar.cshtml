            <span>กลับหน้าหลัก</span>
        </a>
    </div>
</nav>

<script>
    function loadPage(event, page) {
        event.preventDefault();
        
        // Remove active class from all links
        const links = document.querySelectorAll('.navbar-link');
        links.forEach(link => link.classList.remove('active'));

        // Add active class to clicked link
        event.target.closest('.navbar-link').classList.add('active');

        // Load content based on page
        const contentDiv = document.getElementById('content');
        
        switch(page) {
            case 'product':
                contentDiv.innerHTML = getProductPage();
                break;
            case 'order':
                contentDiv.innerHTML = getOrderPage();
                break;
            case 'user':
                contentDiv.innerHTML = getUserPage();
                break;
            case 'report':
                contentDiv.innerHTML = getReportPage();
                break;
            case 'settings':
                contentDiv.innerHTML = getSettingsPage();
                break;
        }
    }

