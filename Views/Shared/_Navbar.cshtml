<script>
    const notificationApi = {
        listUrl: '@Url.Action("GetMyNotifications", "Notification")',
        markReadUrl: '@Url.Action("MarkAsRead", "Notification")',
        markAllReadUrl: '@Url.Action("MarkAllAsRead", "Notification")',
        clearUrl: '@Url.Action("ClearMyNotifications", "Notification")'
    };
    window.baileyNotifications = [];

    function checkLoginStatus() {
        const userData = localStorage.getItem('user');
        const loginContainer = document.getElementById('login-link-container');
        const userDropdownContainer = document.getElementById('user-dropdown-container');
        const displayUsername = document.getElementById('display-username');
        const notificationContainer = document.getElementById('notification-container');

        if (!loginContainer || !userDropdownContainer || !displayUsername || !notificationContainer) return;

        if (userData) {
            try {
                const user = JSON.parse(userData);
                if (user && user.username) {
                    displayUsername.innerText = user.username;
                    loginContainer.style.display = 'none';
                    userDropdownContainer.style.display = 'block';
                    notificationContainer.style.display = 'block';
                    refreshNotifications();
                }
            } catch (e) {
                console.error('Error parsing user data', e);
            }
        } else {
            notificationContainer.style.display = 'none';
        }
    }

    function getNotificationStorageKey(user) {
        const identity = (user && (user.username || user.email || user.phone)) || 'guest';
        return `bailey_notifications_${identity}`;
    }

    function getSeedNotifications() {
        return [
            {
                id: 'notif-order-created',
                type: 'order',
                title: 'สร้างออเดอร์สำเร็จ',
                message: 'ออเดอร์ล่าสุดของคุณถูกสร้างแล้ว สามารถไปต่อที่หน้าชำระเงินได้ทันที',
                timeText: '2 นาทีที่แล้ว',
                href: '/Order/Checkout',
                isRead: false
            },
            {
                id: 'notif-payment-verify',
                type: 'payment',
                title: 'กำลังรอตรวจสอบสลิป',
                message: 'ทีมร้านได้รับหลักฐานการชำระเงินแล้ว และจะอัปเดตสถานะให้ทันทีเมื่อยืนยันเสร็จ',
                timeText: '10 นาทีที่แล้ว',
                href: '/Delivery/Delivery#tracking-section',
                isRead: false
            },
            {
                id: 'notif-promo-approved',
                type: 'promotion',
                title: 'คุณได้รับโปรโมชั่นใหม่',
                message: 'BaileyBakery อนุมัติสิทธิ์โปรโมชั่นของคุณแล้ว ลองเข้าไปดูที่หน้า Promotion ได้เลย',
                timeText: '1 ชั่วโมงที่แล้ว',
                href: '/Home/Promotion',
                isRead: true
            },
            {
                id: 'notif-order-shipped',
                type: 'delivery',
                title: 'ออเดอร์กำลังจัดส่ง',
                message: 'คนขับกำลังนำขนมไปส่งให้คุณ สามารถติดตามสถานะล่าสุดได้จากหน้า Delivery',
                timeText: 'เมื่อวาน',
                href: '/Delivery/Delivery#tracking-section',
                isRead: true
            }
        ];
    }

    function loadNotifications(user) {
        if (!user) return [];
        return Array.isArray(window.baileyNotifications) ? window.baileyNotifications : [];
    }

    function saveNotifications(user, items) {
        if (!user) return;

        const previousItems = loadNotifications(user);
        window.baileyNotifications = Array.isArray(items) ? items : [];
        persistNotificationChanges(previousItems, window.baileyNotifications);
    }

    function seedNotifications(user) {
        return;
    }

    function notificationIconClass(type) {
        switch (type) {
            case 'promotion':
                return 'bi bi-gift';
            case 'payment':
                return 'bi bi-credit-card';
            case 'delivery':
                return 'bi bi-truck';
            default:
                return 'bi bi-bag-check';
        }
    }

    function renderNotifications(user) {
        const list = document.getElementById('notification-list');
        const empty = document.getElementById('notification-empty');
        const badge = document.getElementById('notification-badge');
        if (!list || !empty || !badge) return;

        const items = loadNotifications(user);
        const unreadCount = items.filter(item => !item.isRead).length;
        list.innerHTML = '';

        empty.style.display = items.length ? 'none' : 'block';

        items.forEach(function (item) {
            const li = document.createElement('li');
            li.innerHTML = `
                <a class="notification-item ${item.isRead ? '' : 'unread'}" href="${item.href || '#'}" data-id="${item.id}">
                    <div class="notification-icon ${item.type || 'order'}">
                        <i class="${notificationIconClass(item.type)}"></i>
                    </div>
                    <div>
                        <div class="notification-item-title">
                            <span>${item.title || 'Notification'}</span>
                            ${item.isRead ? '' : '<span class="notification-item-dot"></span>'}
                        </div>
                        <div class="notification-item-copy">${item.message || ''}</div>
                        <div class="notification-item-time">${item.timeText || ''}</div>
                    </div>
                </a>
            `;
            list.appendChild(li);
        });

        if (unreadCount > 0) {
            badge.style.display = 'inline-flex';
            badge.textContent = unreadCount > 9 ? '9+' : unreadCount;
        } else {
            badge.style.display = 'none';
        }
    }

    function getCurrentUser() {
        const userData = localStorage.getItem('user');
        if (!userData) return null;

        try {
            return JSON.parse(userData);
        } catch (error) {
            return null;
        }
    }

    function formatNotificationTime(value) {
        if (!value) return '';

        const createdAt = new Date(value);
        const diffMs = Date.now() - createdAt.getTime();
        const diffMinutes = Math.max(0, Math.floor(diffMs / 60000));

        if (diffMinutes < 1) return 'Just now';
        if (diffMinutes < 60) return `${diffMinutes} min ago`;

        const diffHours = Math.floor(diffMinutes / 60);
        if (diffHours < 24) return `${diffHours} hr ago`;

        const diffDays = Math.floor(diffHours / 24);
        if (diffDays < 7) return `${diffDays} day ago`;

        return createdAt.toLocaleString();
    }

    async function fetchNotifications() {
        try {
            const response = await fetch(notificationApi.listUrl, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            if (!response.ok) return [];

            const data = await response.json();
            if (!Array.isArray(data.notifications)) return [];

            return data.notifications.map(function (item) {
                return {
                    ...item,
                    timeText: formatNotificationTime(item.createdAt)
                };
            });
        } catch (error) {
            console.error('Error loading notifications', error);
            return [];
        }
    }

    async function refreshNotifications() {
        const user = getCurrentUser();
        if (!user) return;

        window.baileyNotifications = await fetchNotifications();
        renderNotifications(user);
    }

    function persistNotificationChanges(previousItems, nextItems) {
        const prev = Array.isArray(previousItems) ? previousItems : [];
        const next = Array.isArray(nextItems) ? nextItems : [];

        if (next.length === 0 && prev.length > 0) {
            fetch(notificationApi.clearUrl, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            }).catch(function (error) {
                console.error('Error clearing notifications', error);
            });
            return;
        }

        const unreadBefore = prev.filter(item => !item.isRead);
        const unreadAfter = next.filter(item => !item.isRead);

        if (unreadBefore.length > 0 && unreadAfter.length === 0) {
            fetch(notificationApi.markAllReadUrl, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            }).catch(function (error) {
                console.error('Error marking all notifications as read', error);
            });
            return;
        }

        const changedToRead = next.find(function (item) {
            const oldItem = prev.find(prevItem => prevItem.id === item.id);
            return oldItem && !oldItem.isRead && item.isRead;
        });

        if (changedToRead) {
            fetch(`${notificationApi.markReadUrl}?id=${encodeURIComponent(changedToRead.id)}`, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            }).catch(function (error) {
                console.error('Error marking notification as read', error);
            });
        }
    }

    checkLoginStatus();
    document.addEventListener('DOMContentLoaded', checkLoginStatus);

    document.addEventListener('click', async function (event) {
        const notificationLink = event.target.closest('.notification-item');
        if (!notificationLink) return;

        const user = getCurrentUser();
        if (!user) return;

        event.preventDefault();

        const items = loadNotifications(user).map(function (item) {
            if (item.id === notificationLink.dataset.id) {
                return { ...item, isRead: true };
            }
            return item;
        });

        saveNotifications(user, items);
        renderNotifications(user);

        const targetUrl = notificationLink.getAttribute('href');
        await refreshNotifications();
        if (targetUrl && targetUrl !== '#')
            window.location.href = targetUrl;
    });

    document.getElementById('markAllNotificationsRead')?.addEventListener('click', async function () {
        const user = getCurrentUser();
        if (!user) return;

        const items = loadNotifications(user).map(function (item) {
            return { ...item, isRead: true };
        });

        saveNotifications(user, items);
        renderNotifications(user);
        await refreshNotifications();
    });

    document.getElementById('clearNotificationsBtn')?.addEventListener('click', async function () {
        const user = getCurrentUser();
        if (!user) return;

        saveNotifications(user, []);
        renderNotifications(user);
        await refreshNotifications();
    });

    function logout() {
        localStorage.removeItem('user');
        window.baileyNotifications = [];
        window.location.href = '@Url.Action("Logout", "Account")';
    }
</script>
