@{
    ViewBag.Title = "จัดการสินค้า & สต๊อก";
    ViewBag.PageTitle = "จัดการสินค้า & สต๊อก";
    Layout = "_AdminLayout";
}

<div class="dashboard-card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h3 class="dashboard-card-title" style="margin: 0;">
            <i class="fas fa-box"></i> รายการสินค้าทั้งหมด
        </h3>
        <button class="btn btn-dashboard primary" onclick="alert('เพิ่มสินค้าใหม่')">
            <i class="fas fa-plus"></i> เพิ่มสินค้า
        </button>
    </div>

    <div style="margin-bottom: 20px;">
        <input type="text" class="form-control" placeholder="🔍 ค้นหาสินค้า..." />
    </div>

    <table class="table table-hover">
        <thead>
            <tr>
                <th>รหัสสินค้า</th>
                <th>ชื่อสินค้า</th>
                <th>ราคา</th>
                <th>สต๊อก</th>
                <th>สถานะ</th>
                <th>การกระทำ</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>PRD-001</td>
                <td>เค้กช็อกโกแลต</td>
                <td>฿299</td>
                <td><span class="badge bg-danger">0</span></td>
                <td><span class="badge bg-warning">หมดสต๊อก</span></td>
                <td>
                    <button class="btn btn-sm btn-dashboard primary" onclick="alert('แก้ไข')">แก้ไข</button>
                    <button class="btn btn-sm btn-dashboard danger" onclick="alert('ลบ')">ลบ</button>
                </td>
            </tr>
            <tr>
                <td>PRD-002</td>
                <td>ครัวซองต์เนยสด</td>
                <td>฿45</td>
                <td><span class="badge bg-success">45</span></td>
                <td><span class="badge bg-success">มีจำหน่าย</span></td>
                <td>
                    <button class="btn btn-sm btn-dashboard primary" onclick="alert('แก้ไข')">แก้ไข</button>
                    <button class="btn btn-sm btn-dashboard danger" onclick="alert('ลบ')">ลบ</button>
                </td>
            </tr>
            <tr>
                <td>PRD-003</td>
                <td>ขนมปังกระเทียม</td>
                <td>฿65</td>
                <td><span class="badge bg-warning">8</span></td>
                <td><span class="badge bg-info">ใกล้หมด</span></td>
                <td>
                    <button class="btn btn-sm btn-dashboard primary" onclick="alert('แก้ไข')">แก้ไข</button>
                    <button class="btn btn-sm btn-dashboard danger" onclick="alert('ลบ')">ลบ</button>
                </td>
            </tr>
        </tbody>
    </table>
</div>
