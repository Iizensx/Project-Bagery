@* ─── Modal เพิ่มหมวดหมู่ ─── *@
<div id="modal-addcat" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%;
     background:rgba(0,0,0,0.45); z-index:9999; justify-content:center; align-items:center;">
    <div style="background:#fff; border-radius:14px; padding:32px; width:400px; max-width:90%; box-shadow:0 8px 32px rgba(0,0,0,0.18);">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
            <h5 style="margin:0; font-weight:600;"><i class="fas fa-plus-circle"></i> เพิ่มหมวดหมู่ใหม่</h5>
            <button onclick="closeAddCategoryModal()" style="background:none;border:none;font-size:22px;cursor:pointer;color:#888;">&times;</button>
        </div>
        <div style="margin-bottom:14px;">
            <label style="font-size:13px; font-weight:600; margin-bottom:6px; display:block;">ชื่อหมวดหมู่</label>
            <input type="text" id="new-cat-name" class="form-control" placeholder="เช่น ของหวาน, ไอศกรีม..." />
        </div>
        <div style="margin-bottom:20px;">
            <label style="font-size:13px; font-weight:600; margin-bottom:6px; display:block;">ไอคอน (Emoji)</label>
            <input type="text" id="new-cat-icon" class="form-control" placeholder="เช่น 🍩" maxlength="4" />
        </div>
        <div style="display:flex; gap:10px; justify-content:flex-end;">
            <button class="btn btn-secondary btn-sm" onclick="closeAddCategoryModal()">ยกเลิก</button>
            <button class="btn btn-dashboard primary btn-sm" onclick="addCategory()">บันทึก</button>
        </div>
    </div>
</div>

<style>
    .cat-card {
        background: #fff;
        border: 1.5px solid #ececec;
        border-radius: 14px;
        padding: 28px 16px 20px;
        text-align: center;
        cursor: pointer;
        transition: all 0.18s ease;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
    .cat-card:hover {
        border-color: #4e54c8;
        box-shadow: 0 6px 20px rgba(78,84,200,0.15);
        transform: translateY(-3px);
    }
    .cat-icon { font-size: 40px; margin-bottom: 10px; }
    .cat-name { font-size: 16px; font-weight: 600; color: #333; margin-bottom: 4px; }
    .cat-count { font-size: 12px; color: #999; }

    .summary-card {
        background: #fff;
        border-radius: 10px;
        padding: 16px 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .summary-num { font-size: 28px; font-weight: 700; }
    .summary-label { font-size: 12px; color: #888; margin-top: 2px; }
</style>

<script>
    const productData = {
        'เค้ก': [
            { id:'PRD-001', name:'เค้กช็อกโกแลต', price:'฿299', stock:0,  status:'หมดสต๊อก', badgeClass:'bg-warning text-dark', stockClass:'bg-danger' },
            { id:'PRD-002', name:'เค้กวานิลลา',    price:'฿320', stock:15, status:'มีจำหน่าย', badgeClass:'bg-success',             stockClass:'bg-success' },
            { id:'PRD-008', name:'เค้กมะม่วง',     price:'฿350', stock:10, status:'มีจำหน่าย', badgeClass:'bg-success',             stockClass:'bg-success' },
        ],
        'คุกกี้': [
            { id:'PRD-003', name:'คุกกี้เนย',            price:'฿120', stock:50, status:'มีจำหน่าย', badgeClass:'bg-success', stockClass:'bg-success' },
            { id:'PRD-009', name:'คุกกี้ช็อกโกแลตชิพ',  price:'฿150', stock:45, status:'มีจำหน่าย', badgeClass:'bg-success', stockClass:'bg-success' },
        ],
        'ขนมปัง': [
            { id:'PRD-004', name:'ขนมปังกระเทียม', price:'฿65', stock:8,  status:'ใกล้หมด',   badgeClass:'bg-info',              stockClass:'bg-warning text-dark' },
            { id:'PRD-005', name:'ขนมปังโฮลวีต',   price:'฿85', stock:5,  status:'ใกล้หมด',   badgeClass:'bg-info',              stockClass:'bg-warning text-dark' },
        ],
        'เครื่องดื่ม': [
            { id:'PRD-006', name:'ชาเย็น',    price:'฿60', stock:100, status:'มีจำหน่าย', badgeClass:'bg-success', stockClass:'bg-success' },
            { id:'PRD-007', name:'กาแฟลาเต้', price:'฿80', stock:100, status:'มีจำหน่าย', badgeClass:'bg-success', stockClass:'bg-success' },
        ],
    };

    function showView(view, catName, catIcon) {
        document.getElementById('view-category').style.display = 'none';
        document.getElementById('view-products').style.display  = 'none';
        document.getElementById('view-overview').style.display  = 'none';

        if (view === 'category') {
            document.getElementById('view-category').style.display = 'block';
        } else if (view === 'products') {
            document.getElementById('cat-icon-title').textContent = catIcon + ' ';
            document.getElementById('cat-name-title').textContent = catName;
            const tbody = document.getElementById('product-tbody');
            const items = productData[catName] || [];
            tbody.innerHTML = items.map(p => `
                <tr>
                    <td>${p.id}</td>
                    <td>${p.name}</td>
                    <td>${p.price}</td>
                    <td><span class="badge ${p.stockClass}">${p.stock}</span></td>
                    <td><span class="badge ${p.badgeClass}">${p.status}</span></td>
                    <td>
                        <button class="btn btn-sm btn-dashboard primary" onclick="alert('แก้ไข ${p.name}')">แก้ไข</button>
                        <button class="btn btn-sm btn-dashboard danger"  onclick="alert('ลบ ${p.name}')">ลบ</button>
                    </td>
                </tr>
            `).join('');
            document.getElementById('view-products').style.display = 'block';
        } else if (view === 'overview') {
            document.getElementById('view-overview').style.display = 'block';
        }
    }

    function openAddCategoryModal() {
        document.getElementById('modal-addcat').style.display = 'flex';
    }
    function closeAddCategoryModal() {
        document.getElementById('modal-addcat').style.display = 'none';
    }
    function addCategory() {
        const name = document.getElementById('new-cat-name').value.trim();
        const icon = document.getElementById('new-cat-icon').value.trim() || '📦';
        if (!name) { alert('กรุณากรอกชื่อหมวดหมู่'); return; }
        const grid = document.getElementById('category-grid');
        const card = document.createElement('div');
        card.className = 'cat-card';
        card.innerHTML = `<div class="cat-icon">${icon}</div><div class="cat-name">${name}</div><div class="cat-count">0 รายการ</div>`;
        card.onclick = () => showView('products', name, icon);
        grid.appendChild(card);
        productData[name] = [];
        closeAddCategoryModal();
        document.getElementById('new-cat-name').value = '';
        document.getElementById('new-cat-icon').value = '';
    }
    document.getElementById('modal-addcat').addEventListener('click', function(e) {
        if (e.target === this) closeAddCategoryModal();
    });
</script>
