@using _66022380.Models
@using _66022380.Models.Db
@using Microsoft.AspNetCore.Http
@model AdminStockViewModel

@{
    ViewBag.Title = "จัดการสินค้าและสต๊อก";
    ViewBag.PageTitle = "จัดการสินค้าและสต๊อก";
    Layout = "_AdminLayout";

    var isStaff = string.Equals(Context.Session.GetString("RoleName"), "Staff", StringComparison.OrdinalIgnoreCase);
    var totalProducts = Model.Products.Count;
    var outOfStock = Model.Products.Count(p => (p.Stock1 ?? 0) <= 0);
    var lowStock = Model.Products.Count(p => (p.Stock1 ?? 0) > 0 && (p.Stock1 ?? 0) <= 10);
    var pausedProducts = Model.Products.Count(p => !p.IsAvailable);
    var limitedProducts = Model.Products.Count(p => p.IsLimitedQuantity);

    string GetStockStatus(int stock) => stock <= 0 ? "หมดสต๊อก" : stock <= 10 ? "ใกล้หมด" : "พร้อมขาย";
    string GetStockClass(int stock) => stock <= 0 ? "danger" : stock <= 10 ? "warning" : "success";
}

<style>
    .stock-shell { display: grid; gap: 1.25rem; }
    .stock-card { background: #fff; border: 1px solid #e5edf5; border-radius: 24px; padding: 1.5rem; box-shadow: 0 18px 40px rgba(15,23,42,.06); }
    .stock-header, .toolbar, .toolbar-left, .toolbar-right, .staff-meta { display: flex; gap: .85rem; flex-wrap: wrap; align-items: center; }
    .stock-header, .toolbar { justify-content: space-between; }
    .stock-title { margin: 0; font-size: 1.3rem; font-weight: 900; color: #0f172a; }
    .stock-copy, .helper-text, .list-status, .product-desc { color: #64748b; line-height: 1.6; }
    .stock-btn { border: none; border-radius: 14px; padding: .8rem 1rem; font-weight: 800; cursor: pointer; text-decoration: none; }
    .stock-btn.primary { background: #f97316; color: #fff; }
    .stock-btn.secondary { background: #eff6ff; color: #1d4ed8; }
    .stock-btn.ghost { background: #fff; color: #475569; border: 1px solid #dbe3ee; }
    .stock-alert { padding: .95rem 1rem; border-radius: 14px; font-weight: 700; margin-top: 1rem; }
    .stock-alert.success { background: #ecfdf3; color: #166534; border: 1px solid #bbf7d0; }
    .stock-alert.error { background: #fff1f2; color: #be123c; border: 1px solid #fecdd3; }
    .stock-note { margin-top: 1rem; padding: 1rem; border-radius: 14px; background: #fff7ed; color: #9a3412; border: 1px solid #fed7aa; }
    .summary-grid { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 1rem; margin-top: 1rem; }
    .summary-card, .category-card, .staff-preview { border: 1px solid #e5edf5; border-radius: 18px; padding: 1rem; background: #f8fafc; }
    .summary-label { color: #64748b; font-size: .78rem; font-weight: 800; text-transform: uppercase; }
    .summary-value { margin-top: .4rem; font-size: 1.9rem; font-weight: 900; color: #0f172a; }
    .summary-sub { margin-top: .25rem; color: #94a3b8; font-size: .9rem; }
    .category-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
    .stock-search, .stock-select, .stock-input, .stock-textarea { width: 100%; border: 1px solid #dbe3ee; border-radius: 14px; padding: .8rem .95rem; }
    .stock-search, .stock-select { min-width: 220px; }
    .stock-table-wrap { overflow-x: auto; margin-top: 1rem; }
    .stock-table { width: 100%; border-collapse: separate; border-spacing: 0 .75rem; }
    .stock-table th { padding: 0 .6rem .3rem; font-size: .78rem; text-transform: uppercase; color: #64748b; }
    .stock-row { background: #f8fafc; box-shadow: inset 0 0 0 1px #e2e8f0; }
    .stock-row td { padding: .95rem .6rem; vertical-align: middle; }
    .stock-row td:first-child { border-top-left-radius: 16px; border-bottom-left-radius: 16px; }
    .stock-row td:last-child { border-top-right-radius: 16px; border-bottom-right-radius: 16px; }
    .stock-chip, .user-id-badge { display: inline-flex; align-items: center; padding: .38rem .72rem; border-radius: 999px; font-size: .78rem; font-weight: 800; }
    .user-id-badge, .chip-neutral { background: #e2e8f0; color: #475569; }
    .chip-success { background: #ecfdf3; color: #15803d; }
    .chip-warning { background: #fff7ed; color: #c2410c; }
    .chip-danger { background: #fff1f2; color: #be123c; }
    .product-cell { display: flex; gap: .85rem; align-items: center; min-width: 260px; }
    .product-thumb { width: 60px; height: 60px; border-radius: 16px; object-fit: cover; background: #fff7ed; flex-shrink: 0; }
    .product-name { font-weight: 900; color: #0f172a; }
    .form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .9rem; }
    .full { grid-column: 1 / -1; }
    .field-label { display: block; margin-bottom: .35rem; font-size: .78rem; font-weight: 800; color: #475569; text-transform: uppercase; }
    .toggle-box { display: flex; align-items: center; gap: .7rem; padding: .9rem 1rem; border: 1px solid #dbe3ee; border-radius: 16px; background: #fffaf5; }
    .toggle-box input[type="checkbox"] { width: 18px; height: 18px; accent-color: #f97316; }
    .image-picker { display: grid; grid-template-columns: 120px 1fr; gap: 1rem; align-items: center; }
    .image-preview { width: 120px; height: 120px; border-radius: 18px; overflow: hidden; border: 1px dashed #fdba74; background: #fff7ed; }
    .image-preview img { width: 100%; height: 100%; object-fit: cover; }
    .modal-panel { border: none; border-radius: 24px; overflow: hidden; }
    .modal-header.custom { border-bottom: none; background: #fff7ed; }
    .empty-state { padding: 2rem; border: 1px dashed #cbd5e1; border-radius: 18px; text-align: center; color: #64748b; }
    @@media (max-width: 900px) { .summary-grid, .form-grid, .image-picker { grid-template-columns: 1fr; } .full { grid-column: auto; } }
</style>

<div class="stock-shell">
    <div class="stock-card">
        <div class="stock-header">
            <div>
                <h2 class="stock-title">จัดการสินค้าและสต๊อก</h2>
                <p class="stock-copy">@(isStaff ? "พนักงานสามารถดูสินค้า ปรับจำนวนสต๊อก เปิดขายหรือปิดขาย และกำหนดว่าสินค้าเป็นสินค้ามีจำนวนจำกัดได้" : "แอดมินสามารถเพิ่มหมวดหมู่ เพิ่มสินค้า แก้ไขข้อมูลสินค้า และกำหนดว่าสินค้าจะแสดงขายหน้าร้านหรือไม่")</p>
            </div>
            @if (!isStaff)
            {
                <div class="toolbar-right">
                    <button type="button" class="stock-btn ghost" data-bs-toggle="modal" data-bs-target="#categoryModal" onclick="openCategoryModal()">เพิ่มหมวดหมู่</button>
                    <button type="button" class="stock-btn primary" data-bs-toggle="modal" data-bs-target="#stockModal" onclick="openStockModal()">เพิ่มสินค้า</button>
                </div>
            }
        </div>

        @if (TempData["StockSuccess"] != null)
        {
            <div class="stock-alert success">@TempData["StockSuccess"]</div>
        }
        @if (TempData["StockError"] != null)
        {
            <div class="stock-alert error">@TempData["StockError"]</div>
        }
        @if (isStaff)
        {
            <div class="stock-note">สิทธิ์พนักงานในหน้านี้: ดูสินค้า, ปรับจำนวนสต๊อกแบบบวกหรือลบ, เปิดขายหรือปิดขายชั่วคราว, และกำหนดว่าสินค้ามีจำนวนจำกัด</div>
        }

        <div class="summary-grid">
            <div class="summary-card"><div class="summary-label">สินค้าทั้งหมด</div><div class="summary-value">@totalProducts</div><div class="summary-sub">จำนวนสินค้าทุกหมวด</div></div>
            <div class="summary-card"><div class="summary-label">หมดสต๊อก</div><div class="summary-value" style="color:#dc2626;">@outOfStock</div><div class="summary-sub">สินค้าเหลือ 0 ชิ้น</div></div>
            <div class="summary-card"><div class="summary-label">ใกล้หมด</div><div class="summary-value" style="color:#ea580c;">@lowStock</div><div class="summary-sub">เหลือไม่เกิน 10 ชิ้น</div></div>
            <div class="summary-card"><div class="summary-label">ปิดขาย</div><div class="summary-value" style="color:#be123c;">@pausedProducts</div><div class="summary-sub">ซ่อนจากหน้าร้าน</div></div>
            <div class="summary-card"><div class="summary-label">สินค้าจำกัดจำนวน</div><div class="summary-value" style="color:#c2410c;">@limitedProducts</div><div class="summary-sub">แสดงป้ายจำนวนจำกัด</div></div>
        </div>
    </div>

    <div class="stock-card">
        <div class="stock-header">
            <div>
                <h3 class="stock-title" style="font-size:1.15rem;">หมวดหมู่สินค้า</h3>
                <p class="stock-copy">หมวดหมู่ที่ใช้งานอยู่ในระบบจริง</p>
            </div>
        </div>

        @if (Model.Categories.Any())
        {
            <div class="category-grid">
                @foreach (var category in Model.Categories)
                {
                    <div class="category-card">
                        <div class="stock-header" style="align-items:flex-start;">
                            <div>
                                <div class="product-name">@category.CategoryName</div>
                                <div class="product-desc">@(string.IsNullOrWhiteSpace(category.Description) ? "ยังไม่มีรายละเอียดหมวดหมู่" : category.Description)</div>
                            </div>
                            @if (!isStaff)
                            {
                                <button type="button" class="stock-btn ghost" data-bs-toggle="modal" data-bs-target="#categoryModal" onclick="openCategoryModal(@category.CategoryId, '@category.CategoryName', '@(category.Description ?? "")')">แก้ไข</button>
                            }
                        </div>
                        <div class="staff-meta" style="margin-top:.8rem;">
                            <span class="stock-chip chip-neutral">@category.Stocks.Count รายการ</span>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">ยังไม่มีหมวดหมู่ในระบบ</div>
        }
    </div>

    <div class="stock-card">
        <div class="toolbar">
            <div class="toolbar-left">
                <input id="stockSearch" class="stock-search" type="text" placeholder="ค้นหาชื่อสินค้า..." />
                <select id="categoryFilter" class="stock-select">
                    <option value="all">ทุกหมวดหมู่</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.CategoryId">@category.CategoryName</option>
                    }
                </select>
            </div>
            @if (!isStaff)
            {
                <button type="button" class="stock-btn secondary" data-bs-toggle="modal" data-bs-target="#stockModal" onclick="openStockModal()">เพิ่มสินค้าใหม่</button>
            }
        </div>

        @if (Model.Products.Any())
        {
            <div class="stock-table-wrap">
                <table class="stock-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>สินค้า</th>
                            <th>หมวดหมู่</th>
                            <th>ราคา</th>
                            <th>สต๊อก</th>
                            <th>สถานะขาย</th>
                            <th>สถานะสต๊อก</th>
                            <th>จัดการ</th>
                        </tr>
                    </thead>
                    <tbody id="stockTableBody">
                        @foreach (var product in Model.Products)
                        {
                            var stockCount = product.Stock1 ?? 0;
                            var categoryName = product.Category?.CategoryName ?? "ไม่ระบุหมวดหมู่";
                            <tr class="stock-row stock-filter-row" data-search="@($"{product.ProductName} {product.Description} {categoryName}".ToLowerInvariant())" data-category-id="@product.CategoryId">
                                <td><span class="user-id-badge">#@product.ProductId</span></td>
                                <td>
                                    <div class="product-cell">
                                        <img class="product-thumb" src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? "/img/bagery1.png" : product.ImageUrl)" alt="@product.ProductName" />
                                        <div>
                                            <div class="product-name">@product.ProductName</div>
                                            <div class="product-desc">@(string.IsNullOrWhiteSpace(product.Description) ? "ยังไม่มีรายละเอียดสินค้า" : product.Description)</div>
                                            <div class="staff-meta" style="margin-top:.45rem;">
                                                @if (product.IsLimitedQuantity)
                                                {
                                                    <span class="stock-chip chip-warning">สินค้ามีจำนวนจำกัด</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="stock-chip chip-neutral">@categoryName</span></td>
                                <td>@((product.Price ?? 0).ToString("0.00")) บาท</td>
                                <td><span class="stock-chip chip-@GetStockClass(stockCount)">@stockCount ชิ้น</span></td>
                                <td><span class="stock-chip @(product.IsAvailable ? "chip-success" : "chip-danger")">@(product.IsAvailable ? "เปิดขาย" : "ปิดขาย")</span></td>
                                <td><span class="stock-chip chip-@GetStockClass(stockCount)">@GetStockStatus(stockCount)</span></td>
                                <td>
                                    @if (isStaff)
                                    {
                                        <button type="button" class="stock-btn ghost js-staff-edit-stock" data-bs-toggle="modal" data-bs-target="#staffStockModal" data-product-id="@product.ProductId" data-product-name="@product.ProductName" data-stock="@(product.Stock1 ?? 0)" data-is-available="@product.IsAvailable.ToString().ToLower()" data-is-limited-quantity="@product.IsLimitedQuantity.ToString().ToLower()" data-image-url="@(product.ImageUrl ?? "")" data-category-name="@categoryName">จัดการสต๊อก</button>
                                    }
                                    else
                                    {
                                        <button type="button" class="stock-btn ghost js-edit-stock" data-bs-toggle="modal" data-bs-target="#stockModal" data-product-id="@product.ProductId" data-product-name="@product.ProductName" data-description="@(product.Description ?? "")" data-price="@((product.Price ?? 0).ToString("0.##"))" data-stock="@(product.Stock1 ?? 0)" data-is-available="@product.IsAvailable.ToString().ToLower()" data-is-limited-quantity="@product.IsLimitedQuantity.ToString().ToLower()" data-category-id="@(product.CategoryId ?? 0)" data-image-url="@(product.ImageUrl ?? "")">แก้ไข</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div id="stockListStatus" class="list-status">กำลังแสดงรายการสินค้า</div>
        }
        else
        {
            <div class="empty-state">ยังไม่มีสินค้าในระบบ</div>
        }
    </div>
</div>

@if (!isStaff)
{
<div class="modal fade" id="categoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-panel">
            <div class="modal-header custom">
                <div><div class="field-label">Category</div><h5 id="categoryModalTitle" class="m-0 fw-bold">เพิ่มหมวดหมู่</h5></div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="SaveCategory" asp-controller="AdminStock" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="categoryIdInput" name="categoryId" value="0" />
                    <div class="form-grid">
                        <div class="full"><label class="field-label">ชื่อหมวดหมู่</label><input id="categoryNameInput" class="stock-input" type="text" name="categoryName" required /></div>
                        <div class="full"><label class="field-label">รายละเอียด</label><textarea id="categoryDescriptionInput" class="stock-textarea" name="description" rows="4"></textarea></div>
                    </div>
                    <div class="toolbar-right" style="margin-top:1rem;"><button type="submit" class="stock-btn primary">บันทึกหมวดหมู่</button></div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="stockModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content modal-panel">
            <div class="modal-header custom">
                <div><div class="field-label">Product</div><h5 id="stockModalTitle" class="m-0 fw-bold">เพิ่มสินค้า</h5></div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="SaveStock" asp-controller="AdminStock" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="productIdInput" name="productId" value="0" />
                    <input type="hidden" id="currentImageUrlInput" value="" />
                    <div class="form-grid">
                        <div class="full"><label class="field-label">ชื่อสินค้า</label><input id="productNameInput" class="stock-input" type="text" name="productName" required /></div>
                        <div><label class="field-label">หมวดหมู่</label><select id="productCategoryInput" class="stock-select" name="categoryId" required><option value="">เลือกหมวดหมู่</option>@foreach (var category in Model.Categories) { <option value="@category.CategoryId">@category.CategoryName</option> }</select></div>
                        <div><label class="field-label">ราคา</label><input id="productPriceInput" class="stock-input" type="number" step="0.01" min="0" name="price" required /></div>
                        <div><label class="field-label">จำนวนสต๊อก</label><input id="productStockInput" class="stock-input" type="number" min="0" name="stock1" required /></div>
                        <div class="full"><div class="toggle-box"><input id="productIsAvailableInput" type="checkbox" name="isAvailable" value="true" /><input type="hidden" name="isAvailable" value="false" /><label for="productIsAvailableInput">แสดงขายบนหน้าร้าน</label></div><div class="helper-text">ถ้าไม่ติ๊ก สินค้าจะถูกซ่อนจากหน้าเมนูของลูกค้า</div></div>
                        <div class="full"><div class="toggle-box"><input id="productIsLimitedQuantityInput" type="checkbox" name="isLimitedQuantity" value="true" /><input type="hidden" name="isLimitedQuantity" value="false" /><label for="productIsLimitedQuantityInput">สินค้ามีจำนวนจำกัด</label></div><div class="helper-text">แสดงป้ายสินค้ามีจำนวนจำกัดบนหน้าลูกค้า</div></div>
                        <div class="full"><label class="field-label">รายละเอียดสินค้า</label><textarea id="productDescriptionInput" class="stock-textarea" name="description" rows="4"></textarea></div>
                        <div class="full"><label class="field-label">รูปสินค้า</label><div class="image-picker"><div class="image-preview"><img id="productImagePreview" src="/img/bagery1.png" alt="ตัวอย่างรูปสินค้า" /></div><div><input id="productImageInput" class="stock-input" type="file" name="imageFile" accept="image/*" /><div class="helper-text">ถ้าไม่เลือกรูปใหม่ ระบบจะใช้รูปเดิมต่อไป</div></div></div></div>
                    </div>
                    <div class="toolbar-right" style="margin-top:1rem;"><button type="submit" class="stock-btn primary">บันทึกสินค้า</button></div>
                </form>
            </div>
        </div>
    </div>
</div>
}

<div class="modal fade" id="staffStockModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content modal-panel">
            <div class="modal-header custom">
                <div><div class="field-label">Stock Update</div><h5 class="m-0 fw-bold">จัดการสต๊อกสินค้า</h5></div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="UpdateStockSettings" asp-controller="AdminStock" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="staffProductIdInput" name="productId" value="0" />
                    <div class="staff-preview">
                        <div class="product-cell"><img id="staffProductImagePreview" class="product-thumb" src="/img/bagery1.png" alt="รูปสินค้า" /><div><div id="staffProductNameLabel" class="product-name">สินค้า</div><div id="staffProductCategoryLabel" class="product-desc">หมวดหมู่</div></div></div>
                        <div class="staff-meta" style="margin-top:.8rem;"><span id="staffCurrentStockLabel" class="stock-chip chip-neutral">คงเหลือ 0 ชิ้น</span><span id="staffCurrentSaleStatusLabel" class="stock-chip chip-neutral">เปิดขาย</span><span id="staffCurrentLimitedLabel" class="stock-chip chip-neutral">สินค้าทั่วไป</span></div>
                    </div>
                    <div class="form-grid" style="margin-top:1rem;">
                        <div class="full"><label class="field-label">ปรับจำนวนสต๊อก</label><input id="staffStockAdjustmentInput" class="stock-input" type="number" name="stockAdjustment" value="0" /><div class="helper-text">ใส่ค่าบวก เช่น 20 เมื่ออบเพิ่ม และค่าลบ เช่น -5 เมื่อตัดของเสีย</div></div>
                        <div class="full"><div class="toggle-box"><input id="staffIsAvailableInput" type="checkbox" name="isAvailable" value="true" /><input type="hidden" name="isAvailable" value="false" /><label for="staffIsAvailableInput">เปิดขายบนหน้าร้าน</label></div><div class="helper-text">ถ้าไม่ติ๊ก สินค้าจะถูกปิดขายชั่วคราวและซ่อนจากหน้าเมนู</div></div>
                        <div class="full"><div class="toggle-box"><input id="staffIsLimitedQuantityInput" type="checkbox" name="isLimitedQuantity" value="true" /><input type="hidden" name="isLimitedQuantity" value="false" /><label for="staffIsLimitedQuantityInput">สินค้ามีจำนวนจำกัด</label></div></div>
                    </div>
                    <div class="toolbar-right" style="margin-top:1rem;"><button type="submit" class="stock-btn primary">บันทึกการเปลี่ยนแปลง</button></div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openCategoryModal(categoryId = 0, categoryName = '', description = '') {
        const title = document.getElementById('categoryModalTitle');
        if (!title) return;
        title.textContent = categoryId > 0 ? 'แก้ไขหมวดหมู่' : 'เพิ่มหมวดหมู่';
        document.getElementById('categoryIdInput').value = categoryId;
        document.getElementById('categoryNameInput').value = categoryName;
        document.getElementById('categoryDescriptionInput').value = description;
    }

    function openStockModal(productId = 0, productName = '', description = '', price = '', stock = '', isAvailable = true, isLimitedQuantity = false, categoryId = '', imageUrl = '') {
        const title = document.getElementById('stockModalTitle');
        if (!title) return;
        title.textContent = productId > 0 ? 'แก้ไขสินค้า' : 'เพิ่มสินค้า';
        document.getElementById('productIdInput').value = productId;
        document.getElementById('productNameInput').value = productName;
        document.getElementById('productDescriptionInput').value = description;
        document.getElementById('productPriceInput').value = price;
        document.getElementById('productStockInput').value = stock;
        document.getElementById('productIsAvailableInput').checked = isAvailable === true || isAvailable === 'true';
        document.getElementById('productIsLimitedQuantityInput').checked = isLimitedQuantity === true || isLimitedQuantity === 'true';
        document.getElementById('productCategoryInput').value = categoryId;
        document.getElementById('currentImageUrlInput').value = imageUrl;
        document.getElementById('productImageInput').value = '';
        document.getElementById('productImagePreview').src = imageUrl || '/img/bagery1.png';
    }

    function openStaffStockModal(productId = 0, productName = '', stock = 0, isAvailable = true, isLimitedQuantity = false, imageUrl = '', categoryName = '') {
        document.getElementById('staffProductIdInput').value = productId;
        document.getElementById('staffStockAdjustmentInput').value = 0;
        document.getElementById('staffIsAvailableInput').checked = isAvailable === true || isAvailable === 'true';
        document.getElementById('staffIsLimitedQuantityInput').checked = isLimitedQuantity === true || isLimitedQuantity === 'true';
        document.getElementById('staffProductImagePreview').src = imageUrl || '/img/bagery1.png';
        document.getElementById('staffProductNameLabel').textContent = productName;
        document.getElementById('staffProductCategoryLabel').textContent = categoryName || 'ไม่ระบุหมวดหมู่';
        document.getElementById('staffCurrentStockLabel').textContent = `คงเหลือ ${stock} ชิ้น`;
        document.getElementById('staffCurrentSaleStatusLabel').textContent = (isAvailable === true || isAvailable === 'true') ? 'เปิดขาย' : 'ปิดขาย';
        document.getElementById('staffCurrentSaleStatusLabel').className = `stock-chip ${(isAvailable === true || isAvailable === 'true') ? 'chip-success' : 'chip-danger'}`;
        document.getElementById('staffCurrentLimitedLabel').textContent = (isLimitedQuantity === true || isLimitedQuantity === 'true') ? 'สินค้ามีจำนวนจำกัด' : 'สินค้าทั่วไป';
        document.getElementById('staffCurrentLimitedLabel').className = `stock-chip ${(isLimitedQuantity === true || isLimitedQuantity === 'true') ? 'chip-warning' : 'chip-neutral'}`;
    }

    document.addEventListener('DOMContentLoaded', function () {
        const searchInput = document.getElementById('stockSearch');
        const categoryFilter = document.getElementById('categoryFilter');
        const rows = Array.from(document.querySelectorAll('.stock-filter-row'));
        const status = document.getElementById('stockListStatus');
        const editButtons = Array.from(document.querySelectorAll('.js-edit-stock'));
        const staffEditButtons = Array.from(document.querySelectorAll('.js-staff-edit-stock'));
        const imageInput = document.getElementById('productImageInput');

        editButtons.forEach(button => button.addEventListener('click', function () {
            openStockModal(this.dataset.productId || 0, this.dataset.productName || '', this.dataset.description || '', this.dataset.price || '', this.dataset.stock || '', this.dataset.isAvailable || 'true', this.dataset.isLimitedQuantity || 'false', this.dataset.categoryId || '', this.dataset.imageUrl || '');
        }));

        staffEditButtons.forEach(button => button.addEventListener('click', function () {
            openStaffStockModal(this.dataset.productId || 0, this.dataset.productName || '', this.dataset.stock || 0, this.dataset.isAvailable || 'true', this.dataset.isLimitedQuantity || 'false', this.dataset.imageUrl || '', this.dataset.categoryName || '');
        }));

        if (imageInput) {
            imageInput.addEventListener('change', function (event) {
                const file = event.target.files && event.target.files[0];
                const preview = document.getElementById('productImagePreview');
                if (!file) {
                    preview.src = document.getElementById('currentImageUrlInput').value || '/img/bagery1.png';
                    return;
                }
                const reader = new FileReader();
                reader.onload = loadEvent => preview.src = loadEvent.target?.result || '/img/bagery1.png';
                reader.readAsDataURL(file);
            });
        }

        function renderRows() {
            const keyword = (searchInput?.value || '').trim().toLowerCase();
            const categoryId = categoryFilter?.value || 'all';
            let visible = 0;

            rows.forEach(row => {
                const haystack = row.getAttribute('data-search') || '';
                const rowCategoryId = row.getAttribute('data-category-id') || '';
                const matchKeyword = !keyword || haystack.includes(keyword);
                const matchCategory = categoryId === 'all' || rowCategoryId === categoryId;
                const show = matchKeyword && matchCategory;
                row.style.display = show ? '' : 'none';
                if (show) visible += 1;
            });

            if (status) status.textContent = visible ? `แสดง ${visible} รายการ` : 'ไม่พบรายการสินค้าตามเงื่อนไขที่เลือก';
        }

        if (searchInput) searchInput.addEventListener('input', renderRows);
        if (categoryFilter) categoryFilter.addEventListener('change', renderRows);
        renderRows();
    });
</script>
}
