@{
    ViewBag.Title = "จัดการสินค้า & สต๊อก";
    ViewBag.PageTitle = "จัดการสินค้า & สต๊อก";
    Layout = "_AdminLayout";
}

@* ─── View 1: หมวดหมู่ ─── *@
<div id="view-category">
    <div class="dashboard-card" style="margin-bottom:16px;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <h3 class="dashboard-card-title" style="margin:0;">
                <i class="fas fa-th-large"></i> หมวดหมู่สินค้า
            </h3>
            <div style="display:flex; gap:10px;">
                <button class="btn btn-dashboard primary" onclick="openAddCategoryModal()">
                    <i class="fas fa-plus"></i> เพิ่มหมวดหมู่
                </button>
                <button onclick="showView('overview')"
                    style="background:#4e54c8; color:#fff; border:none; border-radius:8px;
                           padding:8px 18px; font-weight:600; cursor:pointer; font-size:14px;
                           box-shadow:0 2px 8px rgba(78,84,200,0.3); display:flex; align-items:center; gap:6px;">
                    <i class="fas fa-chart-bar"></i> ดูสต๊อกภาพรวม
                </button>
            </div>
        </div>
    </div>

    <div id="category-grid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:16px; padding:4px 0;">
        @* Category Card: เค้ก *@
        <div class="cat-card" onclick="showView('products', 'เค้ก', '🍰')">
            <div class="cat-icon">🍰</div>
            <div class="cat-name">เค้ก</div>
            <div class="cat-count">3 รายการ</div>
        </div>
        @* Category Card: คุกกี้ *@
        <div class="cat-card" onclick="showView('products', 'คุกกี้', '🍪')">
            <div class="cat-icon">🍪</div>
            <div class="cat-name">คุกกี้</div>
            <div class="cat-count">2 รายการ</div>
        </div>
        @* Category Card: ขนมปัง *@
        <div class="cat-card" onclick="showView('products', 'ขนมปัง', '🍞')">
            <div class="cat-icon">🍞</div>
            <div class="cat-name">ขนมปัง</div>
            <div class="cat-count">2 รายการ</div>
        </div>
        @* Category Card: เครื่องดื่ม *@
        <div class="cat-card" onclick="showView('products', 'เครื่องดื่ม', '🥤')">
            <div class="cat-icon">🥤</div>
            <div class="cat-name">เครื่องดื่ม</div>
            <div class="cat-count">2 รายการ</div>
        </div>
    </div>
</div>

@* ─── View 2: สินค้าในหมวด ─── *@
<div id="view-products" style="display:none;">
    <div class="dashboard-card">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; flex-wrap:wrap; gap:10px;">
            <div style="display:flex; align-items:center; gap:12px;">
                <button onclick="showView('category')"
                    style="background:none; border:1.5px solid #ccc; border-radius:8px;
                           padding:6px 14px; cursor:pointer; font-size:13px; display:flex; align-items:center; gap:6px;">
                    <i class="fas fa-arrow-left"></i> หมวดหมู่
                </button>
                <h3 class="dashboard-card-title" style="margin:0;">
                    <span id="cat-icon-title"></span>
                    <span id="cat-name-title"></span>
                </h3>
            </div>
            <div style="display:flex; gap:10px;">
                <button onclick="showView('overview')"
                    style="background:#f0f0ff; color:#4e54c8; border:1.5px solid #4e54c8; border-radius:8px;
                           padding:6px 14px; cursor:pointer; font-size:13px; font-weight:600; display:flex; align-items:center; gap:6px;">
                    <i class="fas fa-chart-bar"></i> ดูสต๊อกภาพรวม
                </button>
                <button class="btn btn-dashboard primary" onclick="alert('เพิ่มสินค้าในหมวดนี้')">
                    <i class="fas fa-plus"></i> เพิ่มสินค้า
                </button>
            </div>
        </div>

        <div style="margin-bottom:16px;">
            <input type="text" class="form-control" placeholder="🔍 ค้นหาสินค้าในหมวดนี้..." />
        </div>

        <table class="table table-hover">
            <thead>
                <tr>
                    <th>รหัสสินค้า</th>
                    <th>ชื่อสินค้า</th>
                    <th>ราคา</th>
                    <th>สต๊อก</th>
                    <th>สถานะ</th>
                    <th>การกระทำ</th>
                </tr>
            </thead>
            <tbody id="product-tbody">
            </tbody>
        </table>
    </div>
</div>

