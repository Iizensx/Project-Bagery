@model List<_66022380.Models.Db.User>

@{
    ViewBag.Title = "จัดการผู้ใช้งาน";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="dashboard-card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h3 class="dashboard-card-title" style="margin: 0;">
            <i class="fas fa-users"></i> รายชื่อผู้ใช้งาน
        </h3>
        <a asp-action="Lab10" asp-controller="Account" class="btn btn-success btn-sm">
            <i class="fas fa-plus"></i> เพิ่มผู้ใช้งาน
        </a>
    </div>

    <div style="margin-bottom: 20px;">
        <input type="text" class="form-control" placeholder="🔍 ค้นหาผู้ใช้งาน..." />
    </div>

    <table class="table table-hover">
        <thead>
            <tr>
                <th>รหัสผู้ใช้</th>
                <th>ชื่อผู้ใช้</th>
                <th>อีเมล</th>
                <th>เบอร์โทร</th>
                <th>บทบาท</th>
                <th>การกระทำ</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.UserId</td>
                    <td>@user.Username</td>
                    <td>@(user.Email ?? "-")</td>
                    <td>@(user.Phone ?? "-")</td>
                    <td>
                        @if (user.Role?.RoleName == "Admin")
                        {
                            <span class="badge bg-primary">Admin</span>
                        }
                        else if (user.Role?.RoleName == "Staff")
                        {
                            <span class="badge bg-warning text-dark">Staff</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">User</span>
                        }
                    </td>
                    <td>
    <a asp-route-id="@user.UserId" asp-action="Lab10" asp-controller="Account" class="btn btn-sm btn-dashboard primary">แก้ไข</a>
    <a asp-route-id="@user.UserId" asp-action="Lab10D" asp-controller="Account" class="btn btn-sm btn-dashboard danger">ลบ</a>
</td>
                </tr>
            }
        </tbody>
    </table>
</div>