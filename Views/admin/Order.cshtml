@model List<_66022380.Models.Db.Order>

@{
    ViewBag.Title = "จัดการออเดอร์";
    ViewBag.PageTitle = "จัดการออเดอร์";
    Layout = "_AdminLayout";
}

<div class="dashboard-card">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <h3 class="dashboard-card-title" style="margin:0;">
            <i class="fas fa-shopping-bag"></i> รายการออเดอร์ทั้งหมด
        </h3>
        <span style="font-size:13px; color:#888;">
            อัปเดตล่าสุด: <span id="lastUpdate"></span>
        </span>
    </div>

    <div style="display:flex; gap:8px; margin-bottom:20px; flex-wrap:wrap;">
        <button class="filter-btn active" onclick="filterOrders('all', this)">ทั้งหมด</button>
        <button class="filter-btn pending" onclick="filterOrders('Pending', this)">Pending</button>
        <button class="filter-btn paid" onclick="filterOrders('Paid', this)">Paid</button>
        <button class="filter-btn preparing" onclick="filterOrders('Preparing', this)">Preparing</button>
        <button class="filter-btn shipped" onclick="filterOrders('Shipped', this)">Shipped</button>
        <button class="filter-btn completed" onclick="filterOrders('Completed', this)">Completed</button>
        <button class="filter-btn cancelled" onclick="filterOrders('Cancelled', this)">Cancelled</button>
    </div>

    <div style="margin-bottom:20px;">
        <input type="text" id="searchInput" class="form-control"     placeholder="🔍 ค้นหา Order ID หรือชื่อลูกค้า..."
               oninput="searchOrders()" />
    </div>

    <table class="table table-hover" id="orderTable">
        <thead>
            <tr>
                <th>Order ID</th>
                <th>ลูกค้า</th>
                <th>รายการ</th>
                <th>ยอดรวม</th>
                <th>สถานะออเดอร์</th>
                <th>สถานะชำระ</th>
                <th>สลิป</th>
                <th>การจัดการ</th>
            </tr>
        </thead>
        <tbody id="orderBody">
            @foreach (var order in Model)
            {
                <tr data-status="@order.Status" data-id="ORD-@order.OrderId" data-customer="@order.User?.Username">
                    <td><strong>ORD-@order.OrderId</strong></td>
                    <td>@(order.User?.Username ?? "-")</td>
                    <td>
                        <span style="font-size:12px; color:#555;">
                            @string.Join(", ", order.Orderdetails.Select(d => $"{d.Product?.ProductName} x{d.Quantity}"))
                        </span>
                    </td>
                    <td>฿@order.TotalAmount</td>
                    <td>
                        @{
                            var statusClass = order.Status switch
                            {
                                "Paid" => "bg-success",
                                "Preparing" => "bg-info",
                                "Pending" => "bg-warning text-dark",
                                "Shipped" => "bg-primary",
                                "Completed" => "bg-dark",
                                "Cancelled" => "bg-danger",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @statusClass">@order.Status</span>
                    </td>
                    <td>
                        @{
                            var payClass = order.PaymentStatus switch
                            {
                                "Paid" => "bg-success",
                                "PendingVerify" => "bg-warning text-dark",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @payClass">@(order.PaymentStatus ?? "Pending")</span>
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(order.SlipImagePath))
                        {
                            <a href="@order.SlipImagePath" target="_blank">
                                <img src="@order.SlipImagePath"
                                     style="width:50px;height:50px;object-fit:cover;border-radius:8px;border:1px solid #eee;">
                            </a>
                        }
                        else
                        {
                            <span style="color:#aaa; font-size:12px;">ยังไม่มี</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-dashboard primary"                         onclick="viewOrder(@order.OrderId)">
                            <i class="fas fa-eye"></i> ดู
                        </button>

                        @if (order.PaymentStatus == "PendingVerify")
                        {
                            <button class="btn btn-sm btn-success"                     style="border-radius:6px; padding:4px 10px;"
                                    onclick="confirmPayment(@order.OrderId, this)">
                                ยืนยันชำระ
                            </button>
                        }
                        else if (order.Status == "Paid")
                        {
                            <button class="btn btn-sm"
                                    style="background:#6c63ff;color:#fff;border:none;border-radius:6px;padding:4px 10px;"
                                    onclick="acceptOrder(this, @order.OrderId)">
                                รับออเดอร์
                            </button>
                        }
                        else if (order.Status == "Preparing")
                        {
                            <button class="btn btn-sm"
                                    style="background:#17a2b8;color:#fff;border:none;border-radius:6px;padding:4px 10px;"
                                    onclick="shipOrder(this, @order.OrderId)">
                                จัดส่งสินค้า
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
</div>

@section Styles {
<style>
    .filter-btn {
        padding: 6px 16px;
        border: 1.5px solid #ddd;
        border-radius: 20px;
        background: #fff;
        cursor: pointer;
        font-size: 13px;
        transition: all 0.2s;
        font-weight: 500;
    }

    .filter-btn.active {
        background: #4e54c8;
        color: #fff;
        border-color: #4e54c8;
    }

    .filter-btn.pending {
        border-color: #ffc107;
        color: #856404;
    }

    .filter-btn.pending.active {
        background: #ffc107;
        color: #fff;
        border-color: #ffc107;
    }

    .filter-btn.paid {
        border-color: #28a745;
        color: #155724;
    }

    .filter-btn.paid.active {
        background: #28a745;
        color: #fff;
        border-color: #28a745;
    }

    .filter-btn.preparing {
        border-color: #17a2b8;
        color: #0c5460;
    }

    .filter-btn.preparing.active {
        background: #17a2b8;
        color: #fff;
        border-color: #17a2b8;
    }

    .filter-btn.shipped {
        border-color: #007bff;
        color: #004085;
    }

    .filter-btn.shipped.active {
        background: #007bff;
        color: #fff;
        border-color: #007bff;
    }

    .filter-btn.cancelled {
        border-color: #dc3545;
        color: #721c24;
    }

    .filter-btn.completed {
        border-color: #343a40;
        color: #343a40;
    }

    .filter-btn.cancelled.active {
        background: #dc3545;
        color: #fff;
        border-color: #dc3545;
    }

    .filter-btn.completed.active {
        background: #343a40;
        color: #fff;
        border-color: #343a40;
    }

    #orderModal .modal-body {
        max-height: 70vh;
        overflow-y: auto;
    }
    
    .order-detail-item {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 0;
        border-bottom: 1px solid #eee;
    }
    
    .slip-image-container {
        text-align: center;
        margin: 1rem 0;
    }
    
    .slip-image-container img {
        max-width: 100%;
        max-height: 400px;
        border-radius: 8px;
        border: 1px solid #ddd;
    }
</style>
}

<!-- Modal for Order Details -->
<div class="modal fade" id="orderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">รายละเอียดออเดอร์</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="orderModalBody">
                <p class="text-center text-muted">กำลังโหลด...</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Global functions for Order Management
    document.getElementById('lastUpdate').textContent = new Date().toLocaleTimeString('th-TH');

    function filterOrders(status, btn) {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('#orderBody tr').forEach(row => {
            row.style.display = (status === 'all' || row.dataset.status === status) ? '' : 'none';
        });
    }

    function searchOrders() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('#orderBody tr').forEach(row => {
            const id = row.dataset.id?.toLowerCase() || '';
            const cust = row.dataset.customer?.toLowerCase() || '';
            row.style.display = (id.includes(q) || cust.includes(q)) ? '' : 'none';
        });
    }

    async function confirmPayment(orderId, btn) {
        if (!confirm('ยืนยันการชำระเงินออเดอร์นี้?')) return;
        btn.disabled = true;
        btn.textContent = 'กำลังยืนยัน...';

        try {
            const res = await fetch('/Account/ConfirmPayment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `orderId=${orderId}`
            });
            const data = await res.json();

            if (data.success) {
                alert(data.message);
                btn.closest('td').innerHTML = '<span style="color:green;font-weight:600;">ยืนยันแล้ว</span>';
            } else {
                alert(data.message);
                btn.disabled = false;
                btn.textContent = 'ยืนยันชำระ';
            }
        } catch (error) {
            alert('เกิดข้อผิดพลาด: ' + error.message);
            btn.disabled = false;
            btn.textContent = 'ยืนยันชำระ';
        }
    }

    async function acceptOrder(btn, orderId) {
        if (!confirm(`รับออเดอร์ ORD-${orderId}?`)) return;
        try {
            const res = await fetch('/Account/AcceptOrder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `orderId=${orderId}`
            });
            const data = await res.json();
            if (data.success) {
                alert('ยอมรับออเดอร์เรียบร้อย');
                location.reload();
            } else {
                alert(data.message);
            }
        } catch (error) {
            alert('เกิดข้อผิดพลาด: ' + error.message);
        }
    }

    async function shipOrder(btn, orderId) {
        if (!confirm(`ยืนยันจัดส่งสินค้า ORD-${orderId}?`)) return;
        try {
            const res = await fetch('/Account/ShipOrder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `orderId=${orderId}`
            });
            const data = await res.json();
            if (data.success) {
                alert('จัดส่งสินค้าเรียบร้อย');
                location.reload();
            } else {
                alert(data.message);
            }
        } catch (error) {
            alert('เกิดข้อผิดพลาด: ' + error.message);
        }
    }

    async function viewOrder(orderId) {
        try {
            const res = await fetch(`/Account/GetOrderDetails?orderId=${orderId}`);
            const data = await res.json();
            
            if (!data.success) {
                alert('ไม่สามารถโหลดรายละเอียดออเดอร์');
                return;
            }

            let html = `
                <div style="margin-bottom: 1.5rem;">
                    <h6 style="color: #333; font-weight: 600; margin-bottom: 0.5rem;">ข้อมูลลูกค้า</h6>
                    <div class="order-detail-item">
                        <span>ชื่อ:</span>
                        <strong>${data.customerName || '-'}</strong>
                    </div>
                    <div class="order-detail-item">
                        <span>อีเมล:</span>
                        <strong>${data.customerEmail || '-'}</strong>
                    </div>
                    <div class="order-detail-item">
                        <span>เบอร์โทร:</span>
                        <strong>${data.customerPhone || '-'}</strong>
                    </div>
                </div>

                <div style="margin-bottom: 1.5rem;">
                    <h6 style="color: #333; font-weight: 600; margin-bottom: 0.5rem;">ข้อมูลออเดอร์</h6>
                    <div class="order-detail-item">
                        <span>Order ID:</span>
                        <strong>ORD-${data.orderId}</strong>
                    </div>
                    <div class="order-detail-item">
                        <span>วันที่สั่ง:</span>
                        <strong>${data.orderDate}</strong>
                    </div>
                    <div class="order-detail-item">
                        <span>สถานะออเดอร์:</span>
                        <span class="badge ${getStatusBadge(data.status)}">${data.status}</span>
                    </div>
                    <div class="order-detail-item">
                        <span>สถานะชำระ:</span>
                        <span class="badge ${getPaymentBadge(data.paymentStatus)}">${data.paymentStatus}</span>
                    </div>
                </div>

                <div style="margin-bottom: 1.5rem;">
                    <h6 style="color: #333; font-weight: 600; margin-bottom: 0.5rem;">รายการสินค้า</h6>
                    ${data.items.map(item => `
                        <div class="order-detail-item">
                            <span>${item.productName} x${item.quantity}</span>
                            <strong>฿${(item.subtotal || 0).toLocaleString('th-TH', {minimumFractionDigits: 2})}</strong>
                        </div>
                    `).join('')}
                    <div class="order-detail-item" style="border-top: 2px solid #333; padding-top: 1rem; font-weight: 600;">
                        <span>ยอดรวมทั้งหมด:</span>
                        <strong style="color: #ff6b6b;">฿${(data.totalAmount || 0).toLocaleString('th-TH', {minimumFractionDigits: 2})}</strong>
                    </div>
                </div>
            `;

            if (data.slipImagePath) {
                html += `
                    <div style="margin-bottom: 1.5rem;">
                        <h6 style="color: #333; font-weight: 600; margin-bottom: 0.5rem;">สลิปการชำระเงิน</h6>
                        <div class="slip-image-container">
                            <img src="${data.slipImagePath}" alt="Slip Image" />
                        </div>
                    </div>
                `;
            }

            document.getElementById('orderModalBody').innerHTML = html;
            const modalEl = document.getElementById('orderModal');
            bootstrap.Modal.getOrCreateInstance(modalEl).show();
        } catch (error) {
            alert('เกิดข้อผิดพลาด: ' + error.message);
        }
    }

    function getStatusBadge(status) {
        const badges = {
            'Paid': 'bg-success',
            'Preparing': 'bg-info',
            'Pending': 'bg-warning text-dark',
            'Shipped': 'bg-primary',
            'Completed': 'bg-dark',
            'Cancelled': 'bg-danger'
        };
        return badges[status] || 'bg-secondary';
    }

    function getPaymentBadge(status) {
        const badges = {
            'Paid': 'bg-success',
            'PendingVerify': 'bg-warning text-dark',
            'Pending': 'bg-secondary'
        };
        return badges[status] || 'bg-secondary';
    }
</script>
}
